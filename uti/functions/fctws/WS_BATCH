#----------------------------------------------------------------------------
# FUNCTION: WS_BATCH
#
# Input parameters:
# WS_BATCH_NAME  : Name of the Spring bean that contains the batch service to
#                  call (mandatory)
# WS_INPUT_FILE  : Optional parameter that contains the path of a file that
#                  will be uploaded to the Java server and consumed by the Java
#                  service.
# WS_OUTPUT_FILE : Optional parameter that contains the path of a file that
#                  will be created by the Java batch service upon completion
#                  of the call.
# WS_PARAMS      : Optional file that contains parameters to pass to the batch
#                  service. Each line of the file is decomposed in two fields,
#                  separated by a space: name value. Can be constructed with
#                  help of WS_PARAMS_TEXT function.
# WS_SYNCHRONOUS : Optional parameter that can be set to true to force
#                  synchronous execution of the batch, or to false to force
#                  asynchronous execution in a thread pool. By default, all
#                  batches are executed in synchronous mode.
# WS_OPT         : Optional parameters that can be passed to the curl command.
# WS_DEBUG       : If true, trace the HTTP request and response to the log.
#
# Global variables:
# NCHAIN, NJOB, NSTEP
# BATCH_SRV_HOSTNAME    Hostname where the Java batch application is deployed.
#                       If unset in environment file, defaults to localhost.
# BATCH_SRV_PORT        TCP port where the Java batch application is deployed.
#                       If unset in environment file, defaults to 8080.
# BATCH_SRV_APPLI       Name of the Java application for batches.
#                       If unset in environment file, defaults to
#                       omega2-batch-web.
#
# Subject: Technical function that allows to call a Java batch running in an
# Application Server (Web Service call). Needs the "curl" command to be
# installed on Unix/Linux.
# Return 0 if OK, >0 otherwise
#----------------------------------------------------------------------------
WS_BATCH() {
	if [ "${RP}" = "" -o "${RP}" = "${NSTEP}" -o "${ADT}" != "" ]; then
		ADT="${NSTEP}"

		STEP_PRG=WS_BATCH
		STEPSTART

		# Check mandatory parameters
		if [ -z "${WS_BATCH_NAME}" ]; then
			echo "# Missing required parameter WS_BATCH_NAME"
			STEPEND 99
			return 99
		fi

		# Check input file
		if [ -n "${WS_INPUT_FILE}" ]; then
			if [ ! -s ${WS_INPUT_FILE} ]; then
				echo '# Information: No input file for processing'
				STEPEND 0
				# Clear global variables
				_WS_FINALLY
				unset WS_BATCH_NAME
				return 0
			fi
		fi

		# Synchronous call by default
		WS_SYNCHRONOUS=${WS_SYNCHRONOUS:-true}

		# Perform the call. Global variables that can be overridden in environment
		# file:
		#	BATCH_SRV_HOSTNAME
		#	BATCH_SRV_PORT
		#	BATCH_SRV_APPLI
		# get the first 3 characters of the ws_batch_name
		isLIRAS=$(echo "${WS_BATCH_NAME}" | cut -c-3 ) 
		if [ "${isLIRAS}" = "LIR" ]
		then 
			_DO_WS_CALL ${BATCH_SRV_HOSTNAME_LIR:-localhost} ${BATCH_SRV_PORT_LIR:-8080} ${BATCH_SRV_APPLI_LIR:-liras-batch-web} batch start ${WS_BATCH_NAME} 1
		else 
			_DO_WS_CALL ${BATCH_SRV_HOSTNAME:-localhost} ${BATCH_SRV_PORT:-8080} ${BATCH_SRV_APPLI:-omega2-batch-web} batch start ${WS_BATCH_NAME} 1
		fi
		rc=$?
		STEPEND $rc
		unset WS_BATCH_NAME
		return $rc
	fi
}
