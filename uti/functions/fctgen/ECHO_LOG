#----------------------------------------------------------------------------
# FUNCTION: ECHO_LOG
# no input parameter:
#----------------------------------------------------------------------------
ECHO_LOG () {
	case ${JOB_LOG_OUTPUT} in
	"STANDARD")
		echo ${@}
		;;
	"TEE")
		echo ${@} 2>&1 | ${TEE}
		;;
	"DLOG")
		echo ${@} >> ${FLOG}
		;;
	*)
		echo ${@}
		;;
	esac
}
