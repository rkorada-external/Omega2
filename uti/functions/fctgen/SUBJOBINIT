SUBJOBINIT ()
{
NSUBJOB=${NSTEP}_${NSUBJOB}
echo '#-------------------------------------------------------------------------' 
echo '# Start of subjob   : ' ${NSUBJOB} " Date : " `date +"%Y/%m/%d %H:%M:%S"` 
echo "# Current PID     : " $$ 
echo '#-------------------------------------------------------------------------' 
GET_SQL_LOGIN_PSWD $SRV
if [ $? -ne 0 ]
then
  STEPEND 99
fi

}

