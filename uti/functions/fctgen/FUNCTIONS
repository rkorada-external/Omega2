# Trie des parametres
#-------------------------------------------------------------------------------
# Declaration des fonctions de trie des parametres
#-------------------------------------------------
function exit_faild
{
   for f in ${TMPFIL}
   do
     rm -f ${DFILT}/${f}
   done

   echo "#========================================================================="
   echo "#                            Comparison failed                            "
   echo "#                       Abnormal DATACAMP terminate                       "
   echo "# For more information see ano file in ${DFILT}                           "
   echo "# ${DATACMP_ano}                                                          "
   echo "#========================================================================="
   exit $1
}
function exit_success
{
   for f in ${TMPFIL}
   do
     rm -f ${DFILT}/${f}
   done

   rm ${DATACMP_ano} 2>&1 1>/dev/null
   echo "#========================================================================="
   echo "#                            Comparison success                           "
   echo "#                         normal DATACAMP terminate                       "
   echo "#========================================================================="
   exit $1
}


# fonction pour recuperer la liste des fichier a comparer
# (les fichiers du cote gauche de Syncsort)
#--------------------------------------------------------
function get_left_side_files
{
while [ $I -lt ${#PARAM[@]} ]
do
   if [[ ${PARAM[$I]} =~ ^-(.)+ ]]; then
      read_param
   fi
   LINF[${#LINF[@]}]=${PARAM[$I]}
   let "I++"
   read_param
done
}


