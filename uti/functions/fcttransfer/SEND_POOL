# Get files to send to the same place
for FDAT in ${LIST_FILE}
do
  NEWFILE=`basename ${FDAT} | awk '{gsub(PREFIX,NEW_PREFIX"_"ID); print}' PREFIX=${SEND_POOL_PREFIX} NEW_PREFIX=${NCHAIN} ID=${NUM}`

  # Insert line into the ftx file
  DATA="YES"
  FSIZE=`ls -l ${FDAT} | awk '{print $5}'`
  printf "%s:%s\n" "${NEWFILE}" "${FSIZE}" >> ${DFILT}/${FFTX}   
  
