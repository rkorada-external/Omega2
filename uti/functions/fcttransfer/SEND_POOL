then
  continue
fi

TRGT=${SEND_POOL_SITE}
PUT_POOL  
}

#****************************** SEND_POOL ************************
SEND_POOL () {

[ "${FCT_DEBUG}" = "YES" ] && set -x

if [ "${RP}" = ""  -o "${RP}" = "${NSTEP}" -o "${ADT}" != "" ]
then
  ADT="${NSTEP}"
  STEP_PRG=SEND_POOL
  STEPSTART

  if [ "${SEND_POOL_FILES}" = "" ]
  then
    echo "# !!! No file to transfer"
    STEPEND 0
    return 0
  fi

  # Get list of files to send to pool
  LIST_FILE=`echo ${SEND_POOL_FILES} | awk 'BEGIN{RS="|";ORS=" "} {print $0}'`

  GET_EXTNUM_CHAIN=${NCHAIN_SHORT}
  GET_EXTNUM_O=${DFILT}/${NSTEP}_${IB}_TFILSUP.dat
  GET_EXTNUM

  NUM=`cat ${GET_EXTNUM_O}`
  /bin/rm -f ${GET_EXTNUM_O} >/dev/null 2>&1

  case ${SEND_POOL_TYPE} in    

	SITE)
	        if [ "${SEND_POOL_SITE}" = "" ]
	        then
		  echo "#	!!! No site defined"
		  STEPEND 2
		fi
		SEND_POOL_SITE;;

	SSD)
		SEND_POOL_SSD;;

	SSDESB)
		SEND_POOL_SSDESB;;

	*)
		echo "# No good type defined in variable SEND_POOL_TYPE"
		STEPEND 3;;

  esac
  STEPEND 0
fi
}



