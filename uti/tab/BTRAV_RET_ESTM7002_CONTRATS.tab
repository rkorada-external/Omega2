END
go
/*
 * Creating TABLE dbo.RET_ESTM7002_CONTRATS
 */
CREATE TABLE RET_ESTM7002_CONTRATS (
    CTR_NF       URETCTR_NF    NOT NULL,
    END_NT       UEND_NT       NOT NULL,
    SEC_NF       USEC_NF       NOT NULL,
    UWY_NF       UUWY_NF       NOT NULL,
    UW_NT        UUW_NT        NOT NULL,

    RETCTR_NF    URETCTR_NF    NULL,
    RETEND_NT    UEND_NT       NULL,
    RETSEC_NF    URETSEC_NF    NULL,
    RTY_NF       UUWY_NF       NULL,
    RETUW_NT     UUW_NT        NULL,

    RCL_NF       UCLM_NF       NULL,
    PLC_NT       UPLC_NT      NULL,
    RTO_NF       UCLI_NF      NULL,
    INT_NF       UCLI_NF      NULL,
    RETPAY_NF    UCLI_NF      NULL,
    RETKEY_CF    char(1)      NULL,
    TAUXCESSION  USHA_R       NULL
)
go
IF OBJECT_ID('dbo.RET_ESTM7002_CONTRATS') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.RET_ESTM7002_CONTRATS >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.RET_ESTM7002_CONTRATS >>>'
go
CREATE INDEX ESTM7002C_01
    ON dbo.RET_ESTM7002_CONTRATS(CTR_NF , END_NT, SEC_NF, UWY_NF, UW_NT)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.RET_ESTM7002_CONTRATS') AND name='ESTM7002C_01')
    PRINT '<<< CREATED INDEX dbo.RET_ESTM7002_CONTRATS.ESTM7002C_01 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.RET_ESTM7002_CONTRATS.ESTM7002C_01 >>>'
go
