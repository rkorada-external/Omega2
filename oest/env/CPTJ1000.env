# [000] 09/09/2019 Pratik Potdar

# chain name
export NCHAIN=${ENV_PREFIX}_CPTJ1000

# filename radix
export EXTCHAIN=${ENV_PREFIX}_CPTJ1000


# [001]
# Chain executed in Paris, New-York or Singapore
case ${HOST_PRDSIT} in
    USA1) if [ "${ENV_PREFIX}" = "T" ]
            then 
                export REMOTE_SITE=charlotte_test
          else
                export REMOTE_SITE=charlotte
          fi
    ;;
    *) export REMOTE_SITE="local"
    ;;
esac
export REMOTE_SITE="local"
# original name
export NOM_PREFIX=${ENV_PREFIX}_CPTJ1000

# default server
export SRV=${PRD_SRV}

# infomega server
export SRV2=${INF_SRV}

unset LANG
