. ${DENV}/EST.env

export NCHAIN=${ENV_PREFIX}_ESID3860
export NCHAIN_SHORT=${EXTCHAIN}

export EST_PLAN=${DFILP}/${ENV_PREFIX}_ESCJ0000_PLAN1.dat
export EST_PARAM=${DFILP}/${ENV_PREFIX}_ESCJ0000_PARM1.dat

export SITE_ONEGL=ONEGL_${HOST_PRDSIT}_OUT

#  omega server
export SRV=${PRD_SRV}
export BASE="BCLI"

unset LANG
