if [ "${PRD_SRV}" = "DEV_TPO2" ]
then

# VPD
export IN2=/scordata_dcvin2obbatch
export INT=/scordata_dcvintobbatch
export MAI=/scordata_dcvmaiobbatch
export CNV=/scordata_dcvcnvobbatch
export MUT=/scordata_dcvprdobmutbat
# AZURE
export IN2Z=/scordata_aenin2o2batch
export INTZ=/scordata_aeninto2batch
export MAIZ=/scordata_aenmaio2batch
export CNVZ=/scordata_aencnvo2batch
export PRD=/scordata_aenprdo2batch
export UAT=/scordata_aenuato2batch
export ITK=/scordata_aenitko2batch
export DEV=/scor/scordata

else

export IN2=/scor/scordata
export INT=/scor/scordata
export INTZ=/scor/scordata
export PRD=/scor/scordata
export MAI=/scor/scordata
export UAT=/scor/scordata
export ITK=/scor/scordata
export CNV=/scor/scordata
export MUT=/scor/scordata
export DEV=/scor/scordata

fi
