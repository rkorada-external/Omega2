# [000] 01/06/2012 Lalatiana RAKOTOZAFY :spot:23860 
# [001] 23/01/2013 Lalatiana Rakotozafy :spot:23860
# [002] 2019-09-10 Added SITE_ID for parameterizing SGLA in the report file name. : Spira 80575
# [003] 25/03/2020 S.Behague :spira:82196 IFRS17- REQ.LIF.01: AE interface for Life from SAS 

# chain name
export NCHAIN=${ENV_PREFIX}_ESIJ0800

# filename radix
export EXTCHAIN=${ENV_PREFIX}_ESIJ0800

# [001]
# Chain executed in Paris, New-York or Singapore
case ${HOST_PRDSIT} in
    USA1)
       export REMOTE_SITE="charlotte"
       export CSM_SITE="LifeReserving"
       export SITE_ID="SGLA"
    ;;
    FRA1)
       export REMOTE_SITE="local"
       export CSM_SITE="LifeReserving"
       export SITE_ID="SGLA"
    ;;
    SGP1)
       export REMOTE_SITE="local"
       export CSM_SITE="LifeReserving"
       export SITE_ID="SGLA"
    ;;
    *) export REMOTE_SITE="local"
       export CSM_SITE="LifeReserving"
       export SITE_ID="SCOR"
    ;;
esac

# original name
export NOM_PREFIX=${ENV_PREFIX}_ESIJ0800_AE

# default server
export SRV=${PRD_SRV}

# infomega server
export SRV2=${INF_SRV}

unset LANG
