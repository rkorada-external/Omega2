export NCHAIN=${ENV_PREFIX}_ESEH2010

# Debug level flor segmentation logs
# possible values: INFO, DEBUG
export SEG_LOG_LVL="DEBUG"

# Infomega Server
export SRV=${INF_SRV}

# Java batch server
export BATCH_SRV_HOSTNAME=localhost

# Define the first production site of the night batch cycle
# The production site defined in FIRST_PRDSITCF launches the segmentation
export FIRST_PRDSITCF="SGP1"
export LAST_PRDSITCF="USA1"

#================
# Init parameter for PARALLEL_INIT function
# Define the number of process to run in parallel 
# for the different part of the batch
#================

# Segmentation process
# 3 parallel tasks:
# - snapshot to run before saving segmentation results
# - segmentation process (extract, perimeter update, process) for assumed
# - segmentation process for retro
export CONCURRENT_SEG_PROCESS=3

# Legacy process
# 4 parallel tasks:
# - snapshot on new segmentation results
# - update simulation perimeter
# - export to MIS
# - export to UWAbstract
export CONCURRENT_LEGACY=4

# Store result process
# - store results for assumed perimeter
# - store results for retro perimeter
export CONCURRENT_STORERESULT=2

unset LANG