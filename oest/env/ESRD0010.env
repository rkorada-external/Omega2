
#[000] 29/03/2012 Roger Cassis  :spot:23199 - Normalisation des .env
#[001] 11/06/2012 Roger Cassis  :spot:23802 - Normalisation pour export Sites
#[002] 13/08/2012 Roger Cassis  :spot:24041 - Normalisation pour export Site Mutre

export NCHAIN=${ENV_PREFIX}_ESRD0010

export BASE="BEST"

export SRV=${PRD_SRV}

export NCHAIN_SHORT=ESRD0010


# IF CHAIN EXECUTED IN  PARIS :
if [ "${HOST_PRDSIT}" = "FRA1" -o "${HOST_PRDSIT}" = "FRAM" ]
then
	export LOCAL_SITE="local"
	export REMOTE_SITE="local"
fi

# IF CHAIN EXECUTED IN  SGP:
if [ "${HOST_PRDSIT}" = "SGP1" ]
then
	export LOCAL_SITE="singapore"
	export REMOTE_SITE="paris"
fi

# IF CHAIN EXECUTED IN  NY :
if [ "${HOST_PRDSIT}" = "USA1" ]
then
	export LOCAL_SITE="new-york"
	export REMOTE_SITE="paris"
fi

export EST_PARAM=${DFILP}/${ENV_PREFIX}_ESCJ0000_PARM1.dat
export EST_PLAN=${DFILP}/${ENV_PREFIX}_ESCJ0000_PLAN1.dat

unset LANG
