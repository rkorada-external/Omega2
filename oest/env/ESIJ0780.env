# [000] 19/03/2020 S. Behague :spira:82196 IFRS17- REQ.LIF.01: AE interface for Life from SAS 
# [001] 04/03/2021 S. Behague :spira:94442 I17: AE - Delta used IFRS 4 closing date instead of IFRS 17 one
. ${DENV}/EST.env

export EST_PARAMI17=${DFILP}/${ENV_PREFIX}_ESFJ0000_PARM_I17.dat

# chain name
export NCHAIN=${ENV_PREFIX}_ESIJ0780

# filename radix
export EXTCHAIN=${ENV_PREFIX}_ESIJ0790

# [001]
# Chain executed in Paris, New-York or Singapore
case ${HOST_PRDSIT} in
    USA1) 
       export REMOTE_SITE="LifeReserving"
       export REP_DESTINATION="charlotte"
       export SITE_ID="SGLA"        
    ;;
    FRA1) 
       export REMOTE_SITE="LifeReserving"
       export REP_DESTINATION="local"
       export SITE_ID="SGLA"        
    ;;
    SGP1) 
       export REMOTE_SITE="LifeReserving"
       export REP_DESTINATION="local"
       export SITE_ID="SGLA"        
    ;;
    *) export REMOTE_SITE="local"
       export SITE_ID="SCOR"
    ;;
esac

# original name
export NOM_PREFIX=${ENV_PREFIX}_ESIJ0780_AE

# default server
export SRV=${PRD_SRV}

# infomega server
export SRV2=${INF_SRV}

unset LANG
