
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDSII_H') AND name='ITECLEDSII_H_01')  
    DROP INDEX TTECLEDSII_H.ITECLEDSII_H_01 
go
CREATE NONCLUSTERED INDEX ITECLEDSII_H_01 ON dbo.TTECLEDSII_H(CTR_NF,END_NT,SEC_NF,UWY_NF,UW_NT) local index
go 
