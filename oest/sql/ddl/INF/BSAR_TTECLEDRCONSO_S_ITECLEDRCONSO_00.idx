
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDRCONSO_S') AND name='ITECLEDRCONSO_00')  
    DROP INDEX TTECLEDRCONSO_S.ITECLEDRCONSO_00 
go
CREATE NONCLUSTERED INDEX ITECLEDRCONSO_00 ON dbo.TTECLEDRCONSO_S(RETCTR_NF,RETRTY_NF,RETUW_NT,RETSEC_NF,RTO_NF) local index
go 
