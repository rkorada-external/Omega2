
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDSII_A') AND name='ITECLEDSII_A_04')  
    DROP INDEX TTECLEDSII_A.ITECLEDSII_A_04 
go
CREATE NONCLUSTERED INDEX ITECLEDSII_A_04 ON dbo.TTECLEDSII_A(SSD_CF,CUR_CF,BALSHEY_NF,CLOTYP_CT,CLODAT_D,PATCAT_CT,NORME_CF) local index
go 
