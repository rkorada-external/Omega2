IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDRSNEM_T') AND name='ITECLEDRSNEM_T_00')  
    DROP INDEX TTECLEDRSNEM_T.ITECLEDRSNEM_T_00 
go
CREATE NONCLUSTERED INDEX ITECLEDRSNEM_T_00 ON dbo.TTECLEDRSNEM_T(TRNCOD_CF,SSD_CF,ESB_CF) local index
