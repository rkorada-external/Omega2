
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDR_E') AND name='ITECLEDER_E_01')  
    DROP INDEX TTECLEDR_E.ITECLEDER_E_01 
go
CREATE NONCLUSTERED INDEX ITECLEDER_E_01 ON dbo.TTECLEDR_E(RETCTR_NF,RETRTY_NF,RETUW_NT,RETSEC_NF,RTO_NF) local index
go 
