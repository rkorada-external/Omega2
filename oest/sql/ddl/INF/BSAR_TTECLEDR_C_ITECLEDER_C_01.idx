
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDR_C') AND name='ITECLEDER_C_01')  
    DROP INDEX TTECLEDR_C.ITECLEDER_C_01 
go
CREATE NONCLUSTERED INDEX ITECLEDER_C_01 ON dbo.TTECLEDR_C(RETCTR_NF,RETRTY_NF,RETUW_NT,RETSEC_NF,RTO_NF) local index
go 
