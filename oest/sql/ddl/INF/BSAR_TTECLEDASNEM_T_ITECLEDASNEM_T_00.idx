IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDASNEM_T') AND name='ITECLEDASNEM_T_00')  
    DROP INDEX TTECLEDASNEM_T.ITECLEDASNEM_T_00 
go
CREATE NONCLUSTERED INDEX ITECLEDASNEM_T_00 ON dbo.TTECLEDASNEM_T(TRNCOD_CF,SSD_CF,ESB_CF) local index
