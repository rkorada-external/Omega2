
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDASNEM_S') AND name='ITECLEDASNEM_S_00')  
    DROP INDEX TTECLEDASNEM_S.ITECLEDASNEM_S_00 
go
CREATE NONCLUSTERED INDEX ITECLEDASNEM_S_00 ON dbo.TTECLEDASNEM_S(TRNCOD_CF,SSD_CF,ESB_CF) local index
