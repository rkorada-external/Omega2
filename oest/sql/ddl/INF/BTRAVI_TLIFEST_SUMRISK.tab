USE BTRAVI
Go

IF OBJECT_ID('TLIFEST_SUMRISK') IS NOT NULL
BEGIN
    DROP TABLE TLIFEST_SUMRISK

    IF OBJECT_ID('TLIFEST_SUMRISK') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TLIFEST_SUMRISK >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TLIFEST_SUMRISK >>>'
END
go

CREATE TABLE TLIFEST_SUMRISK
(
    SSD_CF       USSD_CF    NOT NULL,
    CTR_NF       UCTR_NF    NOT NULL,
    END_NT       UEND_NT    NOT NULL,
    SEC_NF       USEC_NF    NOT NULL,
    UWY_NF       UUWY_NF    NOT NULL,
    UW_NT        UUW_NT     NOT NULL,
    ACY_NF       smallint   NOT NULL,
    CRE_D        UUPD_D     DEFAULT getdate() NOT NULL,
    PRS_CF       smallint   NOT NULL,
    ACMTRS_NT    smallint   NOT NULL,
    BALSHEY_NF   smallint   NOT NULL,
    BALSHTMTH_NF tinyint    NOT NULL,
    CUR_CF       UCUR_CF    DEFAULT '' NOT NULL,
    ESTMNT_M     UAMT_M     NOT NULL,
    UDP_NF       CHAR(1)    NOT NULL,
    LOB_CF       CHAR(2)    NOT NULL,
    ACCSTS_CT    smallint   NOT NULL,
    ACCADMTYP_CF smallint   NOT NULL,
    ESTCRB_CT    smallint   NULL,
    CED_NF       smallint   NULL,
    BRK_NF       smallint   NULL,
    PAY_NF       smallint   NULL,
    GAYPAYORD_NT smallint   NULL,
    ADJCOD_CT    smallint   NULL,
    RETCOD_CT    smallint   NULL,
    DETTRS_NT    smallint   NULL,
    ADJSIG_B     smallint   NOT NULL,
    ESB_CF       smallint   NOT NULL,
    LIFTRTTYP_CF CHAR(1)    NOT NULL,
    INDSUP_B     smallint   DEFAULT 0 NOT NULL,
    ORICOD_LS    UL16       NULL,
    CREUSR_CF    UUPDUSR_CF DEFAULT user NOT NULL,
    LSTUPD_D     UUPD_D     DEFAULT getdate() NOT NULL,
    LSTUPDUSR_CF UUPDUSR_CF DEFAULT user NOT NULL,
    SPIMOD_CF    smallint   NULL
)
LOCK ALLPAGES
go
GRANT ALL ON TLIFEST_SUMRISK TO GOMEGA
go
GRANT ALL ON TLIFEST_SUMRISK TO GDBBATCH
go
GRANT SELECT ON TLIFEST_SUMRISK TO GCONSULT
go
IF OBJECT_ID('TLIFEST_SUMRISK') IS NOT NULL
    PRINT '<<< CREATED TABLE TLIFEST_SUMRISK >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TLIFEST_SUMRISK >>>'
go
CREATE UNIQUE CLUSTERED INDEX TLIFEST_SUMRISK_00
    ON TLIFEST_SUMRISK(CTR_NF,END_NT,SEC_NF,UWY_NF,UW_NT,CRE_D,ACY_NF,ACMTRS_NT)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TLIFEST_SUMRISK') AND name='TLIFEST_SUMRISK_00')
    PRINT '<<< CREATED INDEX TLIFEST.TLIFEST_SUMRISK_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX TLIFEST_SUMRISK_00 >>>'
go
