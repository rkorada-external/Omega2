
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDSII_T') AND name='ITECLEDSII_T_03')  
    DROP INDEX TTECLEDSII_T.ITECLEDSII_T_03 
go
CREATE NONCLUSTERED INDEX ITECLEDSII_T_03 ON dbo.TTECLEDSII_T(RETCTR_NF,RETEND_NT,RETSEC_NF,RETRTY_NF,RETUW_NT) local index
go 
