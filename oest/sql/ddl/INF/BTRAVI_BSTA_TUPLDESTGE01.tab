USE BTRAVI
go
IF OBJECT_ID('BSTA_TUPLDESTGE01') IS NOT NULL
BEGIN
  DROP TABLE BSTA_TUPLDESTGE01
  IF OBJECT_ID('BSTA_TUPLDESTGE01') IS NOT NULL
    PRINT '<<< FAILED DROPPING TABLE BSTA_TUPLDESTGE01 >>>'
  ELSE
    PRINT '<<< DROPPED TABLE BSTA_TUPLDESTGE01 >>>'
END
go
CREATE TABLE BSTA_TUPLDESTGE01
(
	MESSTHM_C UMESSTHM_C NOT NULL,
	UPLDNO_NT int NOT NULL,
	NUMFIC_NT	int NOT NULL,
	PROVIDER_CF UL16 NOT NULL,
	SSD_CF	USSD_CF NOT NULL,
	ESB_CF	UESB_CF NOT NULL,
	USR_CF	UUSR_CF NOT NULL,
	NOMFICORIG_LL	UL64 NOT NULL,
	NOMFICSERV_LL	UL64 NOT NULL,
	INTEG_D	datetime NULL,
	FICSTS_CF	tinyint NULL,
	NBLGTOT_NT	int DEFAULT 0 NOT NULL,
	NBLGKO_NT	int DEFAULT 0 NOT NULL,
	NBANO_NT	int DEFAULT 0 NOT NULL,
	LSTUPDUSR_CF UUSR_CF NOT NULL,
	LSTUPD_D datetime NOT NULL,
	BLCSHT_D datetime NOT NULL
)
LOCK DATAROWS
go
IF OBJECT_ID('BSTA_TUPLDESTGE01') IS NOT NULL
  PRINT '<<< CREATED TABLE BSTA_TUPLDESTGE01 >>>'
ELSE
  PRINT '<<< FAILED CREATING TABLE BSTA_TUPLDESTGE01 >>>'
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('BSTA_TUPLDESTGE01') AND name='IBSTA_TUPLDESTGE01_00')
BEGIN
	DROP INDEX BSTA_TUPLDESTGE01.IBSTA_TUPLDESTGE01_00
	IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('BSTA_TUPLDESTGE01') AND name='IBSTA_TUPLDESTGE01_00')
    PRINT '<<< FAILED DROPPING INDEX BSTA_TUPLDESTGE01.IBSTA_TUPLDESTGE01_00 >>>'
	ELSE
    PRINT '<<< DROPPED INDEX BSTA_TUPLDESTGE01.IBSTA_TUPLDESTGE01_00 >>>'
END
go
CREATE NONCLUSTERED INDEX IBSTA_TUPLDESTGE01_00 
  ON BSTA_TUPLDESTGE01 (MESSTHM_C, UPLDNO_NT, NUMFIC_NT, PROVIDER_CF, SSD_CF, ESB_CF, USR_CF, FICSTS_CF, LSTUPDUSR_CF)
go
GRANT ALL ON BSTA_TUPLDESTGE01 TO GOMEGA
go
GRANT ALL ON BSTA_TUPLDESTGE01 TO GDBBATCH
go
GRANT SELECT ON BSTA_TUPLDESTGE01 TO GCONSULT
go