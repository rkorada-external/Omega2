
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDRSNEM_H') AND name='ITECLEDRSNEM_H_00')  
    DROP INDEX TTECLEDRSNEM_H.ITECLEDRSNEM_H_00 
go
CREATE NONCLUSTERED INDEX ITECLEDRSNEM_H_00 ON dbo.TTECLEDRSNEM_H(TRNCOD_CF,SSD_CF,ESB_CF) local index
go 
