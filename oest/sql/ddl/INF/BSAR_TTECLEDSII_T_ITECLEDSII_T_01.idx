
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDSII_T') AND name='ITECLEDSII_T_01')  
    DROP INDEX TTECLEDSII_T.ITECLEDSII_T_01 
go
CREATE NONCLUSTERED INDEX ITECLEDSII_T_01 ON dbo.TTECLEDSII_T(CTR_NF,END_NT,SEC_NF,UWY_NF,UW_NT) local index
go 
