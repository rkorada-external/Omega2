USE BTRAVI
go
IF OBJECT_ID('BSTA_TUPLDESTDET02') IS NOT NULL
BEGIN
  DROP TABLE BSTA_TUPLDESTDET02
  IF OBJECT_ID('BSTA_TUPLDESTDET02') IS NOT NULL
    PRINT '<<< FAILED DROPPING TABLE BSTA_TUPLDESTDET02 >>>'
  ELSE
    PRINT '<<< DROPPED TABLE BSTA_TUPLDESTDET02 >>>'
END
go
CREATE TABLE BSTA_TUPLDESTDET02
(
	MESSTHM_C UMESSTHM_C NOT NULL,
	UPLDNO_NT int NOT NULL,
	NUMFIC_NT	int NOT NULL,
	PROVIDER_CF UL16 NOT NULL,
	SSD_CF	USSD_CF NOT NULL,
	ESB_CF	UESB_CF NOT NULL,
	NUMLIGNE_NT int NOT NULL,
	MESS_N int NOT NULL,
	MESS_L VARCHAR(200) NOT NULL,
	CTR_NF UCTR_NF DEFAULT '' NOT NULL,
	SEC_NF USEC_NF NULL,
	UWY_NF UUWY_NF NULL,
	ACY_NF smallint NULL,
	PCPCUR_CF UCUR_CF NULL,
	DETTRNCOD_CF UDETTRS_CF DEFAULT '' NOT NULL,
	AMT_M numeric(18,3) NULL,
	USR_CF UUSR_CF NOT NULL,
	NOMFICORIG_LL	UL64 NOT NULL,
	NOMFICSERV_LL	UL64 NOT NULL,
	INTEG_D	datetime NULL,
	FICSTS_CF	tinyint NULL,
	NBLGTOT_NT	int DEFAULT 0 NOT NULL,
	NBLGKO_NT	int DEFAULT 0 NOT NULL,
	NBANO_NT	int DEFAULT 0 NOT NULL,
	LSTUPDUSR_CF UUSR_CF NOT NULL,
	LSTUPD_D datetime NOT NULL,
	BLCSHT_D datetime NOT NULL
)
LOCK DATAROWS
go
IF OBJECT_ID('BSTA_TUPLDESTDET02') IS NOT NULL
  PRINT '<<< CREATED TABLE BSTA_TUPLDESTDET02 >>>'
ELSE
  PRINT '<<< FAILED CREATING TABLE BSTA_TUPLDESTDET02 >>>'
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('BSTA_TUPLDESTDET02') AND name='IBSTA_TUPLDESTDET02_00')
BEGIN
	DROP INDEX BSTA_TUPLDESTDET02.IBSTA_TUPLDESTDET02_00
	IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('BSTA_TUPLDESTDET02') AND name='IBSTA_TUPLDESTDET02_00')
    PRINT '<<< FAILED DROPPING INDEX BSTA_TUPLDESTDET02.IBSTA_TUPLDESTDET02_00 >>>'
	ELSE
    PRINT '<<< DROPPED INDEX BSTA_TUPLDESTDET02.IBSTA_TUPLDESTDET02_00 >>>'
END
go
CREATE NONCLUSTERED INDEX IBSTA_TUPLDESTDET02_00 
  ON BSTA_TUPLDESTDET02 (MESSTHM_C, UPLDNO_NT, NUMFIC_NT, PROVIDER_CF, SSD_CF, ESB_CF, NUMLIGNE_NT, MESS_N, CTR_NF, SEC_NF, PCPCUR_CF, DETTRNCOD_CF, USR_CF, FICSTS_CF, LSTUPDUSR_CF)
go
GRANT ALL ON BSTA_TUPLDESTDET02 TO GOMEGA
go
GRANT ALL ON BSTA_TUPLDESTDET02 TO GDBBATCH
go
GRANT SELECT ON BSTA_TUPLDESTDET02 TO GCONSULT
go