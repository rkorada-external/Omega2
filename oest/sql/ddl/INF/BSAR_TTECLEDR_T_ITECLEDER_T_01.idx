
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDR_T') AND name='ITECLEDER_T_01')  
    DROP INDEX TTECLEDR_T.ITECLEDER_T_01 
go
CREATE NONCLUSTERED INDEX ITECLEDER_T_01 ON dbo.TTECLEDR_T(RETCTR_NF,RETRTY_NF,RETUW_NT,RETSEC_NF,RTO_NF) local index
go 
