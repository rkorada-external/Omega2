
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDSII_H') AND name='ITECLEDSII_H_03')  
    DROP INDEX TTECLEDSII_H.ITECLEDSII_H_03 
go
CREATE NONCLUSTERED INDEX ITECLEDSII_H_03 ON dbo.TTECLEDSII_H(RETCTR_NF,RETEND_NT,RETSEC_NF,RETRTY_NF,RETUW_NT) local index
go 
