USE BTRAVI
go

IF OBJECT_ID('TEMPMIS') IS NOT NULL
BEGIN
    DROP TABLE TEMPMIS
    IF OBJECT_ID('TEMPMIS') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TEMPMIS >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TEMPMIS >>>'
END
go
CREATE TABLE TEMPMIS
(
    SGT_NT     INT NOT NULL,
    SGTRUN_NT  INT NOT NULL,
    SGTVER_NT  INT NOT NULL,
    SEGTYPE_CF INT NULL,
    BASENEWID_NT INT IDENTITY
)
go
GRANT SELECT ON TEMPMIS TO GCONSULT
go
GRANT DELETE ON TEMPMIS TO GOMEGA
go
GRANT INSERT ON TEMPMIS TO GOMEGA
go
GRANT SELECT ON TEMPMIS TO GOMEGA
go
GRANT UPDATE ON TEMPMIS TO GOMEGA
go
IF OBJECT_ID('TEMPMIS') IS NOT NULL
    PRINT '<<< CREATED TABLE TEMPMIS >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TEMPMIS >>>'
go


