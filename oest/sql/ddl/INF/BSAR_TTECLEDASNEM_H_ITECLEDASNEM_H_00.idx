
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDASNEM_H') AND name='ITECLEDASNEM_H_00')  
    DROP INDEX TTECLEDASNEM_H.ITECLEDASNEM_H_00 
go
CREATE NONCLUSTERED INDEX ITECLEDASNEM_H_00 ON dbo.TTECLEDASNEM_H(TRNCOD_CF,SSD_CF,ESB_CF) local index
go 
