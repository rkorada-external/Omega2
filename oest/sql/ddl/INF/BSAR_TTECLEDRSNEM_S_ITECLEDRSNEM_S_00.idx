
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDRSNEM_S') AND name='ITECLEDRSNEM_S_00')  
    DROP INDEX TTECLEDRSNEM_S.ITECLEDRSNEM_S_00 
go
CREATE NONCLUSTERED INDEX ITECLEDRSNEM_S_00 ON dbo.TTECLEDRSNEM_S(TRNCOD_CF,SSD_CF,ESB_CF) local index
