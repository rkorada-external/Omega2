IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDACONSO_S') AND name='ITECLEDACONSO_03')  
    DROP INDEX TTECLEDACONSO_S.ITECLEDACONSO_03 
go
CREATE NONCLUSTERED INDEX ITECLEDACONSO_03 ON dbo.TTECLEDACONSO_S(SSD_CF,TRNCOD_CF,ESB_CF) local index
