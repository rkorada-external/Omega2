
USE BSAR
go
SETUSER 'dbo'
go
          
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDACONSO_C') AND name='ITECLEDACONSO_01')  
    DROP INDEX TTECLEDACONSO_C.ITECLEDACONSO_01 
go
CREATE NONCLUSTERED INDEX ITECLEDACONSO_01 ON dbo.TTECLEDACONSO_C(CTR_NF,END_NT,SEC_NF,UWY_NF,UW_NT) local index
go 
