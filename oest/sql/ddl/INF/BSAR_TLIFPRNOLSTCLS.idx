use BSAR
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFPRNOLSTCLS')
                                      AND name='ILIFPRNOLSTCLS_00')
BEGIN
    DROP INDEX TLIFPRNOLSTCLS.ILIFPRNOLSTCLS_00
    PRINT '<<< DROPPED INDEX dbo.TLIFPRNOLSTCLS.ILIFPRNOLSTCLS_00 >>>'
END
go



/*
 * Creating Indexes for Table dbo.TLIFPRNOLSTCLS
 */
CREATE UNIQUE CLUSTERED INDEX ILIFPRNOLSTCLS_00
    ON dbo.TLIFPRNOLSTCLS(CLODAT_D,SSD_CF,CTR_NF,END_NT,SEC_NF,UWY_NF,UW_NT,PLC_NT,ACCRET_CF,ACY_NF,TYPMNT_CT) 
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFPRNOLSTCLS') AND name='ILIFPRNOLSTCLS_00')
    PRINT '<<< CREATED INDEX dbo.TLIFPRNOLSTCLS.ILIFPRNOLSTCLS_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TLIFPRNOLSTCLS.ILIFPRNOLSTCLS_00 >>>'
go

