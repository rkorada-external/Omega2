IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TTECLEDACONSO_B') AND name='ITECLEDACONSO_03')  
    DROP INDEX TTECLEDACONSO_B.ITECLEDACONSO_03 
go
CREATE NONCLUSTERED INDEX ITECLEDACONSO_03 ON dbo.TTECLEDACONSO_B(SSD_CF,TRNCOD_CF,ESB_CF) local index
