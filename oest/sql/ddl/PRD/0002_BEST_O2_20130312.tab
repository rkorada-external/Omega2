USE BSTA
go
CREATE TABLE dbo.TSUIVINTACC
(
    MESSTHM_C     UMESSTHM_C    NOT NULL,
    NUMFIC_NT     UUWENTNBR_NT  NOT NULL,
    SSD_CF        USSD_CF       NOT NULL,
    ESB_CF        UESB_CF       NOT NULL,
    USR_CF        UUSR_CF       NOT NULL,
    NOMFICORIG_LL UL64          NOT NULL,
    NOMFICSERV_LL UL64          NOT NULL,
    INTEG_D       datetime      NULL,
    FICSTS_CF     char(2)       NOT NULL,
    NBLGTOT_NT    int           DEFAULT 0 NOT NULL,
    NBLGKO_NT     int           DEFAULT 0 NOT NULL,
    NBANO_NT      int           DEFAULT 0 NOT NULL,
    MINMVT_NT     decimal(10,0) DEFAULT 0 NOT NULL,
    MAXMVT_NT     decimal(10,0) DEFAULT 0 NOT NULL,
    LSTUPDUSR_CF  UUPDUSR_CF    NOT NULL,
    LSTUPD_D      UUPD_D        NOT NULL,
    POSAMT_M      decimal(18,3) DEFAULT 0 NOT NULL,
    NEGAMT_M      decimal(18,3) DEFAULT 0 NOT NULL,
    BLCSHT_D      datetime      NULL
)
LOCK ALLPAGES
go
IF OBJECT_ID('dbo.TSUIVINTACC') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TSUIVINTACC >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TSUIVINTACC >>>'
go
GRANT DELETE ON dbo.TSUIVINTACC TO GOMEGA
go
GRANT DELETE STATISTICS ON dbo.TSUIVINTACC TO GOMEGA
go
GRANT INSERT ON dbo.TSUIVINTACC TO GOMEGA
go
GRANT REFERENCES ON dbo.TSUIVINTACC TO GOMEGA
go
GRANT SELECT ON dbo.TSUIVINTACC TO GOMEGA
go
GRANT SELECT ON dbo.TSUIVINTACC TO GCONSULT
go
GRANT TRUNCATE TABLE ON dbo.TSUIVINTACC TO GOMEGA
go
GRANT UPDATE ON dbo.TSUIVINTACC TO GOMEGA
go
GRANT UPDATE STATISTICS ON dbo.TSUIVINTACC TO GOMEGA
go


USE BSTA
go
SETUSER 'dbo'
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TSUIVINTACC') AND name='ISUIVINTACC_00')
BEGIN
    DROP INDEX TSUIVINTACC.ISUIVINTACC_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TSUIVINTACC') AND name='ISUIVINTACC_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TSUIVINTACC.ISUIVINTACC_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TSUIVINTACC.ISUIVINTACC_00 >>>'
END
go
SETUSER
go
CREATE UNIQUE CLUSTERED INDEX ISUIVINTACC_00
    ON dbo.TSUIVINTACC(MESSTHM_C,NUMFIC_NT,SSD_CF,ESB_CF)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TSUIVINTACC') AND name='ISUIVINTACC_00')
    PRINT '<<< CREATED INDEX dbo.TSUIVINTACC.ISUIVINTACC_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TSUIVINTACC.ISUIVINTACC_00 >>>'
go

