    GRPINIPRO_CF    UBANVAL_CT NULL,
	GRPINISTS_CT    tinyint    NULL,
	CRE_D	        UUPD_D     NULL,
    CREUSR_CF	    UUPDUSR_CF NULL,
    LSTUPD_D        UUPD_D     NULL,
    LSTUPDUSR_CF    UUPDUSR_CF NULL,
    [TIMESTAMP]     timestamp  NULL,
    CONSTRAINT PK_TI17CTRSML
    PRIMARY KEY NONCLUSTERED (CTR_NF,UWY_NF,UW_NT,END_NT,SEC_NF)
)
LOCK DATAROWS
go
