USE BEST
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TCURSIILIFE') AND name='ICURSIILIFE_00')
BEGIN
    DROP INDEX TCURSIILIFE.ICURSIILIFE_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TCURSIILIFE') AND name='ICURSIILIFE_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TCURSIILIFE.ICURSIILIFE_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TCURSIILIFE.ICURSIILIFE_00 >>>'
END
go
CREATE UNIQUE NONCLUSTERED INDEX ICURSIILIFE_00
    ON dbo.TCURSIILIFE(CUR_CF,VALEND_D,CLOSING_D)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TCURSIILIFE') AND name='ICURSIILIFE_00')
    PRINT '<<< CREATED INDEX dbo.TCURSIILIFE.ICURSIILIFE_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TCURSIILIFE.ICURSIILIFE_00 >>>'
go
