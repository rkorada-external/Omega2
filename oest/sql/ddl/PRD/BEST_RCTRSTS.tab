USE BEST
go
EXEC sp_unbindrule 'UCTRSTS_CT'
go

IF OBJECT_ID('dbo.RCTRSTS_CT') IS NOT NULL
BEGIN   
    DROP RULE dbo.RCTRSTS_CT
    IF OBJECT_ID('dbo.RCTRSTS_CT') IS NOT NULL
        PRINT '<<< FAILED DROPPING RULE dbo.RCTRSTS_CT >>>'
    ELSE
        PRINT '<<< DROPPED RULE dbo.RCTRSTS_CT >>>'
END
go
CREATE RULE dbo.RCTRSTS_CT AS @CTRSTS_CT in (1,3,4,5,12,14,16,17,18,19,21,22,23,24,25)
go
IF OBJECT_ID('dbo.RCTRSTS_CT') IS NOT NULL
    PRINT '<<< CREATED RULE dbo.RCTRSTS_CT >>>'
ELSE
    PRINT '<<< FAILED CREATING RULE dbo.RCTRSTS_CT >>>'
go
EXEC sp_bindrule 'dbo.RCTRSTS_CT','UCTRSTS_CT'
go