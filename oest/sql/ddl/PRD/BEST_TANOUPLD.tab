USE BEST
go
IF OBJECT_ID('TANOUPLD') IS NOT NULL
BEGIN
  DROP TABLE TANOUPLD
  IF OBJECT_ID('TANOUPLD') IS NOT NULL
    PRINT '<<< FAILED DROPPING TABLE TANOUPLD >>>'
  ELSE
    PRINT '<<< DROPPED TABLE TANOUPLD >>>'
END
go
CREATE TABLE TANOUPLD
(
	FILEID_CF int,
	NUMLINE_NT int default 0 not null,
	CTR_NF UCTR_NF null,
	SEC_NF USEC_NF null,
	UWY_NF UUWY_NF null,
	ACY_NF smallint null,
	GAAP_NF smallint null,
	DETTRNCOD_CF char(5) default '' not null,
	SEGTYP_CT USEGTYP_CT default '' not null,
	SEG_NF USEG_NF default '' not null,
	ERRORCODE_CT int not null,
	CRE_D datetime not null,
	FILENAME_LL UL255 not null
)
LOCK DATAROWS
go
IF OBJECT_ID('TANOUPLD') IS NOT NULL
  PRINT '<<< CREATED TABLE TANOUPLD >>>'
ELSE
  PRINT '<<< FAILED CREATING TABLE TANOUPLD >>>'
go
GRANT ALL ON TANOUPLD TO GOMEGA
go
GRANT ALL ON TANOUPLD TO GDBBATCH
go
GRANT SELECT ON TANOUPLD TO GCONSULT
go
