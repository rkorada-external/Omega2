USE BEST 
go

IF OBJECT_ID('dbo.TI17CLOPER_V') IS NOT NULL
BEGIN
    DROP TABLE dbo.TI17CLOPER_V
    IF OBJECT_ID('dbo.TI17CLOPER_V') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE dbo.TI17CLOPER_V >>>'
    ELSE
       PRINT '<<< TABLE DROPPED dbo.TI17CLOPER_V >>>'
END
go

/*==============================================================*/
/* Table: dbo.TI17CLOPER_V                                              */
/*==============================================================*/
create table dbo.TI17CLOPER_V
(
	SSD_CF			USSD_CF 		NOT NULL,
	ESB_CF			UESB_CF 		NOT NULL,
	CLODAT_D 		datetime    	NOT NULL,
	PARM1			varchar(32)  	NULL,
	PARM2			varchar(32)  	NULL,
	PARM3			varchar(32) 	NULL,
	PARM4			varchar(32) 	NULL,
	PARM5			varchar(32) 	NULL,
	PARM6			varchar(32) 	NULL,
	PARM7			varchar(32) 	NULL,
	PARM8			varchar(32) 	NULL,
	PARM9			varchar(32) 	NULL,
	PARM10			 varchar(32) 	NULL
)
go
IF OBJECT_ID('dbo.TI17CLOPER_V') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TI17CLOPER_V >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TI17CLOPER_V >>>'
go

CREATE UNIQUE CLUSTERED INDEX II17CLOPER_00
    ON dbo.TI17CLOPER_V(SSD_CF,ESB_CF,CLODAT_D)
go

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TI17CLOPER_V') AND name='II17CLOPER_00')
    PRINT '<<< CREATED INDEX dbo.TI17CLOPER_V.II17CLOPER_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TI17CLOPER_V.II17CLOPER_00 >>>'
go

