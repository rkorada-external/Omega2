use BTRAV
go
IF OBJECT_ID('ESEJ2090_TRESULT') IS NOT NULL
begin
  drop TABLE  ESEJ2090_TRESULT
  if object_id('ESEJ2090_TRESULT') is not null
    print '<<< FAILED DROPPING TABLE ESEJ2090_TRESULT >>>'
  else
    print '<<< DROPPED TABLE ESEJ2090_TRESULT >>>'
end
go


	
CREATE TABLE BTRAV..ESEJ2090_TRESULT ( 
	SGMT_NF USGMT_NF  NULL,
	SGTLVL_NT int  NULL, 
	SEGCTRTYP_CT UBANVAL_CT NULL, 
	RETCTR_NF URETCTR_NF NOT NULL, 
	RTY_NF UUWY_NF NOT NULL,
	RTO_NF UCLI_NF NOT NULL,
	SSD_CF USSD_CF NOT NULL,
	SGTTYP_NT USGTTYP_NT NULL,
	SGTVER_NT int  NULL,
    SGT_NT	USGT_NT NULL,
	CRE_D datetime NOT NULL,
	CTRTYP_CT CHAR(1) NOT NULL,
	GRPIFRSSEG_CT   USEG_NF    NULL,
    GRPIFRSSEG_LL   UL64       NULL,
	GRPIFRSSEG1_CT  USEG_NF    NULL,
    GRPIFRSSEG1_LL  UL64       NULL,    
	PARIFRSSEG_CT   USEG_NF    NULL,
    PARIFRSSEG_LL   UL64       NULL,	
	PARIFRSSEG1_CT  USEG_NF    NULL,
    PARIFRSSEG1_LL  UL64       NULL,
    LOCIFRSSEG_CT   USEG_NF    NULL,
    LOCIFRSSEG_LL   UL64       NULL,
    LOCIFRSSEG1_CT  USEG_NF    NULL,
    LOCIFRSSEG1_LL  UL64       NULL,
    PARSGMT_NF 		USGMT_NF	NULL,
	GRPINISTS_CT	tinyint	   NULL,
	PARINISTS_CT	tinyint	   NULL,
	LOCINISTS_CT	tinyint	   NULL,
	CLISSD_CF    USSD_CF       NULL,
	GRPMANSEG_B  	bit   	NOT NULL,
	GRPFSTCLO_D    datetime   NULL,
    PARFSTCLO_D    datetime   NULL,
    LCLFSTCLO_D    datetime   NULL
)



go
IF OBJECT_ID('ESEJ2090_TRESULT') IS NOT NULL
  print '<<< CREATED TABLE ESEJ2090_TRESULT >>>'
else
  print '<<< FAILED CREATING TABLE  ESEJ2090_TRESULT >>>'
go


CREATE NONCLUSTERED INDEX I1_ESEJ2090_TRESULT
    ON ESEJ2090_TRESULT(CTRTYP_CT, RETCTR_NF, RTY_NF)

go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('ESEJ2090_TRESULT') AND name='I1_ESEJ2090_TRESULT')
    PRINT '<<< CREATED INDEX ESEJ2090_TRESULT.I1_ESEJ2090_TRESULT >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ESEJ2090_TRESULT.I1_ESEJ2090_TRESULT >>>'
go

CREATE NONCLUSTERED INDEX I2_ESEJ2090_TRESULT
    ON ESEJ2090_TRESULT(CTRTYP_CT)

go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('ESEJ2090_TRESULT') AND name='I2_ESEJ2090_TRESULT')
    PRINT '<<< CREATED INDEX ESEJ2090_TRESULT.I2_ESEJ2090_TRESULT >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ESEJ2090_TRESULT.I2_ESEJ2090_TRESULT >>>'
go

