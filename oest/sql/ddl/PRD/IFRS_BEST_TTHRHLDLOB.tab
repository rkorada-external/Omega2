USE BEST
go

IF OBJECT_ID('TTHRHLDLOB') IS NOT NULL
BEGIN
    DROP TABLE TTHRHLDLOB
    IF OBJECT_ID('TTHRHLDLOB') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TTHRHLDLOB >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TTHRHLDLOB >>>'
END
go

CREATE TABLE TTHRHLDLOB
(
    SSD_CF        USSD_CF 	  NOT NULL,
    ESB_CF        UESB_CF 	  NOT NULL,
    NORME_CF 	  CHAR(05)	  NOT NULL,
	LOBTHRHLD_R	  DECIMAL(9,8) NULL,
	EGPITHRHLD_M  DECIMAL(18,3) NULL,
	CUR_CF 		  CHAR(03) 	  NULL,
	CRE_D		  DATETIME    NOT NULL,
	CREUSR_CF	  CHAR(04) 	  NOT NULL,
	LSTUPD_D	  DATETIME	  NOT NULL,
	LSTUPDUSR_CF  CHAR(04)	  NOT NULL,
	FCLODAT_D	  DATETIME    NULL,
	[TIMESTAMP]   timestamp   NULL,
)

go

IF OBJECT_ID('TTHRHLDLOB') IS NOT NULL
    PRINT '<<< CREATED TABLE TTHRHLDLOB>>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TTHRHLDLOB >>>'
go


CREATE UNIQUE CLUSTERED INDEX ITRARAT_00
    ON TTHRHLDLOB(SSD_CF,ESB_CF,NORME_CF,FCLODAT_D)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TTHRHLDLOB') AND name='ITRARAT_00')
    PRINT '<<< CREATED INDEX ITRARAT_00 ON TTHRHLDLOB >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ITRARAT_00 ON TTHRHLDLOB >>>'
go

