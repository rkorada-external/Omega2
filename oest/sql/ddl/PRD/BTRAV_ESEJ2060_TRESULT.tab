use BTRAV
go
IF OBJECT_ID('ESEJ2060_TRESULT') IS NOT NULL
begin
  drop TABLE  ESEJ2060_TRESULT
  if object_id('ESEJ2060_TRESULT') is not null
    print '<<< FAILED DROPPING TABLE ESEJ2060_TRESULT >>>'
  else
    print '<<< DROPPED TABLE ESEJ2060_TRESULT >>>'
end
go


	
CREATE TABLE BTRAV..ESEJ2060_TRESULT (
	SGMT_NF USGMT_NF NOT NULL,
	SGTLVL_NT int NOT NULL, 
	SEGCTRTYP_CT UBANVAL_CT, 
	CTR_NF UCTR_NF NOT NULL, 
	UWY_NF UUWY_NF NOT NULL,
	UW_NT UUW_NT NOT NULL,
	SEC_NF USEC_NF NOT NULL,
	RTO_NF UCLI_NF NOT NULL,
	SSD_CF USSD_CF NOT NULL,
	SGTTYP_NT USGTTYP_NT NOT NULL,
	SGTVER_NT int NOT NULL,
    SGT_NT	USGT_NT	NOT NULL,
    END_NT UEND_NT,
	CRE_D datetime NOT NULL,
	CTRTYP_CT CHAR(1) NOT NULL,
	GRPIFRSSEG_CT   USEG_NF    NULL,
    GRPIFRSSEG_LL   UL64       NULL,
	GRPIFRSSEG1_CT  USEG_NF    NULL,
    GRPIFRSSEG1_LL  UL64       NULL,    
	PARIFRSSEG_CT   USEG_NF    NULL,
    PARIFRSSEG_LL   UL64       NULL,	
	PARIFRSSEG1_CT  USEG_NF    NULL,
    PARIFRSSEG1_LL  UL64       NULL,
    LOCIFRSSEG_CT   USEG_NF    NULL,
    LOCIFRSSEG_LL   UL64       NULL,
    LOCIFRSSEG1_CT  USEG_NF    NULL,
    LOCIFRSSEG1_LL  UL64       NULL,
	PARSGMT_NF USGMT_NF NULL,
	CLISSD_CF    USSD_CF       NULL   --Modification for spira#92406: I17: Management of Portoflio/subportfolio for Assumed involved in IO 
)



go
IF OBJECT_ID('ESEJ2060_TRESULT') IS NOT NULL
  print '<<< CREATED TABLE ESEJ2060_TRESULT >>>'
else
  print '<<< FAILED CREATING TABLE  ESEJ2060_TRESULT >>>'
go


CREATE NONCLUSTERED INDEX I1_ESEJ2060_TRESULT
    ON ESEJ2060_TRESULT(SGTTYP_NT, CTRTYP_CT,CTR_NF,UWY_NF,UW_NT,SEC_NF,END_NT)

go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('ESEJ2060_TRESULT') AND name='I1_ESEJ2060_TRESULT')
    PRINT '<<< CREATED INDEX ESEJ2060_TRESULT.I1_ESEJ2060_TRESULT >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ESEJ2060_TRESULT.I1_ESEJ2060_TRESULT >>>'
go

CREATE NONCLUSTERED INDEX I2_ESEJ2060_TRESULT
    ON ESEJ2060_TRESULT(SGTTYP_NT, CTRTYP_CT)

go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('ESEJ2060_TRESULT') AND name='I2_ESEJ2060_TRESULT')
    PRINT '<<< CREATED INDEX ESEJ2060_TRESULT.I2_ESEJ2060_TRESULT >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ESEJ2060_TRESULT.I2_ESEJ2060_TRESULT >>>'
go

GRANT DELETE ON ESEJ2060_TRESULT TO GOMEGA
go
GRANT INSERT ON ESEJ2060_TRESULT TO GOMEGA
go
GRANT SELECT ON ESEJ2060_TRESULT TO GOMEGA
go
GRANT UPDATE ON ESEJ2060_TRESULT TO GOMEGA
go
GRANT REFERENCES ON ESEJ2060_TRESULT TO GOMEGA
go
