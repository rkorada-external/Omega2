USE BEST
go

IF OBJECT_ID('dbo.TCALL') IS NOT NULL
BEGIN
    DROP TABLE dbo.TCALL
    IF OBJECT_ID('dbo.TCALL') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE dbo.TCALL >>>'
    ELSE
       PRINT '<<< TABLE DROPPED dbo.TCALL >>>'
END

go 

CREATE TABLE dbo.TCALL
(
    SSD_CF       	USSD_CF  NOT NULL,
    ESB_CF       	UESB_CF   NOT NULL,
    CTR_NF       	UCTR_NF NOT NULL,
	UWY_NF			UUWY_NF	NOT NULL,
	SEC_NF        	USEC_NF  NOT NULL,
	ACY_NF			smallint	NOT NULL,
	SCOENDMTH_NF	tinyint		NOT NULL,
	TREATED_B		bit			NOT NULL,
	CRE_D			datetime	NOT NULL,
    CONSTRAINT PK_TCALL_00
    PRIMARY KEY CLUSTERED (SSD_CF,ESB_CF,CTR_NF,UWY_NF,SEC_NF,ACY_NF,CRE_D)
)
LOCK ALLPAGES
go
IF OBJECT_ID('dbo.TCALL') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TCALL >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TCALL >>>'
go

GRANT REFERENCES ON dbo.TCALL TO GOMEGA
