USE BEST
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFEST') AND name='ILIFEST_00')
BEGIN
    DROP INDEX TLIFEST.ILIFEST_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFEST') AND name='ILIFEST_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TLIFEST.ILIFEST_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TLIFEST.ILIFEST_00 >>>'
END
go
CREATE UNIQUE CLUSTERED INDEX ILIFEST_00
    ON dbo.TLIFEST(CTR_NF,END_NT,SEC_NF,UWY_NF,UW_NT,CRE_D,BALSHEY_NF,BALSHTMTH_NF,ACY_NF,PRS_CF,ACMTRS_NT,GAAP_NT,DETTRNCOD_CF)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFEST') AND name='ILIFEST_00')
    PRINT '<<< CREATED INDEX dbo.TLIFEST.ILIFEST_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TLIFEST.ILIFEST_00 >>>'
go
