       PRINT '<<<  FAILED DROPPING TABLE dbo.TPRSMAP >>>'
    ELSE
       PRINT '<<< TABLE DROPPED dbo.TPRSMAP >>>'
END
go


/*==============================================================*/
/* Table: dbo.TPRSMAP                                               */
/*==============================================================*/
create table TPRSMAP(
PRS_CF	smallint not null, 
ACMTRS_NT	smallint not null,
PARM1	varchar(32) null,
PARM2	varchar(32) null,
PARM3	varchar(32) null,
PARM4	varchar(32) null,
PARM5	varchar(32) null,
PARM6	varchar(32) null,
PARM7	varchar(32) null,
PARM8	varchar(32) null,
PARM9	varchar(32) null,
PARM10	varchar(32) null
)


go
IF OBJECT_ID('dbo.TPRSMAP') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TPRSMAP >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TPRSMAP >>>'
go


