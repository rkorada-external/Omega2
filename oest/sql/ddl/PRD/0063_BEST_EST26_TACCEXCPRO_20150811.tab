USE BEST
go

IF OBJECT_ID('dbo.TACCEXCPRO') IS NOT NULL
BEGIN
    DROP TABLE dbo.TACCEXCPRO
    IF OBJECT_ID('dbo.TACCEXCPRO') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE dbo.TACCEXCPRO >>>'
    ELSE
       PRINT '<<< TABLE DROPPED dbo.TACCEXCPRO >>>'
END

go

CREATE TABLE dbo.TACCEXCPRO
(
    SSD_CF       	USSD_CF  NOT NULL,
    ESB_CF       	UESB_CF  NOT NULL,
    LSTUPDUSR_CF    UUPDUSR_CF  NOT NULL,
    CTR_NF       	UCTR_NF NOT NULL,
    SEC_NF        	USEC_NF  NOT NULL,
	UWY_NF			UUWY_NF	NOT NULL,
	ACY_NF			smallint	NOT NULL,
	DETTRNCOD_CF	char(5)		NOT NULL,
	ACCMNT_M		UAMT_M 	NOT NULL,
	ESTMNT_M		UAMT_M	NOT NULL,
	DIFFMNT_M		UAMT_M	NOT NULL,
	CLODAT_D		Datetime	NOT NULL,
	GAP_D			Datetime	NOT NULL,
	GAPSTS_NT		tinyint		NOT NULL,
	CUR_CF			UCUR_CF		NOT NULL,
	CMT_NT			UCMT_NT  			NULL,
    CONSTRAINT PK_TACCEXCPRO_00
    PRIMARY KEY CLUSTERED (SSD_CF,ESB_CF,LSTUPDUSR_CF,CTR_NF,SEC_NF,UWY_NF,ACY_NF,DETTRNCOD_CF,GAP_D)
)
LOCK ALLPAGES
go
IF OBJECT_ID('dbo.TACCEXCPRO') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TACCEXCPRO >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TACCEXCPRO >>>'
go

