USE BEST
go
IF OBJECT_ID('TLOADEST') IS NOT NULL
BEGIN
    -- Backup when there are data in TLOADEST
    CREATE TABLE #backupTLOADEST
    (
        FILENO_NT         UUWENTNBR_NT  NOT NULL,
        SSD_CF              USSD_CF       NOT NULL,
        ESB_CF              UESB_CF       NOT NULL,
        FILE_LL UL64          NOT NULL,
        FILEUNIXNAME_LL UL64          NOT NULL,
        FILETYPE_NT             tinyint NOT NULL,
        CRE_D       datetime      NULL,
        NBLINES_NT    int           DEFAULT 0 NOT NULL,
        NBLINESKO_NT     int           DEFAULT 0 NOT NULL,
        NBANO_NT      int           DEFAULT 0 NOT NULL,
        CREUSR_CF        UUSR_CF       NOT NULL,
        STATUS_CF    tinyint DEFAULT 0 
    )
    IF OBJECT_ID('#backupTLOADEST') IS NOT NULL
      PRINT '<<< CREATED TEMP TABLE #backupTLOADEST >>>'
    ELSE
      PRINT '<<< FAILED CREATING TEMP TABLE #backupTLOADEST >>>'

    INSERT INTO #backupTLOADEST
    SELECT * FROM TLOADEST
    
    DROP TABLE TLOADEST
    IF OBJECT_ID('TLOADEST') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TLOADEST >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TLOADEST >>>'
END
go
CREATE TABLE TLOADEST
(
    FILENO_NT         UUWENTNBR_NT  NOT NULL,
    SSD_CF              USSD_CF       NOT NULL,
    ESB_CF              UESB_CF       NOT NULL,
    FILE_LL UL64          NOT NULL,
    FILEUNIXNAME_LL UL64          NOT NULL,
    FILETYPE_NT             tinyint NOT NULL,
    CRE_D       datetime      NULL,
    NBLINES_NT    int           DEFAULT 0 NOT NULL,
    NBLINESKO_NT     int           DEFAULT 0 NOT NULL,
    NBANO_NT      int           DEFAULT 0 NOT NULL,
    CREUSR_CF        UUSR_CF       NOT NULL,
    STATUS_CF    tinyint DEFAULT 0 
)
LOCK DATAROWS
go
IF OBJECT_ID('TLOADEST') IS NOT NULL
    PRINT '<<< CREATED TABLE TLOADEST >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TLOADEST >>>'
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TLOADEST') AND name='ITLOADEST_00')
BEGIN
    DROP INDEX TLOADEST.ITLOADEST_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TLOADEST') AND name='ITLOADEST_00')
        PRINT '<<< FAILED DROPPING INDEX TLOADEST.ITLOADEST_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX TLOADEST.ITLOADEST_00 >>>'
END
go
CREATE NONCLUSTERED INDEX ITLOADEST_00 
    ON TLOADEST (SSD_CF, ESB_CF, FILETYPE_NT, CREUSR_CF, STATUS_CF)
go
IF OBJECT_ID('#backupTLOADEST') IS NOT NULL 
BEGIN
    INSERT INTO TLOADEST
    SELECT * FROM #backupTLOADEST

    DROP TABLE #backupTLOADEST
END
go
GRANT REFERENCES ON TLOADEST TO GOMEGA
go
GRANT REFERENCES ON TLOADEST TO GDBBATCH
go
GRANT SELECT ON TLOADEST TO GCONSULT
go
GRANT SELECT ON TLOADEST TO GOMEGA
go
GRANT SELECT ON TLOADEST TO GDBBATCH
go
GRANT INSERT ON TLOADEST TO GOMEGA
go
GRANT INSERT ON TLOADEST TO GDBBATCH
go
GRANT DELETE ON TLOADEST TO GOMEGA
go
GRANT DELETE ON TLOADEST TO GDBBATCH
go
GRANT UPDATE ON TLOADEST TO GOMEGA
go
GRANT UPDATE ON TLOADEST TO GDBBATCH
go
GRANT DELETE STATISTICS ON TLOADEST TO GOMEGA
go
GRANT DELETE STATISTICS ON TLOADEST TO GDBBATCH
go
GRANT TRUNCATE TABLE ON TLOADEST TO GOMEGA
go
GRANT TRUNCATE TABLE ON TLOADEST TO GDBBATCH
go
GRANT UPDATE STATISTICS ON TLOADEST TO GOMEGA
go
GRANT UPDATE STATISTICS ON TLOADEST TO GDBBATCH
go
GRANT TRANSFER TABLE ON TLOADEST TO GDBBATCH
go
