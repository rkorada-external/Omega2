/*==============================================================*/
/* Table: TIfrs17Chain                                          */
/*==============================================================*/
create table TIfrs17Chain (
   chain                varchar(30)                    not null,
   comment              varchar(64)                    null
)
go

alter table TIfrs17Chain
   add constraint PK_TIFRS17CHAIN primary key (chain)
go

/*==============================================================*/
/* Table: TIfrs17ContextRequest                                 */
/*==============================================================*/
create table TIfrs17ContextRequest (
   requestId            varchar(30)                    not null,
   ContextId            varchar(20)                    not null,
   comment              varchar(64)                    null
)
go

alter table TIfrs17ContextRequest
   add constraint PK_TIFRS17ContextRequest primary key (requestId, ContextId)
go

/*==============================================================*/
/* Table: TIfrs17Context                                        */
/*==============================================================*/
create table TIfrs17Context (
   ContextId            varchar(20)                    not null,
   comment              varchar(64)                    null
)
go

alter table TIfrs17Context
   add constraint PK_TIFRS17CONTEXT primary key (ContextId)
go

/*==============================================================*/
/* Table: TIfrs17Perm                                           */
/*==============================================================*/
create table TIfrs17Perm (
   version              smallint                       not null,
   fileVariable         varchar(50)                    not null,
   ContextId            varchar(20)                    not null,
   pattern              varchar(128)                   null,
   folder               varchar(20)                    null,
   fonction             varchar(30)                    null,
   chain                varchar(30)                    not null,
   fileName             varchar(30)                    null,
   comment              varchar(64)                    null
)
go

alter table TIfrs17Perm
   add constraint PK_TIFRS17PERM primary key (version, fileVariable, ContextId, chain)
go

/*==============================================================*/
/* Table: TIfrs17Plan                                           */
/*==============================================================*/
create table TIfrs17Plan (
   requestId            varchar(30)                    not null,
   chain                varchar(30)                    not null,
   planId               varchar(30)                    not null,
   comment              varchar(64)                    null
)
go

alter table TIfrs17Plan
   add constraint PK_TIFRS17PLAN primary key (planId, chain, requestId)
go

/*==============================================================*/
/* Table: TIfrs17Request                                        */
/*==============================================================*/
create table TIfrs17Request (
   requestId            varchar(30)                    not null,
   comment              varchar(64)                    null
)
go

alter table TIfrs17Request
   add constraint PK_TIFRS17REQUEST primary key (requestId)
go

alter table TIfrs17ContextRequest
   add constraint FK_CONTEXT__REF_REQ foreign key (requestId)
      references TIfrs17Request (requestId)
go

alter table TIfrs17ContextRequest
   add constraint FK_CONTEXT__REF_TIFRS17Context foreign key (ContextId)
      references TIfrs17Context (ContextId)
go

alter table TIfrs17Perm
   add constraint FK_TIFRS17P_CHAIN_OWN_TIFRS17C foreign key (chain)
      references TIfrs17Chain (chain)
go

alter table TIfrs17Perm
   add constraint FK_TIFRS17P_REFERENCE_TIFRS17C foreign key (ContextId)
      references TIfrs17Context (ContextId)
go

alter table TIfrs17Plan
   add constraint FK_TIFRS17P_REF_REQ foreign key (requestId)
      references TIfrs17Request (requestId)
go

alter table TIfrs17Plan
   add constraint FK_chain_REF_plan foreign key (chain)
      references TIfrs17Chain (chain)
go

