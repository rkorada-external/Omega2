if exists (select 1 
            from  sysobjects c 
            join  sysconstraints s on (s.constrid = c.id and s.tableid = object_id('TIfrs17ContextRequest'))
            where name = 'FK_CONTEXT__REF_REQ' and type = 'RI')
   alter table TIfrs17ContextRequest
      drop constraint FK_CONTEXT__REF_REQ
go

