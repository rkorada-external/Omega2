USE BTRAV
go
-- UAT 1b btrav changes Sam Mansour Feb 03 2014
--  Removed d b o references and added grant for GDBBATCH added the ubgl
/* UBGL_ON */
/*
 * Drop TABLE EST_ESID0811_ESTIMVIE
 */
IF OBJECT_ID('EST_ESID0811_ESTIMVIE') IS NOT NULL
BEGIN
    DROP TABLE EST_ESID0811_ESTIMVIE
    PRINT '<<< DROPPED TABLE EST_ESID0811_ESTIMVIE >>>'
END
go

CREATE TABLE EST_ESID0811_ESTIMVIE
(
    CTR_NF    UCTR_NF    NOT NULL,
    SEC_NF    USEC_NF    NOT NULL,
    UWY_NF    UUWY_NF    NOT NULL,
    ACY_NF    smallint   NOT NULL,
    CUR_CF    UCUR_CF    DEFAULT ''   NOT NULL,
    ACMTRS_NT smallint   NOT NULL,
    ESTMNT_M  UAMT_M     NOT NULL,
    CREUSR_CF UUPDUSR_CF DEFAULT user NOT NULL
)
LOCK DATAROWS
WITH EXP_ROW_SIZE=1
go
IF OBJECT_ID('EST_ESID0811_ESTIMVIE') IS NOT NULL
    PRINT '<<< CREATED TABLE EST_ESID0811_ESTIMVIE >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE EST_ESID0811_ESTIMVIE >>>'
go
GRANT ALL ON EST_ESID0811_ESTIMVIE TO GOMEGA
go
GRANT ALL ON EST_ESID0811_ESTIMVIE TO GCONSULT
go
GRANT ALL ON EST_ESID0811_ESTIMVIE TO GDBBATCH
go