USE BEST
go
IF OBJECT_ID('TLOADAUTOEST') IS NOT NULL
BEGIN
  DROP TABLE TLOADAUTOEST
  IF OBJECT_ID('TLOADAUTOEST') IS NOT NULL
    PRINT '<<< FAILED DROPPING TABLE TLOADAUTOEST >>>'
  ELSE
    PRINT '<<< DROPPED TABLE TLOADAUTOEST >>>'
END
go
CREATE TABLE TLOADAUTOEST
(
	UPLDNO_NT int NOT NULL,
	FILENO_NT	int NOT NULL,
	SSD_CF	USSD_CF NOT NULL,
	ESB_CF	UESB_CF NOT NULL,
	FILE_LL	UL64 NOT NULL,
	FILEUNIXNAME_LL	UL64 NOT NULL,
	FILETYPE_NT	tinyint NOT NULL,
	CRE_D	datetime NULL,
	PROVIDER_CF UL16 NOT NULL,
	NBLINES_NT	int DEFAULT 0 NOT NULL,
	NBLINESKO_NT	int DEFAULT 0 NOT NULL,
	NBANO_NT	int DEFAULT 0 NOT NULL,
	CREUSR_CF	UUSR_CF NOT NULL,
	STATUS_CF	tinyint NULL 
)
LOCK DATAROWS
go
IF OBJECT_ID('TLOADAUTOEST') IS NOT NULL
  PRINT '<<< CREATED TABLE TLOADAUTOEST >>>'
ELSE
  PRINT '<<< FAILED CREATING TABLE TLOADAUTOEST >>>'
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TLOADAUTOEST') AND name='ITLOADAUTOEST_00')
BEGIN
	DROP INDEX TLOADAUTOEST.ITLOADAUTOEST_00
	IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TLOADAUTOEST') AND name='ITLOADAUTOEST_00')
    PRINT '<<< FAILED DROPPING INDEX TLOADAUTOEST.ITLOADAUTOEST_00 >>>'
	ELSE
    PRINT '<<< DROPPED INDEX TLOADAUTOEST.ITLOADAUTOEST_00 >>>'
END
go
CREATE NONCLUSTERED INDEX ITLOADAUTOEST_00 
  ON TLOADAUTOEST (SSD_CF, ESB_CF, FILETYPE_NT, PROVIDER_CF, CREUSR_CF, STATUS_CF)
go
GRANT ALL ON TLOADAUTOEST TO GOMEGA
go
GRANT ALL ON TLOADAUTOEST TO GDBBATCH
go
GRANT SELECT ON TLOADAUTOEST TO GCONSULT
go