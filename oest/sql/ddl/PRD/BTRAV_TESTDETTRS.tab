USE BTRAV
go
IF OBJECT_ID(user_name()+'.TESTDETTRS') IS NOT NULL
BEGIN
    DROP TABLE TESTDETTRS
    IF OBJECT_ID(user_name()+'.TESTDETTRS') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTDETTRS >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTDETTRS >>>'
END
go
--23/10/2013 Florent  :spot:25427 - user géographique
CREATE TABLE TESTDETTRS
(
    DETTRS_CF    UDEPADM_CT NOT NULL,
    PCPTRS_CF    UPAYRQS_NT NOT NULL,
    TRS_CF       UTEL       NOT NULL,
    SUBTRS_CF    USTA_CF    NOT NULL,
    CTRSCOD_CF   UDEPADM_CT NOT NULL,
    TRSTYP_CT    tinyint    NOT NULL,
    OSDRLS_CT    tinyint    NULL,
    LOGSIG_CT    char(1)    NOT NULL,
    RETTRSCOD_CF UDEPADM_CT NOT NULL,
    FINRLSTRS_CF UDEPADM_CT NOT NULL,
    INTRLSTRS_CF UDEPADM_CT NOT NULL,
    TYPCTR_CF    tinyint    NULL,
    CLMENT_B     bit        NOT NULL,
    RET_B        bit        NOT NULL,
    SNDRET_B     tinyint    NOT NULL,
    POSRETACC_NF int        NULL,
    OPN_B        bit        NOT NULL,
    USLFAC_B     bit        NOT NULL,
    USLPRT_B     bit        NOT NULL,
    USLNPT_B     bit        NOT NULL,
    LSTUPD_D     char(12)   NOT NULL,
    LSTUPDUSR_CF UTPPTRS_CF NOT NULL,
    COMP_B       bit        NOT NULL
)
LOCK DATAROWS
go
IF OBJECT_ID(user_name()+'.TESTDETTRS') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTDETTRS >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTDETTRS >>>'
go
GRANT SELECT ON TESTDETTRS TO GCONSULT
go
GRANT ALL ON TESTDETTRS TO GOMEGA
go
GRANT ALL ON TESTDETTRS TO GDBBATCH
go
