USE BTRAV
go

IF OBJECT_ID('TCURSII') IS NOT NULL
BEGIN
    DROP TABLE TCURSII
	PRINT '<<< TCURSII EXISTS. DROPPED. >>>'
END
GO

CREATE TABLE TCURSII
(
	CTY_CF		UCTY_CF		NOT NULL,
	CURDATE		DATETIME,
	CUR_CF		UCUR_CF			NOT NULL
)
LOCK DATAROWS
go
IF OBJECT_ID('TCURSII') IS NOT NULL
    PRINT '<<< CREATED TABLE TCURSII >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TCURSII >>>'
go
GRANT REFERENCES ON TCURSII TO GOMEGA
go
GRANT REFERENCES ON TCURSII TO GDBBATCH
go
GRANT SELECT ON TCURSII TO GCONSULT
go
GRANT SELECT ON TCURSII TO GOMEGA
go
GRANT SELECT ON TCURSII TO GDBBATCH
go
