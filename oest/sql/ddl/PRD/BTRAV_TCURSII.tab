go
GRANT UPDATE ON TCURSII TO GDBBATCH
go
GRANT DELETE STATISTICS ON TCURSII TO GOMEGA
go
GRANT DELETE STATISTICS ON TCURSII TO GDBBATCH
go
GRANT TRUNCATE TABLE ON TCURSII TO GOMEGA
go
GRANT TRUNCATE TABLE ON TCURSII TO GDBBATCH
go
