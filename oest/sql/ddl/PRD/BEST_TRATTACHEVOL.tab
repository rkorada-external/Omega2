USE BEST
go

IF OBJECT_ID('dbo.TRATTACHEVOL') IS NOT NULL
   DROP TABLE dbo.TRATTACHEVOL
go

CREATE TABLE dbo.TRATTACHEVOL
(
    SSD_CF       USSD_CF    NOT NULL,
    CTR_NF       UCTR_NF    NOT NULL,
    UWY_NF       UUWY_NF    NOT NULL,
    UW_NT        UUW_NT     NOT NULL,
    SEC_NF       USEC_NF    NOT NULL,
    END_NT       UEND_NT    NOT NULL,
    ESTCTR_NF    UCTR_NF    NULL,
    ESTSEC_NF    USEC_NF    NULL,
    SEG_NF       USEG_NF    NULL,
    CRE_D        UUPD_D     NOT NULL,
    CREUSR_CF    UUPDUSR_CF NOT NULL,
    LSTUPD_D     UUPD_D     NOT NULL,
    LSTUPDUSR_CF UUPDUSR_CF NOT NULL
)
LOCK ALLPAGES
go

ALTER TABLE TRATTACHEVOL
partition by list (SSD_CF)
(
PRATTACHEVOL_UBEU values (1, 2, 3, 4, 5, 6, 7, 8, 9, 12, 15, 16, 17, 18, 19, 23),
PRATTACHEVOL_UBAM values (10, 11, 13, 14, 25, 26),
PRATTACHEVOL_UBAS values (20, 22, 24)
)
go

IF OBJECT_ID('dbo.TRATTACHEVOL') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TRATTACHEVOL >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TRATTACHEVOL >>>'
go
GRANT DELETE ON dbo.TRATTACHEVOL TO GOMEGA
go
GRANT DELETE ON dbo.TRATTACHEVOL TO GDBBATCH
go
GRANT DELETE STATISTICS ON dbo.TRATTACHEVOL TO GOMEGA
go
GRANT DELETE STATISTICS ON dbo.TRATTACHEVOL TO GDBBATCH
go
