go
GRANT REFERENCES ON dbo.TRATTACHEVOL TO GDBBATCH
go
GRANT SELECT ON dbo.TRATTACHEVOL TO GCONSULT
go
GRANT SELECT ON dbo.TRATTACHEVOL TO GOMEGA
go
GRANT SELECT ON dbo.TRATTACHEVOL TO GDBBATCH
go
GRANT TRANSFER TABLE ON dbo.TRATTACHEVOL TO GOMEGA
go
GRANT TRANSFER TABLE ON dbo.TRATTACHEVOL TO GDBBATCH
go
GRANT TRUNCATE TABLE ON dbo.TRATTACHEVOL TO GOMEGA
go
