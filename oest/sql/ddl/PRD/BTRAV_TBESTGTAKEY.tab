IF OBJECT_ID('TBESTGTAKEY') IS NOT NULL
BEGIN
    DROP TABLE TBESTGTAKEY
    IF OBJECT_ID('TBESTGTAKEY') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TBESTGTAKEY >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TBESTGTAKEY >>>'
END
go
CREATE TABLE TBESTGTAKEY
(
    CTR_NF UCTR_NF NOT NULL,
    END_NT UEND_NT DEFAULT 0 NOT NULL,
    SEC_NF USEC_NF NOT NULL,
    UWY_NF UUWY_NF NOT NULL,
    UW_NT  UUW_NT  DEFAULT 1 NOT NULL
)
LOCK DATAROWS
WITH EXP_ROW_SIZE=1
PARTITION BY ROUNDROBIN
(TBESTGTAKEY_777766797)
go
IF OBJECT_ID('TBESTGTAKEY') IS NOT NULL
    PRINT '<<< CREATED TABLE TBESTGTAKEY >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TBESTGTAKEY >>>'
go
GRANT ALL ON TBESTGTAKEY TO GOMEGA
go
GRANT ALL ON TBESTGTAKEY TO GDBBATCH
go
GRANT SELECT ON TBESTGTAKEY TO GCONSULT
go
