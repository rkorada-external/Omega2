USE BEST
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TPROJECSII') AND name='IPROJECSII_00')
BEGIN
    DROP INDEX TPROJECSII.IPROJECSII_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TPROJECSII') AND name='IPROJECSII_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TPROJECSII.IPROJECSII_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TPROJECSII.IPROJECSII_00 >>>'
END
go
CREATE UNIQUE CLUSTERED INDEX IPROJECSII_00
    ON dbo.TPROJECSII(SSD_CF,ESB_CF,CLODAT_D,CTR_NF,UWY_NF,SEC_NF,ACMTRS_NT,CUR_CF)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TPROJECSII') AND name='IPROJECSII_00')
    PRINT '<<< CREATED INDEX dbo.TPROJECSII.IPROJECSII_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TPROJECSII.IPROJECSII_00 >>>'
go
