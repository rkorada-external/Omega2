USE BEST
GO

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TIDLIFEST_GLOBAL') AND name='IIDLIFEST_GLOBAL_00')
BEGIN
    DROP INDEX TIDLIFEST_GLOBAL.IIDLIFEST_GLOBAL_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TIDLIFEST_GLOBAL') AND name='IIDLIFEST_GLOBAL_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TIDLIFEST_GLOBAL.IIDLIFEST_GLOBAL_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TIDLIFEST_GLOBAL.IIDLIFEST_GLOBAL_00 >>>'
END
GO
CREATE UNIQUE CLUSTERED INDEX IIDLIFEST_GLOBAL_00
    ON dbo.TIDLIFEST_GLOBAL(ID_CF, SSD_CF, ESB_CF, LSTUPDUSR_CF, GAAP_NT, PERIOD_NT, ACY_NF, END_D,QUARTER_B)
GO
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TIDLIFEST_GLOBAL') AND name='IIDLIFEST_GLOBAL_00')
    PRINT '<<< CREATED INDEX dbo.TIDLIFEST_GLOBAL.IIDLIFEST_GLOBAL_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TIDLIFEST_GLOBAL.IIDLIFEST_GLOBAL_00 >>>'
GO
