USE BTRAV
go
IF OBJECT_ID(user_name()+'.TESTTRSLNK') IS NOT NULL
BEGIN
    DROP TABLE TESTTRSLNK
    IF OBJECT_ID(user_name()+'.TESTTRSLNK') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTTRSLNK >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTTRSLNK >>>'
END
go
--23/10/2013 Florent  :spot:25427 - user géographique
CREATE TABLE TESTTRSLNK
(
    ACMTRS_NT smallint   NOT NULL,
    DETTRS_CF UDETTRS_CF NOT NULL
)
LOCK DATAROWS
WITH EXP_ROW_SIZE=1
go
IF OBJECT_ID(user_name()+'.TESTTRSLNK') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTTRSLNK >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTTRSLNK >>>'
go
GRANT SELECT ON TESTTRSLNK TO GCONSULT
go
GRANT ALL ON TESTTRSLNK TO GOMEGA
go
GRANT ALL ON TESTTRSLNK TO GDBBATCH
go
