USE BEST
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFDRID') AND name='ILIFDRID_00')
BEGIN
    DROP INDEX TLIFDRID.ILIFDRID_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFDRID') AND name='ILIFDRID_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TLIFDRID.ILIFDRID_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TLIFDRID.ILIFDRID_00 >>>'
END
go
CREATE UNIQUE CLUSTERED INDEX ILIFDRID_00
    ON dbo.TLIFDRID(CTR_NF,END_NT,SEC_NF,UWY_NF,UW_NT,CRE_D,BALSHEY_NF,BALSHTMTH_NF,ACY_NF,ACM_NF)
LOCAL INDEX ILIFDRI_00_1737054193
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFDRID') AND name='ILIFDRID_00')
    PRINT '<<< CREATED INDEX dbo.TLIFDRID.ILIFDRID_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TLIFDRID.ILIFDRID_00 >>>'
go
