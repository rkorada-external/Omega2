USE BEST
go

IF OBJECT_ID('dbo.TEXPRAT') IS NOT NULL
BEGIN
    DROP TABLE dbo.TEXPRAT
    IF OBJECT_ID('dbo.TEXPRAT') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE dbo.TEXPRAT >>>'
    ELSE
       PRINT '<<< TABLE DROPPED dbo.TEXPRAT >>>'
END
go


/*==============================================================*/
/* Table: dbo.TEXPRAT                                               */
/*==============================================================*/
create table dbo.TEXPRAT 
(
   SSD_CF               USSD_CF                        not null,
   ESB_CF               UESB_CF                        not null,
   SEG_NF               USGMT_NF                       not null,
   NORME_CF             char(5)                        not null,
   CTRNAT_CT            char(1)                        not null,
   ACQRAT_R             USHA_R                         null,
   MAINTRAT_R           USHA_R                         null,
   CLODAT_D             datetime                       not null,
   PER_CF               char(10)                       not null,
   CREUSR_CF            UUPDUSR_CF        					NOT NULL,
   CRE_D                UUPD_D            					NOT NULL,
   LSTUPDUSR_CF         UUPDUSR_CF        					NOT NULL,
   LSTUPD_D             UUPD_D            					NOT NULL
)


go
IF OBJECT_ID('dbo.TEXPRAT') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TEXPRAT >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TEXPRAT >>>'
go

CREATE UNIQUE CLUSTERED INDEX TEXPRAT
    ON dbo.TEXPRAT(SSD_CF, ESB_CF ,SEG_NF ,NORME_CF,CTRNAT_CT , CLODAT_D, PER_CF)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TEXPRAT') AND name='TEXPRAT')
    PRINT '<<< CREATED INDEX ON TEXPRAT >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ON TEXPRAT >>>'
go

GRANT REFERENCES ON dbo.TEXPRAT TO GOMEGA
go
GRANT REFERENCES ON dbo.TEXPRAT TO GDBBATCH
go
GRANT SELECT ON dbo.TEXPRAT TO GCONSULT
go
