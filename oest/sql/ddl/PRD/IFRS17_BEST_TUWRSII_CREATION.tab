USE BEST
go

IF OBJECT_ID('TUWRSII') IS NOT NULL
BEGIN
    DROP TABLE TUWRSII
    IF OBJECT_ID('TUWRSII') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TUWRSII >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TUWRSII >>>'
END
go

CREATE TABLE TUWRSII
(
    SSD_CF        USSD_CF 	  NOT NULL,
    ESB_CF        UESB_CF 	  NOT NULL,
	ORGDIV_NF	  USGMT_NF    NOT NULL,
	UWR_R		  USHORAT_R   NULL,
	FCLODAT_D	  DATETIME    NULL,
	CRE_D		  DATETIME    NOT NULL,
	CREUSR_CF	  CHAR(04) 	  NOT NULL,
	LSTUPD_D	  DATETIME	  NOT NULL,
	LSTUPDUSR_CF  CHAR(04)	  NOT NULL	
)

go

IF OBJECT_ID('TUWRSII') IS NOT NULL
    PRINT '<<< CREATED TABLE TUWRSII>>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TUWRSII >>>'
go

CREATE UNIQUE CLUSTERED INDEX ITUOASII_00
    ON TUWRSII(SSD_CF,ESB_CF,ORGDIV_NF,FCLODAT_D)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TUWRSII') AND name='ITUOASII_00')
    PRINT '<<< CREATED INDEX ITUOASII_00 ON TUWRSII >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ITUOASII_00 ON TUWRSII >>>'
go

GRANT REFERENCES ON TUWRSII TO GOMEGA
go
GRANT REFERENCES ON TUWRSII TO GDBBATCH
go
