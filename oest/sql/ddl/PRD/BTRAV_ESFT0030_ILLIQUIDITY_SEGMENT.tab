use BTRAV
go

IF OBJECT_ID('ESFT0030_ILLIQUIDITY_SEGMENT') IS NOT NULL
begin
  drop TABLE  ESFT0030_ILLIQUIDITY_SEGMENT
  if object_id('ESFT0030_ILLIQUIDITY_SEGMENT') is not null
    print '<<< FAILED DROPPING TABLE ESFT0030_ILLIQUIDITY_SEGMENT >>>'
  else
    print '<<< DROPPED TABLE ESFT0030_ILLIQUIDITY_SEGMENT >>>'
end
go

create table ESFT0030_ILLIQUIDITY_SEGMENT
(
  CTR_NF			UCTR_NF 		NOT NULL,
  END_NT  			UEND_NT 		NOT NULL,
  SEC_NF 			USEC_NF 		NOT NULL,
  UWY_NF 			UUWY_NF 		NOT NULL,
  UW_NT 			UUW_NT 			NOT NULL,			
  SGTTYP_NT			INTEGER 		NULL,
  SGMT_NF			INTEGER			NULL,
  SGMT_LS			UL16 			NULL,
  SGMT_LL			UL64	 		NULL,
  SGTVER_NT			INTEGER			NULL
)
go
IF OBJECT_ID('ESFT0030_ILLIQUIDITY_SEGMENT') IS NOT NULL
  print '<<< CREATED TABLE ESFT0030_ILLIQUIDITY_SEGMENT >>>'
else
  print '<<< FAILED CREATING TABLE ESFT0030_ILLIQUIDITY_SEGMENT >>>'
go

