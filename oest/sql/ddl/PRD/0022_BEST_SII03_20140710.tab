USE BEST
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TSIIERR') AND name='ITSIIERR_00')
BEGIN
    DROP INDEX TSIIERR.ITSIIERR_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TSIIERR') AND name='ITSIIERR_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TSIIERR.ITSIIERR_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TSIIERR.ITSIIERR_00 >>>'
END
go
CREATE CLUSTERED INDEX ITSIIERR_00
    ON dbo.TSIIERR(UPID_NT,ILIASNBR_NT , MESS_N, ERRROW_NF)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TSIIERR') AND name='ITSIIERR_00')
    PRINT '<<< CREATED INDEX dbo.TSIIERR.ITSIIERR_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TSIIERR.ITSIIERR_00 >>>'
go
