 ,LOCIFRSLOB_CF 	varchar(5)		NULL
 ,LOCIFRSLOB_LL 	varchar(64)		NULL
 ,CRUW_NT 			UUW_NT 			DEFAULT 1 	NOT NULL
 ,CTRTYP_CT			varchar(4) 		NULL
)
go
IF OBJECT_ID('ESFD8000_TCR') IS NOT NULL
