use BTRAV
go
IF OBJECT_ID('ESFD8000_TCR') IS NOT NULL
begin
  drop TABLE  ESFD8000_TCR
  if object_id('ESFD8000_TCR') is not null
    print '<<< FAILED DROPPING TABLE ESFD8000_TCR >>>'
  else
    print '<<< DROPPED TABLE ESFD8000_TCR >>>'
end
go

create table ESFD8000_TCR
