USE BEST
go

IF OBJECT_ID('dbo.TI17CTRINFO') IS NOT NULL
BEGIN
    DROP TABLE dbo.TI17CTRINFO
    IF OBJECT_ID('dbo.TI17CTRINFO') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE dbo.TI17CTRINFO >>>'
    ELSE
       PRINT '<<< TABLE DROPPED dbo.TI17CTRINFO >>>'
END
go

CREATE TABLE TI17CTRINFO
(
    CTR_NF       UCTR_NF   NULL,
    SEC_NF       USEC_NF   NULL,
	UWY_NF 		 UUWY_NF   NULL,
	UW_NT 		 UUW_NT    NULL,
	END_NT       UEND_NT   NULL,
	RETCTR_NF 	 UCTR_NF   NULL,
	RETSEC_NF 	 USEC_NF   NULL,
	RTY_NF 		 UUWY_NF   NULL,
	RETUW_NT 	 UUW_NT    NULL,
	RETEND_NT    UEND_NT   NULL,
	LOFACTORSTD_R float    NULL,
	LOFACTORINI_R float    NULL,
	LCPATTERN_R   float    NULL,
	CSMPATTERN_R  float    NULL,
	ANNLIM_B	 char(1)   DEFAULT 0 NOT NULL,
	CLODAT_D	 datetime  NOT NULL,
    CRE_D        datetime  NOT NULL,
    CREUSR_CF    UUSR_CF   NOT NULL,
	LSTUPDUSR_CF UUSR_CF   NULL,
	LSTUPD_D	 datetime  NULL
)

go

IF OBJECT_ID('dbo.TI17CTRINFO') IS NOT NULL 
    PRINT '<<< CREATED TABLE dbo.TI17CTRINFO >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TI17CTRINFO >>>'
go

CREATE INDEX II17CTRINFO_00
    ON dbo.TI17CTRINFO(CTR_NF,SEC_NF,UWY_NF,UW_NT,END_NT,RETCTR_NF,RETSEC_NF,RTY_NF,RETUW_NT,RETEND_NT,CLODAT_D)
go

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TI17CTRINFO') AND name='II17CTRINFO_00')
    PRINT '<<< CREATED INDEX dbo.TI17CTRINFO.II17CTRINFO_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TI17CTRINFO.II17CTRINFO_00 >>>'
go

CREATE INDEX II17CTRINFO_01
    ON dbo.TI17CTRINFO(CTR_NF,SEC_NF,UWY_NF,UW_NT,END_NT,CLODAT_D)
go

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TI17CTRINFO') AND name='II17CTRINFO_01')
    PRINT '<<< CREATED INDEX dbo.TI17CTRINFO.II17CTRINFO_01 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TI17CTRINFO.II17CTRINFO_01 >>>'
go

CREATE INDEX II17CTRINFO_02
    ON dbo.TI17CTRINFO(RETCTR_NF,RETSEC_NF,RTY_NF,RETUW_NT,RETEND_NT,CLODAT_D)
go

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TI17CTRINFO') AND name='II17CTRINFO_02')
