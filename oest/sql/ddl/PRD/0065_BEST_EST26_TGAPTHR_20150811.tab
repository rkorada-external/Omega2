USE BEST
go

IF OBJECT_ID('dbo.TGAPTHR') IS NOT NULL
BEGIN
    DROP TABLE dbo.TGAPTHR
    IF OBJECT_ID('dbo.TGAPTHR') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE dbo.TGAPTHR >>>'
    ELSE
       PRINT '<<< TABLE DROPPED dbo.TGAPTHR >>>'
END

go

CREATE TABLE dbo.TGAPTHR
(
    SSD_CF       	USSD_CF  NOT NULL,
    ESB_CF       	UESB_CF  NOT NULL,
    CUR_CF       	UCUR_CF NOT NULL,
	AMT_M			UAMT_M	NULL,
	AMT2_M        	UAMT_M    NULL,
	CREUSR_CF		UUPDUSR_CF			NULL,
	CRE_D			UUPD_D		NULL,
	LSTUPDUSR_CF	UUPDUSR_CF			NULL,
	LSTUPD_D		UUPD_D 		NULL,
	TIMESTAMP		timestamp		NULL,
    CONSTRAINT PK_TGAPTHR_00
    PRIMARY KEY CLUSTERED (SSD_CF,ESB_CF)
)
LOCK ALLPAGES
go
IF OBJECT_ID('dbo.TGAPTHR') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TGAPTHR >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TGAPTHR >>>'
go

