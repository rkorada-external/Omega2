USE BEST
go
CREATE TABLE dbo.TRETCATCVR
( 
    RCATCVR_NT      numeric(11,0) NOT NULL,
    SSD_CF          USSD_CF       NOT NULL,
    ESB_CF          UESB_CF       NOT NULL,
    RETCTR_NF       UCTR_NF       NOT NULL,
    RTY_NF          UUWY_NF       NOT NULL,
    RETSEC_NF       USEC_NF       NOT NULL,
    AECUR_CF        UCUR_CF       NOT NULL,
    BALSH_D         datetime      NOT NULL,
    CATCVRDMN_CT    int           NOT NULL,
    RCL_NF          UCLM_NF       NULL,
    PLC_NT          UPLC_NT       NULL,
    RETCEDAMT_M     decimal(18,3) DEFAULT 0         NOT NULL,
    ULTAMT_M        decimal(18,3) NULL,
    TRNAMT_M        decimal(18,3) NULL,
    TRN_NT          numeric(10,0) NULL,
    CMT_NT          int           NULL,
    BOOKING_B       bit           DEFAULT 0         NOT NULL,
    MANUAL_B        bit           DEFAULT 0         NOT NULL,
    CRE_D           datetime      DEFAULT getdate() NOT NULL,
    CREUSR_CF       UUPDUSR_CF    DEFAULT user      NOT NULL,
    LSTUPD_D        datetime      DEFAULT getdate() NOT NULL,
    LSTUPDUSR_CF    UUPDUSR_CF    DEFAULT user      NOT NULL,
    LSTULTUPD_D     datetime      NULL,
    LSTULTUPDUSR_CF UUPDUSR_CF    NULL,
    CONSTRAINT PK_TRETCATCVR
    PRIMARY KEY CLUSTERED (RCATCVR_NT)
)
LOCK ALLPAGES
go
IF OBJECT_ID('dbo.TRETCATCVR') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TRETCATCVR >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TRETCATCVR >>>'
go
