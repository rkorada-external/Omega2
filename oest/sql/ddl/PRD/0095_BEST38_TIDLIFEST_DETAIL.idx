USE BEST
GO

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TIDLIFEST_DETAIL') AND name='IIDLIFEST_DETAIL_00')
BEGIN
    DROP INDEX TIDLIFEST_DETAIL.IIDLIFEST_DETAIL_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TIDLIFEST_DETAIL') AND name='IIDLIFEST_DETAIL_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TIDLIFEST_DETAIL.IIDLIFEST_DETAIL_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TIDLIFEST_DETAIL.IIDLIFEST_DETAIL_00 >>>'
END
GO
CREATE UNIQUE CLUSTERED INDEX IIDLIFEST_DETAIL_00
    ON dbo.TIDLIFEST_DETAIL(ID_CF, SSD_CF, ESB_CF, CTR_NF, SEC_NF, ACY_NF, DETTRNCOD_CF, LSTUPDUSR_CF, PERIOD_NT, UWY_NF, QUARTER_B)
GO
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TIDLIFEST_DETAIL') AND name='IIDLIFEST_DETAIL_00')
    PRINT '<<< CREATED INDEX dbo.TIDLIFEST_DETAIL.IIDLIFEST_DETAIL_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TIDLIFEST_DETAIL.IIDLIFEST_DETAIL_00 >>>'
GO
