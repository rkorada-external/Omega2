---- SPIRA 	109481

USE BEST
go
SETUSER 'dbo'
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TACCSUP') AND name='IACCSUP_01')
BEGIN
    DROP INDEX TACCSUP.IACCSUP_01
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TACCSUP') AND name='IACCSUP_01')
        PRINT '<<< FAILED DROPPING INDEX dbo.TACCSUP.IACCSUP_01 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TACCSUP.IACCSUP_01 >>>'
END
go
SETUSER
go
CREATE  INDEX IACCSUP_01
    ON dbo.TACCSUP(ACCTRN_NT )
	
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TACCSUP') AND name='IACCSUP_01')
    PRINT '<<< CREATED INDEX dbo.TACCSUP.IACCSUP_01 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TACCSUP.IACCSUP_01 >>>'
go
     