USE BTRAV
go
IF OBJECT_ID(user_name()+'.TESTPMDCTR') IS NOT NULL
BEGIN
    DROP TABLE TESTPMDCTR
    IF OBJECT_ID(user_name()+'.TESTPMDCTR') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTPMDCTR >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTPMDCTR >>>'
END
go
-- 23/10/2013 Florent :spot:25427 - user gÈographique
-- 20/11/2014 Florent :spot:27747 - ajout multi-devise
CREATE TABLE TESTPMDCTR
(
  CTR_NF       UCTR_NF NOT NULL
 ,UWY_NF       UUWY_NF NOT NULL
 ,UW_NT        UUW_NT  NOT NULL
 ,END_NT       UEND_NT NOT NULL
 ,SEC_NF       USEC_NF NOT NULL
 ,SSD_CF       USSD_CF NOT NULL
 ,EGPCUR_CF    UCUR_CF NOT NULL
 ,EXCEGP_R     ULNGDEC NULL
 ,PMDEGPCUR_M  UAMT_M  NULL
 ,MINPRVPR1_M  UAMT_M  NULL
 ,EXCPR1_R     ULNGDEC NULL
 ,PRVPRMCU1_CF UCUR_CF NOT NULL
 ,MINPRVPR2_M  UAMT_M  NULL
 ,EXCPR2_R     ULNGDEC NULL
 ,PRVPRMCU2_CF UCUR_CF NOT NULL
 ,MINPRVPR3_M  UAMT_M  NULL
 ,EXCPR3_R     ULNGDEC NULL
 ,PRVPRMCU3_CF UCUR_CF NOT NULL
 ,MINPRVPR4_M  UAMT_M  NULL
 ,EXCPR4_R     ULNGDEC NULL
 ,PRVPRMCU4_CF UCUR_CF NOT NULL
 ,MINPRVPR5_M  UAMT_M  NULL
 ,EXCPR5_R     ULNGDEC NULL
 ,PRVPRMCU5_CF UCUR_CF NOT NULL
)
LOCK DATAROWS
go
IF OBJECT_ID(user_name()+'.TESTPMDCTR') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTPMDCTR >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTPMDCTR >>>'
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID(user_name()+'.TESTPMDCTR') AND name='IESTPMDCTR')
BEGIN
    DROP INDEX TESTPMDCTR.IESTPMDCTR
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID(user_name()+'.TESTPMDCTR') AND name='IESTPMDCTR')
        PRINT '<<< FAILED DROPPING INDEX TESTPMDCTR.IESTPMDCTR >>>'
    ELSE
        PRINT '<<< DROPPED INDEX TESTPMDCTR.IESTPMDCTR >>>'
END
go
CREATE NONCLUSTERED INDEX IESTPMDCTR
    ON TESTPMDCTR(CTR_NF,UWY_NF,UW_NT,END_NT,SEC_NF)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID(user_name()+'.TESTPMDCTR') AND name='IESTPMDCTR')
    PRINT '<<< CREATED INDEX TESTPMDCTR.IESTPMDCTR >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX TESTPMDCTR.IESTPMDCTR >>>'
go
GRANT SELECT ON TESTPMDCTR TO GCONSULT
go
GRANT ALL ON TESTPMDCTR TO GOMEGA
go
GRANT ALL ON TESTPMDCTR TO GDBBATCH
go
