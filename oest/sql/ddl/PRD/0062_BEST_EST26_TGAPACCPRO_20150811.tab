USE BEST
go 

IF OBJECT_ID('dbo.TGAPACCPRO') IS NOT NULL
BEGIN
    DROP TABLE dbo.TGAPACCPRO
    IF OBJECT_ID('dbo.TGAPACCPRO') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE dbo.TGAPACCPRO >>>'
    ELSE
       PRINT '<<< TABLE DROPPED dbo.TGAPACCPRO >>>'
END

go

CREATE TABLE dbo.TGAPACCPRO
(
    SSD_CF       	USSD_CF  NOT NULL,
    ESB_CF       	UESB_CF  NOT NULL,
    LSTUPDUSR_CF    UUPDUSR_CF  NOT NULL,
    CTR_NF       	UCTR_NF NOT NULL,
    SEC_NF        	USEC_NF  NOT NULL,
	UWY_NF			UUWY_NF	NOT NULL,
	ACY_NF			smallint	NOT NULL,
	DETTRNCOD_CF	char(5)		NOT NULL,
	ACCMNT_M		UAMT_M	NOT NULL,
	ESTMNT_M		UAMT_M	NOT NULL,
	DIFFMNT_M		UAMT_M	NOT NULL,
	SCOENDMTH_NF	tinyint		NOT NULL,
	GAP_D			Datetime	NOT NULL,
	VAC_NT			tinyint		NOT NULL,
	GAPSTS_NT		tinyint		NOT NULL,
	CUR_CF			UCUR_CF		NOT NULL,
	CMT_NT			UCMT_NT  			NULL,
    CONSTRAINT PK_TGAPACCPRO_00
    PRIMARY KEY CLUSTERED (SSD_CF,ESB_CF,LSTUPDUSR_CF,CTR_NF,SEC_NF,UWY_NF,ACY_NF,DETTRNCOD_CF,GAP_D,VAC_NT)
)
LOCK ALLPAGES
go
IF OBJECT_ID('dbo.TGAPACCPRO') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TGAPACCPRO >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TGAPACCPRO >>>'
go

