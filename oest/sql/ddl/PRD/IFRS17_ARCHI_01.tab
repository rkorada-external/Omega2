if exists (select 1 
            from  sysobjects c 
            join  sysconstraints s on (s.constrid = c.id and s.tableid = object_id('TI17PERMFIL'))
            where name = 'FK_FNCT_PERM' and type = 'RI')
   alter table TI17PERMFIL
      drop constraint FK_FNCT_PERM
go

