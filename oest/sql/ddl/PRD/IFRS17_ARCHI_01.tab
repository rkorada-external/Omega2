/*==============================================================*/
/* Table: TI17CHN                                               */
/*==============================================================*/
create table TI17CHN (
   CHAIN_CT             varchar(30)                    not null,
   CHAIN_LL             varchar(64)                    null
)
go

alter table TI17CHN
   add constraint PK_TI17CHN primary key nonclustered (CHAIN_CT)
go

/*==============================================================*/
/* Table: TI17FNC                                               */
/*==============================================================*/
create table TI17FNC (
   IDF_CT               varchar(30)                    not null,
   IDF_LL               varchar(64)                    null
)
go

alter table TI17FNC
   add constraint PK_TI17FNC primary key nonclustered (IDF_CT)
go

/*==============================================================*/
/* Table: TI17PERMFIL                                           */
/*==============================================================*/
create table TI17PERMFIL (
   IDF_CT               varchar(30)                    not null,
   PERMFIL_CT           varchar(50)                    not null,
   PATHPATTRN_LL        varchar(128)                   null,
   IO                   char(1)                        null,
   PERM_LL              varchar(64)                    null
)
go

alter table TI17PERMFIL
   add constraint PK_TI17PERMFIL primary key nonclustered (IDF_CT, PERMFIL_CT)
go

/*==============================================================*/
/* Table: TI17REQ                                               */
/*==============================================================*/
create table TI17REQ (
   REQCOD_CT            varchar(32)                    not null,
   REQCOD_LL            varchar(64)                    null
)
go

alter table TI17REQ
   add constraint PK_TI17REQ primary key nonclustered (REQCOD_CT)
go

/*==============================================================*/
/* Table: TI17REQCHN                                            */
/*==============================================================*/
create table TI17REQCHN (
   REQCOD_CT            varchar(32)                    not null,
   CHAIN_CT             varchar(30)                    not null,
   IDF_CT               varchar(30)                    not null,
   REQST_CHAIN_LL       char(10)                       null
)
go

alter table TI17REQCHN
   add constraint PK_TI17REQCHN primary key nonclustered (REQCOD_CT, CHAIN_CT, IDF_CT)
go

/*==============================================================*/
/* Table: TI17REQJOB                                            */
/*==============================================================*/
create table dbo.TI17REQJOB (
   SSD_CF               USSD_CF                        not null,
   BALSHEYEA_NF         smallint                       not null,
   BALSHTMTH_NF         tinyint                        not null,
   CLODAT_D             datetime                       not null,
   REQCOD_CT            varchar(32)                    not null,
   CRE_D                UUPD_D                         not null,
   DBCLO_D              UUPD_D                         not null,
   LAUNCH_D             UUPD_D                         null,
   CLOTYP_CT            char(5)                        null,
   NORME_CF             char(5)                        null,
   CLOPER_LS            UL64                           null,
   VRS_NF               numeric(10,0)                  null,
   UPDUSR_CF            UUSR_CF                        not null,
   START_D              UUPD_D                         null,
   END_D                UUPD_D                         null,
   SITE_CF              char(4)                        not null,
   ID_NF                int                            not null
)
go

alter table dbo.TI17REQJOB
   add constraint PK_TI17REQJOB primary key (REQCOD_CT, CRE_D, SITE_CF)
go

/*==============================================================*/
/* Table: TI17REQJOBPLAN                                        */
/*==============================================================*/
create table dbo.TI17REQJOBPLAN (
   SSD_CF               USSD_CF                        not null,
   BALSHEYEA_NF         smallint                       not null,
   BALSHTMTH_NF         tinyint                        not null,
   CLODAT_D             datetime                       not null,
   REQCOD_CT            varchar(32)                    not null,
   CRE_D                UUPD_D                         not null,
   DBCLO_D              UUPD_D                         null,
   LAUNCH_D             UUPD_D                         null,
   CLOTYP_CT            char(5)                        null,
   NORME_CF             char(5)                        null,
   CLOPER_LS            UL64                           null,
   VRS_NF               numeric(10,0)                  null,
   UPDUSR_CF            UUSR_CF                        null,
   START_D              UUPD_D                         null,
   END_D                UUPD_D                         null,
   SITE_CF              char(4)                        not null,
   ID_NF                int                            identity
)
go

alter table dbo.TI17REQJOBPLAN
   add constraint PK_TI17REQJOBPLAN primary key (REQCOD_CT, CRE_D, SITE_CF)
go

