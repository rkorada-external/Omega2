USE BEST
go

IF OBJECT_ID('TIDLIFEST_CALL') IS NOT NULL
BEGIN
    DROP TABLE TIDLIFEST_CALL
    IF OBJECT_ID('TIDLIFEST_CALL') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TIDLIFEST_CALL >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TIDLIFEST_CALL >>>'
END
go

CREATE TABLE TIDLIFEST_CALL
(
    ID_CF          int           NOT NULL,
	UPDTYP_CT      bit           NOT NULL,
    SSD_CF         USSD_CF       NOT NULL,
    ESB_CF         UESB_CF       NOT NULL,
    LSTUPDUSR_CF   UUSR_CF       NOT NULL,
    CTR_NF         UCTR_NF       NOT NULL,
    SEC_NF         USEC_NF       NOT NULL,
	UWY_NF         UUWY_NF       NOT NULL,
    FLAG_B         bit           NOT NULL,
	START_D        datetime      NOT NULL,
	END_D          datetime      NOT NULL,
    CONSTRAINT PK_TIDLIFEST_CALL_00
    PRIMARY KEY CLUSTERED (ID_CF,SSD_CF,ESB_CF,LSTUPDUSR_CF,CTR_NF,SEC_NF,UWY_NF,START_D,END_D)
)
LOCK ALLPAGES
go
IF OBJECT_ID('TIDLIFEST_CALL') IS NOT NULL
    PRINT '<<< CREATED TABLE TIDLIFEST_CALL >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TIDLIFEST_CALL >>>'
go
