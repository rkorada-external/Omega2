USE BEST
go
IF OBJECT_ID('TCASHFLOWADJ') IS NOT NULL
BEGIN
  -- Backup when there are data in TCASHFLOWADJ
  CREATE TABLE #backupTCASHFLOWADJ (
      TRN_NT numeric(10,0) not null,
      CLODAT_D datetime,
      SSD_CF USSD_CF not null,
      ESB_CF UESB_CF not null,
      CTR_NF UCTR_NF not null,
      SEC_NF USEC_NF not null,
      UWY_NF UUWY_NF not null,
      ACY_NF smallint not null,
      TRNCOD_CF UDETTRS_CF not null,
      CFQUARTER_CF date,
      CUR_CF UCUR_CF not null,
      AMT1_M UAMT_M not null,
      TYPO_CF char(30) not null,
      COMMENT_LL varchar(64) null,
      ADJTYP_CF char(20) not null,
      CRE_D UUPD_D not null,
      CREUSR_CF UUPDUSR_CF not null,
      UPL_B bit  default 1 not null
  )
  
  IF OBJECT_ID('#backupTCASHFLOWADJ') IS NOT NULL
    PRINT '<<< CREATED TEMP TABLE #backupTCASHFLOWADJ >>>'
  ELSE
    PRINT '<<< FAILED CREATING TEMP TABLE #backupTCASHFLOWADJ >>>'

  INSERT INTO #backupTCASHFLOWADJ
  SELECT * FROM TCASHFLOWADJ
  
  DROP TABLE TCASHFLOWADJ
  
  IF OBJECT_ID('TCASHFLOWADJ') IS NOT NULL
      PRINT '<<< FAILED DROPPING TABLE TCASHFLOWADJ >>>'
  ELSE
      PRINT '<<< DROPPED TABLE TCASHFLOWADJ >>>'
END
go
CREATE TABLE TCASHFLOWADJ (
  TRN_NT numeric(10,0) not null,
  CLODAT_D datetime, -- Change for Spira defect 69171
  SSD_CF USSD_CF not null,
  ESB_CF UESB_CF not null,
  CTR_NF UCTR_NF not null,
  SEC_NF USEC_NF not null,
  UWY_NF UUWY_NF not null,
  ACY_NF smallint not null,
  TRNCOD_CF UDETTRS_CF not null,
  CFQUARTER_CF date,
  CUR_CF UCUR_CF not null,
  AMT1_M UAMT_M not null,
  TYPO_CF char(30) not null,
  COMMENT_LL varchar(64) null,
  ADJTYP_CF char(20) not null,
  CRE_D UUPD_D not null,
  CREUSR_CF UUPDUSR_CF not null,
  UPL_B bit  default 1 not null
)

LOCK DATAROWS
go
IF OBJECT_ID('TCASHFLOWADJ') IS NOT NULL
    PRINT '<<< CREATED TABLE TCASHFLOWADJ >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TCASHFLOWADJ >>>'
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TCASHFLOWADJ') AND name='ITCASHFLOW_00')
BEGIN
    DROP INDEX TCASHFLOWADJ.ITCASHFLOW_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TCASHFLOWADJ') AND name='ITCASHFLOW_00')
        PRINT '<<< FAILED DROPPING INDEX TCASHFLOWADJ.ITCASHFLOW_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX TCASHFLOWADJ.ITCASHFLOW_00 >>>'
END
go
CREATE NONCLUSTERED INDEX ITCASHFLOW_00 
    ON TCASHFLOWADJ (CLODAT_D, SSD_CF, ESB_CF, CTR_NF, UWY_NF, ACY_NF, TRNCOD_CF, CFQUARTER_CF, ADJTYP_CF, CREUSR_CF)
go
IF OBJECT_ID('#backupTCASHFLOWADJ') IS NOT NULL 
BEGIN
    INSERT INTO TCASHFLOWADJ
    SELECT * FROM #backupTCASHFLOWADJ

    DROP TABLE #backupTCASHFLOWADJ
END
go
GRANT ALL ON TCASHFLOWADJ TO GOMEGA
go
GRANT ALL ON TCASHFLOWADJ TO GDBBATCH
go
GRANT SELECT ON TCASHFLOWADJ TO GCONSULT
go
