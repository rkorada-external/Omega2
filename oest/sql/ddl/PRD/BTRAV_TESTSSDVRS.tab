--IF OBJECT_ID(user_name()+'.TESTSSDVRS') IS NOT NULL
IF OBJECT_ID('TESTSSDVRS') IS NOT NULL
BEGIN
    DROP TABLE TESTSSDVRS
--    IF OBJECT_ID(user_name()+'.TESTSSDVRS') IS NOT NULL
    IF OBJECT_ID('TESTSSDVRS') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTSSDVRS >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTSSDVRS >>>'
END
go
--23/10/2013 Florent  :spot:25427 - user géographique
CREATE TABLE TESTSSDVRS
(
    SSD_CF    USSD_CF       NULL,
    SEGTYP_CT char(1)       NULL,
    VRS_NF    numeric(10,0) NULL
)
LOCK DATAROWS
go
--IF OBJECT_ID(user_name()+'.TESTSSDVRS') IS NOT NULL
IF OBJECT_ID('TESTSSDVRS') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTSSDVRS >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTSSDVRS >>>'
go
GRANT SELECT ON TESTSSDVRS TO GCONSULT
go
GRANT ALL ON TESTSSDVRS TO GOMEGA
go
GRANT ALL ON TESTSSDVRS TO GDBBATCH
