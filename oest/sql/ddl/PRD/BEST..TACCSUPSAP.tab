USE BEST
go

IF OBJECT_ID('TACCSUPSAP') IS NOT NULL
BEGIN
    DROP TABLE TACCSUPSAP
    IF OBJECT_ID('TACCSUPSAP') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TACCSUPSAP >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TACCSUPSAP >>>'
END
go


CREATE TABLE TACCSUPSAP
(
  TRN_NT       numeric(10,0) NOT NULL,
  PARM1        varchar(25)   NULL,
  PARM2        varchar(25)   NULL,
  PARM3        varchar(25)   NULL,
  CTR_NF       UCTR_NF       NULL,
  SEC_NF       USEC_NF       NULL,
  UWY_NF       UUWY_NF       NULL,
	POSTING_D    UUPD_D DEFAULT getdate() NOT NULL,
  SENDED_B     bit          DEFAULT 0 NOT NULL
)
go

IF OBJECT_ID('TACCSUPSAP') IS NOT NULL
    PRINT '<<< CREATED TABLE TACCSUPSAP >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TACCSUPSAP >>>'
go
GRANT SELECT ON TACCSUPSAP TO GCONSULT
go
GRANT ALL ON TACCSUPSAP TO GOMEGA
go
GRANT ALL ON TACCSUPSAP TO GDBBATCH
go
