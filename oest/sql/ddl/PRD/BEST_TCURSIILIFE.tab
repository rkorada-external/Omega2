CREATE TABLE dbo.TCURSIILIFE
(
    CUR_CF       UCUR_CF    NOT NULL,
    GRPCUR_CF    UCUR_CF    NOT NULL,
    CRE_D        datetime   DEFAULT getdate() NOT NULL,
    CREUSR_CF    UUPDUSR_CF NOT NULL,
    LSTUPD_D     UUPD_D     NOT NULL,
    LSTUPDUSR_CF UUPDUSR_CF NOT NULL,
    VALEND_D     datetime   NULL,
    CLOSING_D    datetime   NULL
)
LOCK DATAROWS
go

