	LOCIFRSLOB_LL varchar(64)   NULL,
	LOCIFRSSEG_CT USEG_NF    NULL,
	LOCIFRSSEG_LL  UL64       NULL,
	CRE_D DATE NOT NULL
)



go
IF OBJECT_ID('ESEJ2050_TSEGRUNRES') IS NOT NULL
  print '<<< CREATED TABLE ESEJ2050_TSEGRUNRES >>>'
else
  print '<<< FAILED CREATING TABLE  ESEJ2050_TSEGRUNRES >>>'
go


CREATE NONCLUSTERED INDEX I1_ESEJ2050_TSEGRUNRES
    ON ESEJ2050_TSEGRUNRES(SGTTYP_NT, CTRTYP_CT,CTR_NF,UWY_NF,UW_NT,SEC_NF,END_NT)

go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('ESEJ2050_TSEGRUNRES') AND name='I1_ESEJ2050_TSEGRUNRES')
    PRINT '<<< CREATED INDEX ESEJ2050_TSEGRUNRES.I1_ESEJ2050_TSEGRUNRES >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ESEJ2050_TSEGRUNRES.I1_ESEJ2050_TSEGRUNRES >>>'
go

CREATE NONCLUSTERED INDEX I2_ESEJ2050_TSEGRUNRES
    ON ESEJ2050_TSEGRUNRES(SGTTYP_NT, CTRTYP_CT)

go
