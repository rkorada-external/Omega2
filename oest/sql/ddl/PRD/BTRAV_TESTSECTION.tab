USE BTRAV
go
IF OBJECT_ID(user_name()+'.TESTSECTION') IS NOT NULL
BEGIN
    DROP TABLE TESTSECTION
    IF OBJECT_ID(user_name()+'.TESTSECTION') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTSECTION >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTSECTION >>>'
END
go
--23/10/2013 Florent  :spot:25427 - user gťographique
CREATE TABLE TESTSECTION
(
    CTR_NF    char(9)  NULL,
    UWY_NF    smallint NULL,
    UW_NT     tinyint  NULL,
    END_NT    tinyint  NULL,
    SEC_NF    tinyint  NULL,
    ESTCTR_NF char(9)  NULL,
    SEG_NF    char(10) NULL
)
LOCK DATAROWS
go
IF OBJECT_ID(user_name()+'.TESTSECTION') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTSECTION >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTSECTION >>>'
go
GRANT SELECT ON TESTSECTION TO GCONSULT
go
GRANT ALL ON TESTSECTION TO GOMEGA
go
GRANT ALL ON TESTSECTION TO GDBBATCH
go
