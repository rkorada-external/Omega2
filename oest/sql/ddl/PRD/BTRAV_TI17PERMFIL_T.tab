    ACTIONTYP_CT  char(1)       NOT NULL,
    CRE_D         UUPD_D        DEFAULT getdate() NULL,
    CREUSR_CF     UL16          NULL,
    [TIMESTAMP]   timestamp     NOT NULL,
    CONSTRAINT PK_TI17PERMFIL_T
    PRIMARY KEY CLUSTERED (ACTION_D,IDF_CT,PERMFIL_CT,ACTIONTYP_CT,[TIMESTAMP])
)
