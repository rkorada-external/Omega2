USE BTRAV
go
IF OBJECT_ID(user_name()+'.TESTRMD') IS NOT NULL
BEGIN
    DROP TABLE TESTRMD
    IF OBJECT_ID(user_name()+'.TESTRMD') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTRMD >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTRMD >>>'
END
go
--23/10/2013 Florent  :spot:25427 - user gťographique
CREATE TABLE TESTRMD
(
    UWRSPUSR_CF  UUSR_CF     NOT NULL,
    ADMUSR_CF    UUPDUSR_CF  NOT NULL,
    RMDOBJ_LL    UL64        NULL,
    RMDDOM_CT    char(3)     NULL,
    RMDENTLAB_LL UL64        NULL,
    RMDENTIDT_CT varchar(20) NULL,
    CMT_T        UCMT_T      NULL
)
LOCK DATAROWS
go
IF OBJECT_ID(user_name()+'.TESTRMD') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTRMD >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTRMD >>>'
go
GRANT SELECT ON TESTRMD TO GCONSULT
go
GRANT ALL ON TESTRMD TO GOMEGA
go
GRANT ALL ON TESTRMD TO GDBBATCH
go
