USE BEST
go

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TRATTACHEVOL') AND name='IRATTACHEVOL_00')
   DROP INDEX TRATTACHEVOL.IRATTACHEVOL_00
   PRINT '<<< DROPED INDEX dbo.TRATTACHEVOL.IRATTACHEVOL_00 >>>'
go

CREATE UNIQUE CLUSTERED INDEX IRATTACHEVOL_00
    ON dbo.TRATTACHEVOL(SSD_CF,CTR_NF,UWY_NF,UW_NT,SEC_NF,END_NT) LOCAL INDEX
            IRATTACHEVOL_00_339385843,
            IRATTACHEVOL_00_355385900,
            IRATTACHEVOL_00_371385957
go

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TRATTACHEVOL') AND name='IRATTACHEVOL_00')
    PRINT '<<< CREATED INDEX dbo.TRATTACHEVOL.IRATTACHEVOL_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TRATTACHEVOL.IRATTACHEVOL_00 >>>'
go
