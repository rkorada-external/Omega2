USE BTRAV
go
IF OBJECT_ID(user_name()+'.TESTCPLAMT') IS NOT NULL
BEGIN
    DROP TABLE TESTCPLAMT
    IF OBJECT_ID(user_name()+'.TESTCPLAMT') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTCPLAMT >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTCPLAMT >>>'
END
go
--23/10/2013 Florent  :spot:25427 - user gťographique
CREATE TABLE TESTCPLAMT
(
    CTR_NF       UCTR_NF  NOT NULL,
    UWY_NF       UUWY_NF  NOT NULL,
    UW_NT        UUW_NT   NOT NULL,
    END_NT       UEND_NT  NOT NULL,
    SEC_NF       USEC_NF  NOT NULL,
    PRMCPLACC_M  UAMT_M   DEFAULT 0 NOT NULL,
    UPRCPLACC_M  UAMT_M   DEFAULT 0 NOT NULL,
    CLMCPLACC_M  UAMT_M   DEFAULT 0 NOT NULL,
    ACRCPLACC_M  UAMT_M   DEFAULT 0 NOT NULL,
    CHACPLACC_M  UAMT_M   DEFAULT 0 NOT NULL,
    RESCPLACC_M  UAMT_M   DEFAULT 0 NOT NULL,
    ACCPRM_M     UAMT_M   DEFAULT 0 NOT NULL,
    ACCUPR_M     UAMT_M   DEFAULT 0 NOT NULL,
    ACCCLM_M     UAMT_M   DEFAULT 0 NOT NULL,
    ACCACR_M     UAMT_M   DEFAULT 0 NOT NULL,
    ACCCHA_M     UAMT_M   DEFAULT 0 NOT NULL,
    ACY_NF       smallint DEFAULT 0 NOT NULL,
    SCOENDMTH_NF tinyint  NULL
)
LOCK DATAROWS
go
IF OBJECT_ID(user_name()+'.TESTCPLAMT') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTCPLAMT >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTCPLAMT >>>'
go
GRANT SELECT ON TESTCPLAMT TO GCONSULT
go
GRANT ALL ON TESTCPLAMT TO GOMEGA
go
GRANT ALL ON TESTCPLAMT TO GDBBATCH
