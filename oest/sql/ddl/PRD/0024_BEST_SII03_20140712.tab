USE BTRAV
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TSIILEDGER') AND name='ITSIILEDGER_00')
BEGIN
    DROP INDEX TSIILEDGER.ITSIILEDGER_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TSIILEDGER') AND name='ITSIILEDGER_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TSIILEDGER.ITSIILEDGER_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TSIILEDGER.ITSIILEDGER_00 >>>'
END
go
CREATE CLUSTERED INDEX ITSIILEDGER_00
    ON dbo.TSIILEDGER(SSD_CF,ESB_CF,CNTR_NT,USR_CF)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TSIILEDGER') AND name='ITSIILEDGER_00')
    PRINT '<<< CREATED INDEX dbo.TSIILEDGER.ITSIILEDGER_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TSIILEDGER.ITSIILEDGER_00 >>>'
go
