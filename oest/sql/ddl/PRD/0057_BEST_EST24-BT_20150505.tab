USE BEST
go
CREATE TABLE dbo.TIOTYPE
(
    CTR_NF       char(9)  NOT NULL,
    END_NT       tinyint  NOT NULL,
    SEC_NF       tinyint  NOT NULL,
    UWY_NF       smallint NOT NULL,
    UW_NT        tinyint  NOT NULL,
    CRE_D        datetime NOT NULL,
    CREUSR_CF    char(4)  NOT NULL,
    LSTUPD_D     datetime NOT NULL,
    LSTUPDUSR_CF char(4)  NOT NULL,
    CONSTRAINT PK_TIOTYPE
    PRIMARY KEY CLUSTERED (CTR_NF,END_NT,SEC_NF,UWY_NF,UW_NT)
)
LOCK ALLPAGES
go
IF OBJECT_ID('dbo.TIOTYPE') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TIOTYPE >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TIOTYPE >>>'
go

