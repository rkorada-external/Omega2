go
GRANT UPDATE ON TUOASII TO GDBBATCH
go
GRANT DELETE STATISTICS ON TUOASII TO GOMEGA
go
GRANT DELETE STATISTICS ON TUOASII TO GDBBATCH
go
GRANT TRUNCATE TABLE ON TUOASII TO GOMEGA
go
GRANT TRUNCATE TABLE ON TUOASII TO GDBBATCH
go
