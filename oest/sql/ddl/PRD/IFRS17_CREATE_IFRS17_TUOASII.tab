USE BEST
go

IF OBJECT_ID('TUOASII') IS NOT NULL
BEGIN
    DROP TABLE TUOASII
    IF OBJECT_ID('TUOASII') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TUOASII >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TUOASII >>>'
END
go

CREATE TABLE TUOASII
(
    SSD_CF         USSD_CF           NOT NULL,
	ESB_CF         UESB_CF           NOT NULL,
	SGMT_NF			USGMT_NF 			NOT NULL,
	SGT_NT		 USGT_NT           NOT NULL,
	SGTVER_NT			USGTVER_NT				NOT NULL,
	NORMCOD_CF			char(5)  		NOT NULL,
	THRESHOLD_M			USHA_R     NULL,
	FCLODAT_D			datetime          NULL,
    CRE_D   	   datetime          NULL,
    CREUSR_CF      UUPDUSR_CF       	 NULL,
    LSTUPDUSR_CF   UUPDUSR_CF       	 NULL,
	LSTUPD_D       datetime       	 NULL,
    TIMESTAMP      timestamp         NULL
)

go
IF OBJECT_ID('TUOASII') IS NOT NULL
    PRINT '<<< CREATED TABLE TUOASII >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TUOASII >>>'
go

CREATE UNIQUE CLUSTERED INDEX TUOASII
    ON TUOASII(SSD_CF,ESB_CF,SGMT_NF,SGT_NT, SGTVER_NT,NORMCOD_CF,FCLODAT_D)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TUOASII') AND name='TUOASII')
    PRINT '<<< CREATED INDEX ON TUOASII >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ON TUOASII >>>'
go

GRANT REFERENCES ON TUOASII TO GOMEGA
go
GRANT REFERENCES ON TUOASII TO GDBBATCH
go
GRANT SELECT ON TUOASII TO GCONSULT
go
GRANT SELECT ON TUOASII TO GOMEGA
go
GRANT SELECT ON TUOASII TO GDBBATCH
go
