USE BEST
go 

IF OBJECT_ID('dbo.TGAPLISTDIFF') IS NOT NULL
BEGIN
    DROP TABLE dbo.TGAPLISTDIFF
    IF OBJECT_ID('dbo.TGAPLISTDIFF') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE dbo.TGAPLISTDIFF >>>'
    ELSE
       PRINT '<<< TABLE DROPPED dbo.TGAPLISTDIFF >>>'
END

go

CREATE TABLE dbo.TGAPLISTDIFF
(
    SSD_CF       	USSD_CF  NOT NULL,
    ESB_CF       	UESB_CF  NOT NULL,
    UWGRP_CF       	UGRP_CF NOT NULL,
	USR_CF			UUSR_CF	 NOT NULL,
	CRE_D			 UUPD_D		NULL,
	CREUSR_CF		UUPDUSR_CF			NULL,
	LSTUPDUSR_CF	UUPDUSR_CF			NULL,
	LSTUPD_D		UUPD_D   		NULL,
	TIMESTAMP		timestamp		NULL,
    CONSTRAINT PK_TGAPLISTDIFF_00
    PRIMARY KEY CLUSTERED (SSD_CF,ESB_CF,UWGRP_CF,USR_CF)
)
LOCK ALLPAGES
go
IF OBJECT_ID('dbo.TGAPLISTDIFF') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TGAPLISTDIFF >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TGAPLISTDIFF >>>'
go

