USE BEST
go

IF OBJECT_ID('TIDLIFEST_DETAIL') IS NOT NULL
BEGIN
    DROP TABLE TIDLIFEST_DETAIL
    IF OBJECT_ID('TIDLIFEST_DETAIL') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TIDLIFEST_DETAIL >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TIDLIFEST_DETAIL >>>'
END
go

CREATE TABLE TIDLIFEST_DETAIL
(
    ID_CF          int           NOT NULL,
    SSD_CF         USSD_CF       NOT NULL,
    ESB_CF         UESB_CF       NOT NULL,
    LSTUPDUSR_CF   UUSR_CF       NOT NULL,
	PERIOD_NT      tinyint       NOT NULL,
    CTR_NF         UCTR_NF       NOT NULL,
    SEC_NF         USEC_NF       NOT NULL,
	UWY_NF         UUWY_NF       NOT NULL,
    ACY_NF         UACCYER_NF    NOT NULL,
	DETTRNCOD_CF   char(5)       NOT NULL,
    CUR_CF         UCUR_CF       NOT NULL,
    PREVIFRSAMT_M  decimal(18,3) NOT NULL,
    IFRSAMT_M      decimal(18,3) NOT NULL,
    PLNIFRSAMT_M   decimal(18,3) NOT NULL,
    PREVPRNTAMT_M  decimal(18,3) NOT NULL,
    PRNTAMT_M      decimal(18,3) NOT NULL,
    PLNPRNTAMT_M   decimal(18,3) NOT NULL,
    PREVLOCALAMT_M decimal(18,3) NOT NULL,
    LOCALAMT_M     decimal(18,3) NOT NULL,
    PLNLOCALAMT_M  decimal(18,3) NOT NULL
  
)
LOCK ALLPAGES
go
IF OBJECT_ID('TIDLIFEST_DETAIL') IS NOT NULL
    PRINT '<<< CREATED TABLE TIDLIFEST_DETAIL >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TIDLIFEST_DETAIL >>>'
go

CREATE UNIQUE CLUSTERED INDEX TIDLIFEST_DETAIL
    ON TIDLIFEST_DETAIL(ID_CF, SSD_CF, ESB_CF, CTR_NF, SEC_NF, ACY_NF, DETTRNCOD_CF, LSTUPDUSR_CF, UWY_NF)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TIDLIFEST_DETAIL') AND name='TIDLIFEST_DETAIL')
    PRINT '<<< CREATED INDEX ON TIDLIFEST_DETAIL >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ON TIDLIFEST_DETAIL >>>'
go

GRANT REFERENCES ON TIDLIFEST_DETAIL TO GOMEGA
go
GRANT REFERENCES ON TIDLIFEST_DETAIL TO GDBBATCH
go
