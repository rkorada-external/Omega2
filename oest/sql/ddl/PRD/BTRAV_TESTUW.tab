USE BTRAV
go
IF OBJECT_ID(user_name()+'.TESTUW') IS NOT NULL
BEGIN
    DROP TABLE TESTUW
    IF OBJECT_ID(user_name()+'.TESTUW') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTUW >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTUW >>>'
END
go
--23/10/2013 Florent  :spot:25427 - user gÈographique
CREATE TABLE TESTUW
(
    CTR_NF       UCTR_NF   NOT NULL,
    UWY_NF       UUWY_NF   NOT NULL,
    UW_NT        UUW_NT    NOT NULL,
    END_NT       UEND_NT   NOT NULL,
    SEC_NF       USEC_NF   NOT NULL,
    CTRNAT_CT    char(1)   NOT NULL,
    SCOGLOEGP_M  UAMT_M    DEFAULT 0 NOT NULL,
    TOTCLM_M     UAMT_M    DEFAULT 0 NOT NULL,
    SCOEGPCAL_B  bit       DEFAULT 0 NOT NULL,
    ADMMODCTR_CT char(1)   NOT NULL,
    ESTEND_B     bit       DEFAULT 0 NOT NULL,
    ESTUPDTYP_CT char(1)   NOT NULL,
    PMLRAT_R     USHORAT_R NULL
)
LOCK DATAROWS
go
IF OBJECT_ID(user_name()+'.TESTUW') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTUW >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTUW >>>'
go
GRANT SELECT ON TESTUW TO GCONSULT
go
GRANT ALL ON TESTUW TO GOMEGA
go
GRANT ALL ON TESTUW TO GDBBATCH
go
