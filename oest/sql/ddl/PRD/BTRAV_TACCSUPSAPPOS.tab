USE BTRAV
go

IF OBJECT_ID('TACCSUPSAPPOS') IS NOT NULL
BEGIN
    DROP TABLE TACCSUPSAPPOS
    IF OBJECT_ID('TACCSUPSAPPOS') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TACCSUTACCSUPSAPPOSPSAPSENT >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TACCSUPSAPPOS >>>'
END
go


CREATE TABLE TACCSUPSAPPOS
(
	TRN_NT 	        numeric(10,0) NOT NULL,
	POSTING_D       UUPD_D DEFAULT getdate() NOT NULL
)
go

IF OBJECT_ID('TACCSUPSAPPOS') IS NOT NULL
    PRINT '<<< CREATED TABLE TACCSUPSAPPOS >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TACCSUPSAPPOS >>>'
go
GRANT SELECT ON TACCSUPSAPPOS TO GCONSULT
go
GRANT ALL ON TACCSUPSAPPOS TO GOMEGA
go
GRANT ALL ON TACCSUPSAPPOS TO GDBBATCH
go
