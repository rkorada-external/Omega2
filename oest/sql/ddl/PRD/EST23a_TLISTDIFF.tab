USE BEST
go

IF OBJECT_ID('TLISTDIFF') IS NOT NULL
BEGIN
    DROP TABLE TLISTDIFF
    IF OBJECT_ID('TLISTDIFF') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TLISTDIFF >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TLISTDIFF >>>'
END
go

CREATE TABLE TLISTDIFF
(
    SSD_CF         USSD_CF           NOT NULL,
	ESB_CF         UESB_CF           NOT NULL,
    UWGRP_CF       UGRP_CF       	 NOT NULL,
	USR_CF         UUSR_CF       	 NOT NULL,
    CRE_D   	   datetime          NULL,
    CREUSR_CF      UUPDUSR_CF       	 NULL,
    LSTUPDUSR_CF   UUPDUSR_CF       	 NULL,
	LSTUPD_D       datetime       	 NULL,
    TIMESTAMP      timestamp         NULL
)
LOCK ALLPAGES
go
IF OBJECT_ID('TLISTDIFF') IS NOT NULL
    PRINT '<<< CREATED TABLE TLISTDIFF >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TLISTDIFF >>>'
go

CREATE UNIQUE CLUSTERED INDEX TLISTDIFF
    ON TLISTDIFF(SSD_CF, ESB_CF, UWGRP_CF, USR_CF)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TLISTDIFF') AND name='TLISTDIFF')
    PRINT '<<< CREATED INDEX ON TLISTDIFF >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ON TLISTDIFF >>>'
go

GRANT REFERENCES ON TLISTDIFF TO GOMEGA
go
GRANT REFERENCES ON TLISTDIFF TO GDBBATCH
go
GRANT SELECT ON TLISTDIFF TO GCONSULT
go
GRANT SELECT ON TLISTDIFF TO GOMEGA
go
GRANT SELECT ON TLISTDIFF TO GDBBATCH
go
GRANT INSERT ON TLISTDIFF TO GOMEGA
go
GRANT INSERT ON TLISTDIFF TO GDBBATCH
go
GRANT DELETE ON TLISTDIFF TO GOMEGA
go
GRANT DELETE ON TLISTDIFF TO GDBBATCH
go
GRANT UPDATE ON TLISTDIFF TO GOMEGA
go
GRANT UPDATE ON TLISTDIFF TO GDBBATCH
go
GRANT DELETE STATISTICS ON TLISTDIFF TO GOMEGA
go
GRANT DELETE STATISTICS ON TLISTDIFF TO GDBBATCH
go
GRANT TRUNCATE TABLE ON TLISTDIFF TO GOMEGA
go
GRANT TRUNCATE TABLE ON TLISTDIFF TO GDBBATCH
go
GRANT UPDATE STATISTICS ON TLISTDIFF TO GOMEGA
go
GRANT UPDATE STATISTICS ON TLISTDIFF TO GDBBATCH
go
GRANT TRANSFER TABLE ON TLISTDIFF TO GOMEGA
go
GRANT TRANSFER TABLE ON TLISTDIFF TO GDBBATCH
go
