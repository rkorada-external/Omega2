USE BTRAV
go

-- :spira:86536

IF OBJECT_ID('EST_ESPD8000_TCTREST') IS NOT NULL
BEGIN
    DROP TABLE EST_ESPD8000_TCTREST
    IF OBJECT_ID('EST_ESPD8000_TCTREST') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE EST_ESPD8000_TCTREST >>>'
    ELSE
        PRINT '<<< DROPPED TABLE EST_ESPD8000_TCTREST >>>'
END
go
CREATE TABLE EST_ESPD8000_TCTREST
(
    CTR_NF       UCTR_NF    NOT NULL,
    END_NT       UEND_NT    NOT NULL,
    SEC_NF       USEC_NF    NOT NULL,
    UWY_NF       UUWY_NF    NOT NULL,
    UW_NT        UUW_NT     NOT NULL,
    CRE_D        UUPD_D     DEFAULT getdate() NOT NULL,
    PRS_CF       smallint   NOT NULL,
    ACMTRS_NT    smallint   NOT NULL,
    SSD_CF       USSD_CF    NULL,
    DIV_NT       UDIV_NT    NOT NULL,
    CUR_CF       UCUR_CF    DEFAULT ''        NOT NULL,
    CALAMT_M     UAMT_M     NULL,
    ENTAMT_M     UAMT_M     NULL,
    RETAMT_M     UAMT_M     NULL,
    ADMMOD_CT    char(1)    DEFAULT ''        NOT NULL,
    CLODAT_D     datetime   NULL,
    ORICOD_LS    UL16       NULL,
    UPDUSR_CF    char(10)   DEFAULT ''        NOT NULL,
    CREUSR_CF    UUPDUSR_CF DEFAULT user      NOT NULL,
    LSTUPD_D     UUPD_D     DEFAULT getdate() NOT NULL,
    LSTUPDUSR_CF UUPDUSR_CF DEFAULT user      NOT NULL,
    CMT_NT       UCMT_NT    NULL,
    INCURREDCI_M UAMT_M     NULL
)
go
IF OBJECT_ID('EST_ESPD8000_TCTREST') IS NOT NULL
    PRINT '<<< CREATED TABLE EST_ESPD8000_TCTREST >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE EST_ESPD8000_TCTREST >>>'
go
GRANT ALL ON EST_ESPD8000_TCTREST TO GOMEGA
go
GRANT ALL ON EST_ESPD8000_TCTREST TO GDBBATCH
go
GRANT ALL ON EST_ESPD8000_TCTREST TO GCONSULT
go
