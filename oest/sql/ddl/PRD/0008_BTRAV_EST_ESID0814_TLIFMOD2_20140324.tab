    PRIPRMAMT_M    UAMT_M     NOT NULL,
    AFTPRMAMT_M    UAMT_M     NOT NULL,
    PRIRESTECAMT_M UAMT_M     NOT NULL,
    AFTRESTECAMT_M UAMT_M     NOT NULL,
