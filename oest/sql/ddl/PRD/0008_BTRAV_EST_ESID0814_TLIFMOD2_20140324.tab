go
grant all on    EST_ESID0814_TLIFMOD2 to GOMEGA
grant all on    EST_ESID0814_TLIFMOD2 to GDBBATCH
grant select on EST_ESID0814_TLIFMOD2 to GCONSULT
go

IF OBJECT_ID('BTRAV.dbo.EST_ESID0814_TLIFMOD2') IS NOT NULL
