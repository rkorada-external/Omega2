USE BTRAV
go


if exists (select * from sysobjects where id = object_id('EST_ESID0814_TLIFMOD2') and type = 'U') drop table EST_ESID0814_TLIFMOD2
go 

CREATE TABLE EST_ESID0814_TLIFMOD2
(
    CTR_NF         UCTR_NF    NOT NULL,
    SEC_NF         USEC_NF    NOT NULL,
    CRE_D          datetime   NOT NULL,
    BALSHEY_NF     smallint   NOT NULL,
