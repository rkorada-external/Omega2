USE BEST
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFESTD') AND name='ILIFESTD_00')
BEGIN
    DROP INDEX TLIFESTD.ILIFESTD_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFESTD') AND name='ILIFESTD_00')
        PRINT '<<< FAILED DROPPING INDEX dbo.TLIFESTD.ILIFESTD_00 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX dbo.TLIFESTD.ILIFESTD_00 >>>'
END
go
CREATE UNIQUE CLUSTERED INDEX ILIFESTD_00
    ON dbo.TLIFESTD(CTR_NF,END_NT,SEC_NF,UWY_NF,UW_NT,BALSHEY_NF,BALSHTMTH_NF,ACY_NF,PRS_CF,ACMTRS_NT,GAAP_NT,DETTRNCOD_CF,CRE_D, SSD_CF,ACM_NF)
LOCAL INDEX ILIFEST_00_2109247538
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TLIFESTD') AND name='ILIFESTD_00')
    PRINT '<<< CREATED INDEX dbo.TLIFESTD.ILIFESTD_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TLIFESTD.ILIFESTD_00 >>>'
go
