go
GRANT UPDATE ON TIDLIFEST_GLOBAL TO GDBBATCH
go
GRANT DELETE STATISTICS ON TIDLIFEST_GLOBAL TO GOMEGA
go
GRANT DELETE STATISTICS ON TIDLIFEST_GLOBAL TO GDBBATCH
go
