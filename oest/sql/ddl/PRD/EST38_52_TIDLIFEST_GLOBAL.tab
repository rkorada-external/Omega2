USE BEST
go

IF OBJECT_ID('TIDLIFEST_GLOBAL') IS NOT NULL
BEGIN
    DROP TABLE TIDLIFEST_GLOBAL
    IF OBJECT_ID('TIDLIFEST_GLOBAL') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TIDLIFEST_GLOBAL >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TIDLIFEST_GLOBAL >>>'
END
go

CREATE TABLE TIDLIFEST_GLOBAL
(
    ID_CF              int           NOT NULL,
    UPDTYP_CT          bit           NOT NULL,
    SSD_CF             USSD_CF       NOT NULL,
    ESB_CF             UESB_CF       NOT NULL,
    LSTUPDUSR_CF       UUSR_CF       NOT NULL,
    GAAP_NT            tinyint       NOT NULL,
    PERIOD_NT          tinyint       NOT NULL,
	ACY_NF             UACCYER_NF    NOT NULL,
	CUR_CF             UCUR_CF       NULL,
    PRIPRMAMT_M        decimal(18,3) NOT NULL,
    CURPRMAMT_M        decimal(18,3) NOT NULL,
    DIFFPRMAMT_M       decimal(18,3) NOT NULL,
    PLNPRMAMT_M        decimal(18,3) NOT NULL,
    PRIRESTECAMT_M     decimal(18,3) NOT NULL,
    CURRESTECAMT_M     decimal(18,3) NOT NULL,
    DIFFRESTECAMT_M    decimal(18,3) NOT NULL,
    PLNRESTECAMT_M     decimal(18,3) NOT NULL,
    PRIRESDACAMT_M     decimal(18,3) NOT NULL,
    CURRESDACAMT_M     decimal(18,3) NOT NULL,
    DIFFRESDACAMT_M    decimal(18,3) NOT NULL,
    PLNRESDACAMT_M     decimal(18,3) NOT NULL,
    EXC_D              datetime      NOT NULL,
    STATREP_D          datetime      NOT NULL,
    END_D              datetime      NOT NULL
)
LOCK ALLPAGES
go

IF OBJECT_ID('TIDLIFEST_GLOBAL') IS NOT NULL
    PRINT '<<< CREATED TABLE TIDLIFEST_GLOBAL >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TIDLIFEST_GLOBAL >>>'
go

CREATE UNIQUE CLUSTERED INDEX TIDLIFEST_GLOBAL
    ON TIDLIFEST_GLOBAL(ID_CF, SSD_CF, ESB_CF, LSTUPDUSR_CF, GAAP_NT, ACY_NF, END_D)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TIDLIFEST_GLOBAL') AND name='TIDLIFEST_GLOBAL')
    PRINT '<<< CREATED INDEX ON TIDLIFEST_GLOBAL >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ON TIDLIFEST_GLOBAL >>>'
go

GRANT REFERENCES ON TIDLIFEST_GLOBAL TO GOMEGA
go
GRANT REFERENCES ON TIDLIFEST_GLOBAL TO GDBBATCH
go
GRANT SELECT ON TIDLIFEST_GLOBAL TO GCONSULT
go
GRANT SELECT ON TIDLIFEST_GLOBAL TO GOMEGA
go
GRANT SELECT ON TIDLIFEST_GLOBAL TO GDBBATCH
go
