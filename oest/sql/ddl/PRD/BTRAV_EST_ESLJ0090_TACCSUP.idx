USE BTRAV
go

-- 12/07/2022 D. TEIXEIRA Spira 105586 Creation index EST_ESLJ0090_TACCSUP

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('EST_ESLJ0090_TACCSUP') AND name='EST_ESLJ0090_TACCSUP_00')
BEGIN
    DROP INDEX EST_ESLJ0090_TACCSUP.EST_ESLJ0090_TACCSUP_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('EST_ESLJ0090_TACCSUP') AND name='EST_ESLJ0090_TACCSUP_00')
        PRINT '<<< FAILED DROPPING INDEX EST_ESLJ0090_TACCSUP.EST_ESLJ0090_TACCSUP_0 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX EST_ESLJ0090_TACCSUP.EST_ESLJ0090_TACCSUP_0 >>>'
END
go
CREATE CLUSTERED INDEX EST_ESLJ0090_TACCSUP_00
    ON EST_ESLJ0090_TACCSUP(TRN_NT)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('EST_ESLJ0090_TACCSUP') AND name='EST_ESLJ0090_TACCSUP_00')
    PRINT '<<< CREATED INDEX EST_ESLJ0090_TACCSUP_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX EST_ESLJ0090_TACCSUP_00 >>>'
go