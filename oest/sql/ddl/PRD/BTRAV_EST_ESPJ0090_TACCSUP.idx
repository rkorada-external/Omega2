USE BTRAV
go

-- 01/10/2019 R. Cassis :spira:81553 Creation index pour optimisation

IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('EST_ESPJ0090_TACCSUP') AND name='EST_ESPJ0090_TACCSUP_00')
BEGIN
    DROP INDEX EST_ESPJ0090_TACCSUP.EST_ESPJ0090_TACCSUP_00
    IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('EST_ESPJ0090_TACCSUP') AND name='EST_ESPJ0090_TACCSUP_00')
        PRINT '<<< FAILED DROPPING INDEX EST_ESPJ0090_TACCSUP.EST_ESPJ0090_TACCSUP_0 >>>'
    ELSE
        PRINT '<<< DROPPED INDEX EST_ESPJ0090_TACCSUP.EST_ESPJ0090_TACCSUP_0 >>>'
END
go
CREATE CLUSTERED INDEX EST_ESPJ0090_TACCSUP_00
    ON EST_ESPJ0090_TACCSUP(TRN_NT)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('EST_ESPJ0090_TACCSUP') AND name='EST_ESPJ0090_TACCSUP_00')
    PRINT '<<< CREATED INDEX EST_ESPJ0090_TACCSUP_00 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX EST_ESPJ0090_TACCSUP_00 >>>'
go
