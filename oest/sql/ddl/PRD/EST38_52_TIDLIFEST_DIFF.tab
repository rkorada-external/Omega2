USE BEST
go 

IF OBJECT_ID('TIDLIFEST_DIFF') IS NOT NULL
BEGIN
    DROP TABLE TIDLIFEST_DIFF
    IF OBJECT_ID('TIDLIFEST_DIFF') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TIDLIFEST_DIFF >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TIDLIFEST_DIFF >>>'
END

go

CREATE TABLE TIDLIFEST_DIFF
(
    SSD_CF       	USSD_CF  	NOT NULL,
    ESB_CF       	UESB_CF  	NOT NULL,
    UWGRP_CF       	UGRP_CF  	NOT NULL,
	USR_CF			UUSR_CF	 	NOT NULL,
	CRE_D			UUPD_D		NULL,
	CREUSR_CF		UUPDUSR_CF	NULL,
	LSTUPDUSR_CF	UUPDUSR_CF	NULL,
	LSTUPD_D		UUPD_D   	NULL,
	TIMESTAMP		timestamp	NULL,
    CONSTRAINT PK_TIDLIFEST_DIFF_00
    PRIMARY KEY CLUSTERED (SSD_CF,ESB_CF,UWGRP_CF,USR_CF)
)
LOCK ALLPAGES
go
IF OBJECT_ID('TIDLIFEST_DIFF') IS NOT NULL
    PRINT '<<< CREATED TABLE TIDLIFEST_DIFF >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TIDLIFEST_DIFF >>>'
go

