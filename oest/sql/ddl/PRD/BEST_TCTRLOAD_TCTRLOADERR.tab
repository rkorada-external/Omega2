--Start of BEST..TCRLOADERR

IF OBJECT_ID('TCTRLOADERR') IS NOT NULL
BEGIN
    DROP TABLE TCTRLOADERR
    IF OBJECT_ID('TCTRLOADERR') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TCTRLOADERR >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TCTRLOADERR >>>'
END
go

/*==============================================================*/
/* Table: TCTRLOADERR                                           */
/*==============================================================*/
create table TCTRLOADERR 
(
   UPLID_NT             UUWENTNBR_NT                 not null,
   ERRROW_NF            int                          not null,
   MESS_N               int                          null,
   ERRTYP_CT            UBANVAL_CT                   null,
   MESSTHM_C            UMESSTHM_C                   null,
   ERRCOL_LM            varchar(32)                  not null,
   CREUSR_CF            UUPDUSR_CF                   not null,
   CRE_D                UUPD_D                       not null,
   LSTUPDUSR_CF         UUPDUSR_CF                   not null,
   LSTUPD_D             UUPD_D                       not null,
   TIMESTAMP            timestamp                    not null,
   
    foreign key (UPLID_NT) REFERENCES TCTRLOAD(UPLID_NT)
)

go
IF OBJECT_ID('TCTRLOADERR') IS NOT NULL
    PRINT '<<< CREATED TABLE TCTRLOADERR >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TCTRLOADERR >>>'
go

CREATE UNIQUE CLUSTERED INDEX ICTRLOADERR_00
    ON TCTRLOADERR(UPLID_NT,ERRROW_NF,ERRCOL_LM)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TCTRLOADERR') AND name='ICTRLOADERR_00')
    PRINT '<<< CREATED INDEX ON TCTRLOADERR >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ON TCTRLOADERR >>>'
go



