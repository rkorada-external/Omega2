--Start of BEST..TCRLOAD

IF OBJECT_ID('TCTRLOAD') IS NOT NULL
BEGIN
    DROP TABLE TCTRLOAD
    IF OBJECT_ID('TCTRLOAD') IS NOT NULL
       PRINT '<<<  FAILED DROPPING TABLE TCTRLOAD >>>'
    ELSE
       PRINT '<<< TABLE DROPPED TCTRLOAD >>>'
END
go

/*==============================================================*/
/* Table: TCTRLOAD                                              */
/*==============================================================*/
create table TCTRLOAD 
(
   UPLID_NT             UUWENTNBR_NT                   not null primary key,
   UPLFILNAM_LL         varchar (128)                  null,
   UPLSTS_CT            UBANVAL_CT                     null,
   CTRUPLTYP_CT         UCTRTYP_CT                     null,
   CTRUPLFAM_CT         tinyint                        null,
   ORIFILNAM_LL         varchar(64)                    null,
   NBLGTOT_NT           int default 0                  null,
   NBLGKO_NT            int                            null,
   NBANO_NT             int                            null,
   CREUSR_CF            UUPDUSR_CF                     not null,
   CRE_D                UUPD_D                         not null,
   LSTUPDUSR_CF         UUPDUSR_CF                     not null,
   LSTUPD_D             UUPD_D                         not null,
   TIMESTAMP            timestamp                      not null
)
go


/*==============================================================*/
/* Index: ICTRLOAD_00                                           */
/*==============================================================*/

CREATE INDEX ICTRLOAD_00
    ON TCTRLOAD(UPLID_NT,CTRUPLTYP_CT,CTRUPLFAM_CT)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('TCTRLOAD') AND name='ICTRLOAD_00')
    PRINT '<<< CREATED INDEX ON TCTRLOAD >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX ON TCTRLOAD >>>'
go

