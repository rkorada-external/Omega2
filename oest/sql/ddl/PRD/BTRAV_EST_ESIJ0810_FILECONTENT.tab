  PRINT '<<< CREATED TABLE EST_ESIJ0810_FILECONTENT >>>'
ELSE
  PRINT '<<< FAILED CREATING EST_ESIJ0810_FILECONTENT  >>>'
go
GRANT ALL ON EST_ESIJ0810_FILECONTENT TO GOMEGA 
