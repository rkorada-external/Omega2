go
CREATE TABLE EST_ESIJ0810_FILECONTENT
(
	FILENO_NT	int NOT NULL,
	NUMLINE_NT numeric default 0 null,
	CUR_CF varchar(25) null,
	ESTMNT_M numeric(18,3) null,
	SSD_CF numeric not null,
	ESB_CF numeric not null,
	USR_CF varchar(25) not null
) LOCK DATAROWS
go

