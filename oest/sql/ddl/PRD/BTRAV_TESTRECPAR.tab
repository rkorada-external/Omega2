USE BTRAV
go
IF OBJECT_ID(user_name()+'.TESTRECPAR') IS NOT NULL
BEGIN
    DROP TABLE TESTRECPAR
    IF OBJECT_ID(user_name()+'.TESTRECPAR') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTRECPAR >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTRECPAR >>>'
END
go
--23/10/2013 Florent  :spot:25427 - user géographique
CREATE TABLE TESTRECPAR
(
    CTR_NF      UCTR_NF    NOT NULL,
    UWY_NF      UUWY_NF    NOT NULL,
    UW_NT       UUW_NT     NOT NULL,
    END_NT      UEND_NT    NOT NULL,
    SEC_NF      USEC_NF    NOT NULL,
    REILIN_NT   UINTORD_NT NULL,
    REIRNK_NT   tinyint    NULL,
    REIPRMBAS_R USHORAT_R  NULL,
    REIPRM_M    UAMT_M     NULL,
    REIPRM_R    USHORAT_R  NULL,
    REIPROTMP_B bit        DEFAULT 0 NOT NULL
)
LOCK DATAROWS
go
IF OBJECT_ID(user_name()+'.TESTRECPAR') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTRECPAR >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTRECPAR >>>'
go
GRANT SELECT ON TESTRECPAR TO GCONSULT
go
GRANT ALL ON TESTRECPAR TO GOMEGA
go
GRANT ALL ON TESTRECPAR TO GDBBATCH
go
