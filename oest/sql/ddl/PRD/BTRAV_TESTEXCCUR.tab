USE BTRAV
go
IF OBJECT_ID(user_name()+'.TESTEXCCUR') IS NOT NULL
BEGIN
    DROP TABLE TESTEXCCUR
    IF OBJECT_ID(user_name()+'.TESTEXCCUR') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TESTEXCCUR >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TESTEXCCUR >>>'
END
go
--23/10/2013 Florent  :spot:25427 - user géographique
CREATE TABLE TESTEXCCUR
(
    SSD_CF    USSD_CF  NOT NULL,
    CUR_CF    UCUR_CF  NOT NULL,
    EXCYEA_NF smallint NOT NULL,
    EXC_R     ULNGDEC  NOT NULL
)
LOCK DATAROWS
WITH EXP_ROW_SIZE=1
go
IF OBJECT_ID(user_name()+'.TESTEXCCUR') IS NOT NULL
    PRINT '<<< CREATED TABLE TESTEXCCUR >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE TESTEXCCUR >>>'
go
GRANT SELECT ON TESTEXCCUR TO GCONSULT
go
GRANT ALL ON TESTEXCCUR TO GOMEGA
go
GRANT ALL ON TESTEXCCUR TO GDBBATCH
go
