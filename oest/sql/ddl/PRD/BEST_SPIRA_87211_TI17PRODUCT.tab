use BEST
go

IF OBJECT_ID('TI17PRODUCT') IS NOT NULL
BEGIN
    DROP TABLE TI17PRODUCT
    IF OBJECT_ID('TI17PRODUCT') IS NOT NULL
        PRINT '<<< FAILED DROPPING TABLE TI17PRODUCT >>>'
    ELSE
        PRINT '<<< DROPPED TABLE TI17PRODUCT >>>'
END
go


create table dbo.TI17PRODUCT (
   I17PRDCOD_CT         varchar(10)                    not null,
   GRPIFRSSEG_CT        USEG_NF                        null,
   GRPINIPRO_CF         UBANVAL_CT                     null,
   GRPIFRSTRA_CT        UBANVAL_CT                     null,
   PARIFRSSEG_CT        USEG_NF                        null,
   PARINIPRO_CF         UBANVAL_CT                     null,
   PARIFRSTRA_CT        UBANVAL_CT                     null,
   LOCIFRSSEG_CT        USEG_NF                        null,
   LOCINIPRO_CF         UBANVAL_CT                     null,
   LOCIFRSTRA_CT        UBANVAL_CT                     null,
   BCHUSR_CF            UUPDUSR_CF                     not null,
   constraint PK_I17_PRODUCT primary key (I17PRDCOD_CT)
)

go
