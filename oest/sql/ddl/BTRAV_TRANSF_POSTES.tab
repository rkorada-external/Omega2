USE BTRAV
go
/*
 * Drop TABLE TRANSF_POSTES
 */
IF OBJECT_ID('dbo.TRANSF_POSTES') IS NOT NULL
BEGIN
    DROP TABLE dbo.TRANSF_POSTES
    PRINT '<<< DROPPED TABLE dbo.TRANSF_POSTES >>>'
END
go
/*
 * Creating TABLE dbo.TRANSF_POSTES
 */
CREATE TABLE TRANSF_POSTES (
    POSTEFROM      UDETTRS_CF DEFAULT '' NOT NULL,
    POSTETOIN      UDETTRS_CF DEFAULT '' NOT NULL,
    POSTETOCPIN    UDETTRS_CF DEFAULT '' NOT NULL,
    POSTETOOUT     UDETTRS_CF DEFAULT '' NOT NULL,
    POSTETOCPOUT   UDETTRS_CF DEFAULT '' NOT NULL
)
go
IF OBJECT_ID('dbo.TRANSF_POSTES') IS NOT NULL
    PRINT '<<< CREATED TABLE dbo.TRANSF_POSTES >>>'
ELSE
    PRINT '<<< FAILED CREATING TABLE dbo.TRANSF_POSTES >>>'
go
CREATE INDEX TRANSPOSTES_01
    ON dbo.TRANSF_POSTES(POSTEFROM)
go
IF EXISTS (SELECT * FROM sysindexes WHERE id=OBJECT_ID('dbo.TRANSF_POSTES') AND name='TRANSPOSTES_01')
    PRINT '<<< CREATED INDEX dbo.TRANSF_POSTES.TRANSPOSTES_01 >>>'
ELSE
    PRINT '<<< FAILED CREATING INDEX dbo.TRANSF_POSTES.TRANSPOSTES_01 >>>'
go
/*
 * Granting/Revoking Permissions on dbo.TRANSF_POSTES
 */
GRANT REFERENCES ON dbo.TRANSF_POSTES TO GOMEGA
go
GRANT SELECT ON dbo.TRANSF_POSTES TO GCONSULT
go
GRANT SELECT ON dbo.TRANSF_POSTES TO GOMEGA
go
GRANT INSERT ON dbo.TRANSF_POSTES TO GOMEGA
go
GRANT DELETE ON dbo.TRANSF_POSTES TO GOMEGA
go
GRANT UPDATE ON dbo.TRANSF_POSTES TO GOMEGA
go

