					<o:Table Id="o240">
						<a:ObjectID>F853FE12-1270-4D04-84CD-5ECB0A086C3D</a:ObjectID>
						<a:Name>Zoom on EGPI</a:Name>
						<a:Code>TZOOEGPUPD</a:Code>
						<a:CreationDate>860680380</a:CreationDate>
						<a:Creator>OME08</a:Creator>
						<a:ModificationDate>860680380</a:ModificationDate>
						<a:Modifier>OME08</a:Modifier>
						<a:Comment>Zoom on facs</a:Comment>
						<a:TotalSavingCurrency/>
						<a:Annotation>That table serve to support of fac zoom windows, open from windows presenting fac accumulation statistic. It is erased and filled in monthly in edition batch of the activity report and accumulation statistic of facs . Activity datas are linked to the last amendment of each fac, new or modified, treatied fac into TFACACT, and only fac which have the total is superior to minimum threshold describe in TPARAM. Statistic datas are linked to the last amendment of each  fac used in TFACSTA, and only fac which the total is superior to minimum threshold describe in TPARAM. Their volume is estimated to 15000lines for Europe site. </a:Annotation>
						<c:Columns>
							<o:Column Id="o1010">
								<a:ObjectID>E3145424-BA0E-48A5-9F61-66044FE3F44A</a:ObjectID>
								<a:Name>Zoom on facs number</a:Name>
								<a:Code>ZOOFAC_NT</a:Code>
								<a:CreationDate>860680380</a:CreationDate>
								<a:Creator>OME08</a:Creator>
								<a:ModificationDate>860680380</a:ModificationDate>
								<a:Modifier>OME08</a:Modifier>
								<a:Comment>Zoom on facs number</a:Comment>
								<a:DataType>numeric(10)</a:DataType>
								<a:Length>10</a:Length>
								<a:Identity>1</a:Identity>
								<a:Mandatory>1</a:Mandatory>
							</o:Column>
							<o:Column Id="o1011">
								<a:ObjectID>A6C26344-4CA0-4FBC-892A-5C93BECADA6E</a:ObjectID>
								<a:Name>Data type</a:Name>
								<a:Code>DATTYP_CT</a:Code>
								<a:CreationDate>860680380</a:CreationDate>
								<a:Creator>OME08</a:Creator>
								<a:ModificationDate>860680380</a:ModificationDate>
								<a:Modifier>OME08</a:Modifier>
								<a:Comment>Data type</a:Comment>
								<a:DefaultValue>''</a:DefaultValue>
								<a:DataType>char(3)</a:DataType>
								<a:Length>3</a:Length>
								<a:Mandatory>1</a:Mandatory>
								<a:DistinctValues>0</a:DistinctValues>
								<a:Annotation>That column take the value "ACT" when we concentrated on fac activity; or the value " STA" when we concentrated on fac accumulation statistic</a:Annotation>
							</o:Column>
							<o:Column Id="o1012">
