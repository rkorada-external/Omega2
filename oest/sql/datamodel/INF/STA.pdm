								<a:Modifier>OME08</a:Modifier>
								<a:Comment>Zoom on facs number</a:Comment>
								<a:DataType>numeric(10)</a:DataType>
								<a:Length>10</a:Length>
								<a:Identity>1</a:Identity>
								<a:Mandatory>1</a:Mandatory>
