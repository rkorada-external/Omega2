<a:Creator>ADMIN</a:Creator>
<a:ModificationDate>979914457</a:ModificationDate>
<a:Modifier>ADMIN</a:Modifier>
<a:Comment>Table de paramétrage pour orienter les résultats d&#39;inventaire vers les bonnes tables</a:Comment>
<a:DataType>char(3)</a:DataType>
<a:Length>3</a:Length>
<a:Column.Mandatory>1</a:Column.Mandatory>
<a:Description>Domaine utilisant la table :
EST : pour Estimations/Inventaire</a:Description>
</o:Column>
