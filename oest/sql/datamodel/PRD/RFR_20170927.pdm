<a:Creator>FRXB156</a:Creator>
<a:ModificationDate>1326980808</a:ModificationDate>
<a:Modifier>FRIOLVI</a:Modifier>
<a:Comment>Verrouillage pour modifs facs ?</a:Comment>
<a:DefaultValue>0</a:DefaultValue>
<a:DataType>tinyint</a:DataType>
<a:Column.Mandatory>1</a:Column.Mandatory>
<a:DistinctValues>0</a:DistinctValues>
<a:Description>oui indique un vérouillage dans l&#39;appli facs oméga en cas de modification.</a:Description>
<a:Annotation>1 si vérouillage</a:Annotation>
</o:Column>
<o:Column Id="o3656">
