<o:Column Id="o3071">
<a:ObjectID>DBF50332-84CE-4920-8AD0-E46918A93384</a:ObjectID>
<a:Name>Accounting T code</a:Name>
<a:Code>DETTRS_CF</a:Code>
<a:CreationDate>880027320</a:CreationDate>
<a:Creator>OME08</a:Creator>
<a:ModificationDate>1326890919</a:ModificationDate>
<a:Modifier>OME08</a:Modifier>
<a:Comment>Poste comptable</a:Comment>
<a:DefaultValue>&#39;&#39;</a:DefaultValue>
<a:DataType>char(8)</a:DataType>
<a:Length>8</a:Length>
<a:Column.Mandatory>1</a:Column.Mandatory>
<a:DistinctValues>0</a:DistinctValues>
<a:AutoMigrated>1</a:AutoMigrated>
<a:Description>Le poste comptable est en 4 parties :

                  - 1er préfixe (1 caractère, position 1) : 
                            - 1 = Acceptation Non Vie.
                            - 2 = Rétro Non Vie.
                            - 3 = Acceptation Vie.
                            - 4 = Rétro Vie.

                  - 2 eme préfixe (1c, p2) :
                            - 1 = Compte de Résultat.
                            - 2 = Bilan.
                            - 3 = Compte de Résultat OD.
                            - 4 = Bilan OD.

                  - Poste comptable :
                            - Poste principal (2c, p3).
                            - Poste (1c, p5).
                            - Poste détaillé (2c, p6).

                  - Suffixe Nature de compte (1c, p8) :
                            - 1 = Définitif.
                            - 2 = Intermédiaire.
                            - 3 = Prévisionnel.
                            - 4 = Rejet prévisionnel.
                            - 5 = Rétro incomplet (retard).
                            - 6 = Complémentaire.</a:Description>
<c:Domain>
<o:PhysicalDomain Ref="o1448"/>
</c:Domain>
</o:Column>
