<a:Creator>OME08</a:Creator>
<a:ModificationDate>1366031707</a:ModificationDate>
<a:Modifier>u000252</a:Modifier>
<a:Comment>Country or Country Grouping code</a:Comment>
<a:DataType>char(3)</a:DataType>
<a:Length>3</a:Length>
<a:Column.Mandatory>1</a:Column.Mandatory>
<a:Annotation>Code pays (dans TCTY) si alpha, ou code regroupement (dans TSUPENT) si numérique.</a:Annotation>
<c:Domain>
<o:PhysicalDomain Ref="o1372"/>
</c:Domain>
</o:Column>
<o:Column Id="o2842">
