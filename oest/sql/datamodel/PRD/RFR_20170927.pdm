<a:Column.Mandatory>1</a:Column.Mandatory>
<a:DistinctValues>0</a:DistinctValues>
<a:Description>Oui indique que les primes facs seront comptabilisées directement dans oméga.</a:Description>
<a:Annotation>1 = directe</a:Annotation>
</o:Column>
