<a:Creator>FRXB156</a:Creator>
<a:ModificationDate>1326822858</a:ModificationDate>
<a:Modifier>FRIOLVI</a:Modifier>
<a:Comment>Allocation des comptes possible ?</a:Comment>
<a:DefaultValue>0</a:DefaultValue>
<a:DataType>tinyint</a:DataType>
<a:Column.Mandatory>1</a:Column.Mandatory>
<a:DistinctValues>0</a:DistinctValues>
<a:Description>Oui indique que l&#39;allocation automatique des comptes est utilisée dans la filiale.</a:Description>
<a:Annotation>1 possible</a:Annotation>
</o:Column>
<o:Column Id="o3657">
