<a:Annotation>valeurs possibles :
0 : sousc. en 3 phases,
1 : sousc. en 4 phases</a:Annotation>
</o:Column>
<o:Column Id="o3655">
<a:ObjectID>F3B57D6B-F56F-459A-B121-3D70F1B976CE</a:ObjectID>
<a:Name>Fac modification lock Y_N</a:Name>
<a:Code>FACMODLOC_B</a:Code>
