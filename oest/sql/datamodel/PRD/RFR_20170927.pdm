<a:Column.Mandatory>1</a:Column.Mandatory>
<a:Annotation>1 si la relance est à classer (conserver)</a:Annotation>
</o:Column>
<o:Column Id="o1642">
<a:ObjectID>B3F6F2AE-B94B-48B0-A3D8-B3C5B91E8215</a:ObjectID>
<a:Name>Reminder to delete Y N</a:Name>
<a:Code>RMDTODEL_B</a:Code>
<a:CreationDate>880027320</a:CreationDate>
<a:Creator>OME08</a:Creator>
<a:ModificationDate>880027320</a:ModificationDate>
<a:Modifier>OME08</a:Modifier>
<a:Comment>Relance à épurer</a:Comment>
<a:DataType>bit</a:DataType>
<a:Column.Mandatory>1</a:Column.Mandatory>
<a:Annotation>1 si la relance est à épurer (sera supprimée lors du prochain batch d&#39;épuration), ainsi que les lignes associées de TREMINUSR</a:Annotation>
</o:Column>
<o:Column Id="o1643">
<a:ObjectID>C68AB875-B1FD-4A53-9E34-733B3484F506</a:ObjectID>
<a:Name>Reminder country code</a:Name>
<a:Code>RMDCTY_CF</a:Code>
<a:CreationDate>880027320</a:CreationDate>
<a:Creator>OME08</a:Creator>
<a:ModificationDate>880027320</a:ModificationDate>
<a:Modifier>OME08</a:Modifier>
<a:Comment>Pays concerné par la relance</a:Comment>
<a:DefaultValue>&#39;&#39;</a:DefaultValue>
<a:DataType>char(3)</a:DataType>
<a:Length>3</a:Length>
<a:Column.Mandatory>1</a:Column.Mandatory>
<c:Domain>
