<a:ObjectID>4DAE775E-A342-4227-B8F4-B98ED51185D4</a:ObjectID>
<a:Name>Terrorism Accounting T code</a:Name>
<a:Code>TERRDETTRS_CF</a:Code>
<a:CreationDate>880027320</a:CreationDate>
<a:Creator>OME08</a:Creator>
<a:ModificationDate>1326890965</a:ModificationDate>
<a:Modifier>frumicm</a:Modifier>
<a:Comment>Poste comptable spécifique aux sinistres terrorisme</a:Comment>
<a:DataType>char(8)</a:DataType>
<a:Length>8</a:Length>
<a:DistinctValues>0</a:DistinctValues>
<a:AutoMigrated>1</a:AutoMigrated>
<a:Description>{\rtf1\ansi\ansicpg1252\deff0\deflang1036{\fonttbl{\f0\fnil\fcharset0 Times New Roman;}}
\viewkind4\uc1\pard\f0\fs20 Le poste comptable est en 4 parties :\par
\par
                  - 1er pr\&#39;e9fixe (1 caract\&#39;e8re, position 1) : \par
                            - 1 = Acceptation Non Vie.\par
                            - 2 = R\&#39;e9tro Non Vie.\par
                            - 3 = Acceptation Vie.\par
                            - 4 = R\&#39;e9tro Vie.\par
\par
                  - 2 eme pr\&#39;e9fixe (1c, p2) :\par
                            - 1 = Compte de R\&#39;e9sultat.\par
                            - 2 = Bilan.\par
                            - 3 = Compte de R\&#39;e9sultat OD.\par
                            - 4 = Bilan OD.\par
\par
                  - Poste comptable :\par
                            - Poste principal (2c, p3).\par
                            - Poste (1c, p5).\par
                            - Poste d\&#39;e9taill\&#39;e9 (2c, p6).\par
\par
                  - Suffixe Nature de compte (1c, p8) :\par
                            - 1 = D\&#39;e9finitif.\par
                            - 2 = Interm\&#39;e9diaire.\par
                            - 3 = Pr\&#39;e9visionnel.\par
                            - 4 = Rejet pr\&#39;e9visionnel.\par
                            - 5 = R\&#39;e9tro incomplet (retard).\par
                            - 6 = Compl\&#39;e9mentaire.\par
}
</a:Description>
