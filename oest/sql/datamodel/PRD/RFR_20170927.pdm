<a:Name>Capacity line number</a:Name>
<a:Code>CAPLIN_NT</a:Code>
<a:CreationDate>880027320</a:CreationDate>
<a:Creator>OME08</a:Creator>
<a:ModificationDate>880027320</a:ModificationDate>
<a:Modifier>OME08</a:Modifier>
<a:Comment>N° ligne capacité</a:Comment>
<a:DefaultValue>1</a:DefaultValue>
<a:DataType>smallint</a:DataType>
<a:Column.Mandatory>1</a:Column.Mandatory>
<a:DistinctValues>0</a:DistinctValues>
<a:Annotation>Utilisé pour les traités, pour distinguer les capacités prop et non prop. (1 ou 2), et pour les facs pour distinguer la ToP (1 à n)</a:Annotation>
