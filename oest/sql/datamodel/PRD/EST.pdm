<o:Column Id="o703">
<a:ObjectID>CF0741A2-E0FE-4319-8758-0E63DD0B2162</a:ObjectID>
<a:Name>Calculated amount</a:Name>
<a:Code>CALAMT_M</a:Code>
<a:CreationDate>880012980</a:CreationDate>
<a:Creator>OME08</a:Creator>
<a:ModificationDate>1584624853</a:ModificationDate>
<a:Modifier>U008652</a:Modifier>
<a:Comment>Montant proposé</a:Comment>
<a:DataType>decimal(18,3)</a:DataType>
<a:Length>18</a:Length>
<a:Precision>3</a:Precision>
<a:Description>L&#39;origine de ce montant dépend du poste extra-comptable concerné :

-  Sinistralité actuarielle 
Montant issu de la ventilation de la sinistralité des segments actuariels

-  Commissions variables
Taux défini en fonction du ratio de sinistralité et des conditions décrites en base de souscription

-  Loss corridor
Montant défini en fonction du ratio de sinistralité

-  Participation aux bénéfices
Montant déterminé en fonction du résultat et des conditions décrites en base de souscription

-  Participation aux pertes
Montant déterminé en fonction du résultat et des conditions décrites en base de souscription</a:Description>
<c:Domain>
<o:PhysicalDomain Ref="o473"/>
</c:Domain>
</o:Column>
