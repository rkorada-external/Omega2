<a:Creator>OME08</a:Creator>
<a:ModificationDate>1584624853</a:ModificationDate>
<a:Modifier>U008652</a:Modifier>
<a:Comment>Montant saisi de prime ultime</a:Comment>
<a:DataType>decimal(18,3)</a:DataType>
<a:Length>18</a:Length>
<a:Precision>3</a:Precision>
<a:Description>Ce montant est mise à jour :
   - lors de l&#39;acceptation du traité ou de la facultative
   - lors de la révision de l&#39;aliment en souscription 
   - lors de la saisie du montant manuel en révision des ultimes.</a:Description>
<c:Domain>
<o:PhysicalDomain Ref="o473"/>
</c:Domain>
</o:Column>
