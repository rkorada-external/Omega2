<a:Length>18</a:Length>
<a:Precision>3</a:Precision>
<a:Description>Pour les traités non proportionnels donnant lieu à calcul de burning cost et/ou à calcul de reconstitution, ce montant est calculé à partir de la prime retenue ultime et du montant de sinitre ultime retenu.</a:Description>
<c:Domain>
<o:PhysicalDomain Ref="o473"/>
</c:Domain>
</o:Column>
<o:Column Id="o1365">
