<a:DataType>decimal(18,3)</a:DataType>
<a:Length>18</a:Length>
<a:Precision>3</a:Precision>
<a:Description>Ce montant est soit égal au montant proposé ultime, soit égal au montant saisi ultime. 

Voir Règle de choix du lot 57</a:Description>
<c:Domain>
<o:PhysicalDomain Ref="o473"/>
</c:Domain>
