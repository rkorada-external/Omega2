<a:Creator>U001264</a:Creator>
<a:ModificationDate>1421328809</a:ModificationDate>
<a:Modifier>U001264</a:Modifier>
<a:Comment>If value is 0, amounts from this GAAP are not propagated to the following ones. If value is 1, amounts from this GAAP are propagated to the following ones.</a:Comment>
<a:DefaultValue>0</a:DefaultValue>
<a:DataType>bit</a:DataType>
<a:Column.Mandatory>1</a:Column.Mandatory>
</o:Column>
<o:Column Id="o1960">
