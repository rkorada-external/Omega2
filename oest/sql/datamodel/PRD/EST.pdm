<o:Table Id="o312">
<a:ObjectID>EAA6B785-67AE-4193-B157-1848E5FED22E</a:ObjectID>
<a:Name>Life estimate table2</a:Name>
<a:Code>TLIFEST</a:Code>
<a:CreationDate>1421328809</a:CreationDate>
<a:Creator>U001264</a:Creator>
<a:ModificationDate>1584629000</a:ModificationDate>
<a:Modifier>U008652</a:Modifier>
<a:Comment>Life estimate table</a:Comment>
<a:TotalSavingCurrency/>
<a:Description>{\rtf1\ansi\ansicpg1252\deff0\deflang1036{\fonttbl{\f0\fnil\fcharset0 Times New Roman;}}
{\*\generator Msftedit 5.41.21.2510;}\viewkind4\uc1\pard\f0\fs20 2013-12-10/ Omega2-Phase2B\par
- SGLA06: added TRN_NT to store Detailed Transaction Code (new primary key replacing ACMTRS_NT &amp; PRS_CF)\par
- EST50: added GAAP_NT &amp; DIFF_M to manage values by GAAPs\par
- SGLA03: added ACM_NF (wave 2C modification done in advance) to take into account monthly values\par
- EST24: added RETCTR_NF, RETSEC_NF, RETUWY_NF  (wave 2C modification done in advance) to indicate associated retro contract\par
\par
2013-12-11/ Omega2-Phase2B-SGLA03\par
- Added Accounting Month (ACM_NF) added to the primary key\par
\par
2014-01-10/ Omega2-Phase2B-SGLA06\par
- Modified code of Detailed transaction code (DETTRNCOD_CF)\par
\par
2014-01-24/ Omega2-Phase2B-EST50\par
- Added PROPAGATION_B boolean to store propagation preferences\par
- Batch: added BATCH_B boolean to indicate when a line has been created or updated by batches.\par
\par
2014-02-10/ Omega2-Phase2B-EST50\par
- Added ORIGAAP_CT column\par
\par
2014-02-10/ Omega2-Phase2B-SGLA06\par
- Added CALCULATED_B column\par
\par
2014-04-28/ Omega2-Phase2B-EST Life\par
- Reordering of columns + use of bit type for booleans\par
- Removed ORIGAAP_CT column\par
\par
2014-05-05/ Omega2-Phase2B-EST Life\par
- use of bit type for booleans on TLIFEST\par
- Final version\par
\par
}
</a:Description>
