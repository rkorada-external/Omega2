\pard\f0\fs20 EXT-IFRS17-903379 - REQ.03.4 - Expenses: add a table to store expenses ratios\par
\par
\lang1036 20/02/2024 : spira 110913 | 110814 | 110815 :\par

\pard 
{\listtext\f1\u10625?\tab}\ls1\widctlpar\fi-360\li720\kerning2\f1\fs22 TLUAERAT\~\par

\pard 
{\listtext\f1\u10625?\tab}\ls1\ilvl1\widctlpar\fi-360\li1440\cf1 Contract nature\par
{\listtext\f1 1\tab}UWY\par
{\listtext\f1 2\tab}LoB N2\cf0\par

\pard 
{\listtext\f1\u10625?\tab}\ls1\widctlpar\fi-360\li720 TEXPRAT\~\par

\pard 
{\listtext\f1\u10625?\tab}\ls1\ilvl1\widctlpar\fi-360\li1440\cf1 UWY\par

\pard\cf0\kerning0\f0\fs20\lang1033\par
}
