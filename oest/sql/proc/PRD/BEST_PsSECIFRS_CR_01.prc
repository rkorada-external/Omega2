-----------------------------
	SELECT 
	  SECIFRS.CTR_NF,
	  SECIFRS.END_NT,
	  SECIFRS.SEC_NF,
	  SECIFRS.UWY_NF,
	  SECIFRS.UW_NT,
	  SECIFRS.PRISRC_CT,
	  SECIFRS.CTRPRI_B,
	  SECIFRS.PRILR_R,
	  SECIFRS.EGPCUR_CF,
	  SECIFRS.PSTEGP_M,
	  SECIFRS.CUREGP_M,
	  SECIFRS.CANEGP_M,
	  SECIFRS.TTLEGP_M,
	  SECIFRS.GRPRATEINDEX_CT,
	  SECIFRS.GRPFIRCLO_D,
	  SECIFRS.GRPIFRSSEG_CT,
	  SECIFRS.GRPINIPRO_CF,
	  SECIFRS.PARRATEINDEX_CT,
	  SECIFRS.PARFIRCLO_D,
	  SECIFRS.PARIFRSSEG_CT,
	  SECIFRS.PARINIPRO_CF,
	  SECIFRS.LOCRATEINDEX_CT,
	  SECIFRS.LOCFIRCLO_D,
	  SECIFRS.LOCIFRSSEG_CT,
	  SECIFRS.LOCINIPRO_CF,
	  SECIFRS.DIV_NT UDIV_NT,
	  SECIFRS.GRPINISTS_CT,
	  SECIFRS.PARINISTS_CT,
	  SECIFRS.LOCINISTS_CT,
	  CR.CR_NF,
	  CR.CRTYP_CT,
