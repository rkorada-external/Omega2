SELECT @erreur = @@error
IF @erreur != 0
BEGIN
    RETURN @erreur
END

RETURN 0
GO

IF OBJECT_ID('dbo.PsSECIFRS_CR_01') IS NOT NULL
    PRINT '<<< CREATED PROCEDURE dbo.PsSECIFRS_CR_01 >>>'
ELSE
    PRINT '<<< FAILED CREATING PROCEDURE dbo.PsSECIFRS_CR_01 >>>'
GO

GRANT EXECUTE ON dbo.PsSECIFRS_CR_01 TO GOMEGA
GO

GRANT EXECUTE ON dbo.PsSECIFRS_CR_01 TO GDBBATCH
GO
