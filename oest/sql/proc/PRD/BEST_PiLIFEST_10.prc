INSERT INTO #PERIMETER 
SELECT * FROM BTRAV..EST_ESID0811_TLIFESTQ 
WHERE ACM_NF <> 13 
AND DETTRNCOD_CF IN (  SELECT (a.PCPTRS_CF + a.TRS_CF + a.SUBTRS_CF) as DETTRNCOD_CF 
                                       FROM BREF..TSUBTRS a 
                                     WHERE a. PCPTRS_CF = '43' 
                                         AND
                                               ( 
                                                 (a.PCPTRS_CF + a.TRS_CF + a.SUBTRS_CF) in (SELECT b.DETTRNCOD1_CF FROM BREF..TSUBTRSASSO b WHERE b.ASSOTYP_CT = '3') or
                                                 (a.PCPTRS_CF + a.TRS_CF + a.SUBTRS_CF) in (SELECT b.DETTRNCOD2_CF FROM BREF..TSUBTRSASSO b WHERE b.ASSOTYP_CT = '3') or
                                                 (a.PCPTRS_CF + a.TRS_CF + a.SUBTRS_CF) in (SELECT b.DETTRNCOD3_CF FROM BREF..TSUBTRSASSO b WHERE b.ASSOTYP_CT = '3') 
                                               ) 
                                   )

