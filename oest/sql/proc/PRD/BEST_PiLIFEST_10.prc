USE BEST
go
CREATE OR REPLACE PROCEDURE dbo.PiLIFEST_10
WITH EXECUTE AS CALLER AS

/* On insert dans la vue perimetre les positions trimestrielles des postes*/
CREATE TABLE #PERIMETER
(
  P_CTR_NF        UCTR_NF    NOT NULL,
  P_END_NT        UEND_NT    NOT NULL,
  P_SEC_NF        USEC_NF    NOT NULL,
  P_UWY_NF        UUWY_NF    NOT NULL,
  P_UW_NT         UUW_NT     NOT NULL,
  P_CRE_D         UUPD_D     NOT NULL,
  P_BALSHEY_NF    smallint   NOT NULL,
  P_BALSHTMTH_NF  tinyint    NOT NULL,
  P_ACY_NF        smallint   NOT NULL,
  P_GAAP_NT       tinyint    NOT NULL,
  P_DETTRNCOD_CF  char(5)    DEFAULT '' NOT NULL,
  P_ACM_NF        tinyint    DEFAULT 13 NOT NULL,
  P_PRS_CF        smallint   NOT NULL,
  P_ACMTRS_NT     smallint   NOT NULL,
  P_SSD_CF        USSD_CF    NOT NULL,
  P_CUR_CF        UCUR_CF    NOT NULL,
  P_ESTMNT_M      UAMT_M     NOT NULL,
  P_INDSUP_B      bit        DEFAULT 0  NOT NULL,
  P_ORICOD_LS     UL16       NULL,
  P_CREUSR_CF     UUPDUSR_CF NOT NULL,
  P_LSTUPD_D      UUPD_D     NOT NULL,
  P_LSTUPDUSR_CF  UUPDUSR_CF NOT NULL,
  P_ORICTR_NF     UCTR_NF    NULL,
  P_ORISEC_NF     USEC_NF    NULL,
  P_ORIUWY_NF     UUWY_NF    NULL,
  P_DIFF_M        UAMT_M     NULL,
  P_PROPAGATION_B bit        DEFAULT 0  NOT NULL,
  P_CALCULATED_B  bit        DEFAULT 0  NOT NULL,
  P_BATCH_B       bit        DEFAULT 0  NOT NULL
)

