  PERIMETER2_ORICOD_LS     UL16       NULL,
  PERIMETER2_CREUSR_CF     UUPDUSR_CF NOT NULL,
  PERIMETER2_LSTUPD_D      UUPD_D     NOT NULL,
  PERIMETER2_LSTUPDUSR_CF  UUPDUSR_CF NOT NULL,
  PERIMETER2_ORICTR_NF     UCTR_NF    NULL,
  PERIMETER2_ORISEC_NF     USEC_NF    NULL,
  PERIMETER2_ORIUWY_NF     UUWY_NF    NULL,
