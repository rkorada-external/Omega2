        or (RETCTR_NF!=NULL and TRNCOD_CF like '[24]%') )
select @erreur = @@error
if @erreur != 0
begin
  select @MsgAnomalie = "Erreur Gťnťration TACCSUP1 - Anomalie(s) liee(s) aux  postes comptables"
	goto ErreurAno
