********************************************************************************************************************************************************/
declare @erreur     	int,
		@error_type		int,
        @tran_imbr		bit,
        @MsgAnomalie    varchar(120),
        @NumMsgAnomalie    varchar(120),                                               -- MOD003 Nb Anomalies : Numťros des Erreurs Rencontrťes
        @MsgGlobalAnomalie    varchar(240),                                            -- MOD003 Anomalies GLobales Rencontrťes
		@cre_d			datetime,	/* date du jour */
		@entpery_nf		smallint,	/* annťe de saisie */
		@entpermth_nf 	tinyint,	/* mois de saisie */
		@spcend_d		datetime,	/* variable en sortie de PsCALEND_02 */
		@account_d		datetime,	/* variable en sortie de PsCALEND_02 */
		@closing_b		bit,		/* variable en sortie de PsCALEND_02 */
		@nbligne_testutisup	int,		/* nbre lignes de la table utilisateurs en entrťe */
		@nbligne_tempaccsup	int,		/* nbre lignes en sortie de traitement */
		@nbligne_tctrano	int,		/* MOD001 - nbre lignes en Anomalies */
		@max_trn_nt		numeric( 10, 0 ), /* numťro d'ťcriture maxi de BEST..TACCSUP */
		@nbligne_PosteOuverture	int,		-- nbre lignes des Postes d'Ouvertures - MOD004
		@Verif_d			datetime            -- Date de Verification - Si Conso/Social : Antťrieur < PeriodePrecedente, Sinon Date du Jour

select @erreur = 0
select @tran_imbr = 1
select @cre_d = getdate()
select @error_type = -1
select @MsgAnomalie = ""
select @NumMsgAnomalie = " - Autres Anomalies Trouvťes Nį "


