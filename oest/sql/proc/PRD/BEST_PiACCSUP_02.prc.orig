        SELECT DISTINCT RETCTR_NF, RETEND_NT, RETSEC_NF, 1, SSD_CF, "A", @p_usr_cf,  @error_type, NUMLINE_NT
        FROM btrav..EST_ESID0801_TESTUTISUP
        WHERE
