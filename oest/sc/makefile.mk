SYBLIBDIR = $(SYBASE)/${SYBASE_OCS}/lib
LDFLAGS	  = -L$(SYBLIBDIR) -L$(SHLIB_PATH)
CFLAGS    = -I. -I$(SYBASE)/${SYBASE_OCS}/include -I$(DINC2)
DBX       = -g -Wall

SUN_CC          = cc -D_FILE_OFFSET_BITS=64
SUN_LIBS        = -lm -lgen -lnsl -lposix4 -ldl
SUN_SYBLIBS     = -lct -lcs -lblk -lcomn -ltcl -lintl

HP_CC           = cc -c -Ae +FPZ
HP_LD           = ld /usr/ccs/lib/crt0.o +s
HP_LIBS         = -lm -lc
HP_SYBLIBS      = -lct -lcs -lblk -lcomn -ltcl -lintl

LINUX_CC	= gcc -fPIC -rdynamic -m32 -DSYB_LP64
LINUX_LIBS	= -lm -lc -lrt
LINUX_SYBLIBS	= -lblk -lct -lcs -lcomn -ltcl -lintl

