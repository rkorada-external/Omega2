#!/bin/ksh
#=============================================================================
# nom de l'application		: ESTIMATIONS - INVENTAIRE
#                                 Edition rapprochement retrocession
# nom du script SHELL		: ESID2533.cmd
# revision			: $Revision:   1.2  $
# date de creation		: 10/1997
# auteur			: CGI (KUHNA)
# references des specifications	: 
#-----------------------------------------------------------------------------
# description
#   Matching report print out   
#   sent to the principal establishment for each subsidary
#
# Job launched by ESID2530.cmd
#
#-----------------------------------------------------------------------------
# historiques des modifications
#===============================================================================
#set -x

# Call generic functions
. ${DUTI}/fctgen.cmd
. ${DUTI}/fctprint.cmd

. ${DCMD}/ESCD9002.cmd

# Initialisation of the Job
JOBINIT


 

NSTEP=${NJOB}_05
# if no file generated by the previous split
#---------------------------------------------------------------
if test ! -s ${DFILT}/${NJOB}_${IB}_ESTR2301_O.dat
then
  JOBEND
fi

NSTEP=${NJOB}_10
#
#---------------------------------------------------------------
LIBEL="Add last page number on each report page"
FWLP_I=${DFILT}/${NJOB}_${IB}_ESTR2301_O.dat
FWLP_O=${DFILT}/${NSTEP}_${IB}_ESTR2301_WLP_O.dat
EST_WLP

NSTEP=${NJOB}_15
#
#---------------------------------------------------------------
LIBEL="Remove temporary file"
RMFIL "${DFILT}/${NJOB}_${IB}_ESTR2301_O.dat"

NSTEP=${NJOB}_20
#subject : matching report print out
#Modif OG 01/10/02, l'edition ne sortira que ds INTRANET et plus sous papier
#---------------------------------------------------------------
LIBEL="Matching report print out in progress ..."
PRT_NAME=${PRTID}
PRN_OUT=WEB
PRN_I=${DFILT}/${NJOB}_10_${IB}_ESTR2301_WLP_O.dat
PRN_FMT="estr2310"
PRN

NSTEP=${NJOB}_15
# Delete temporary files
#-----------------------------------------------------------------------------
LIBEL="Delete temporary files"
RMFIL "${DFILT}/${NJOB}_*_${IB}*.dat"

JOBEND
