#set -x

# Call generic functions
. ${DUTI}/fctgen.cmd

# Job Initialisation
JOBINIT

# Variable initialisation 
# ------------------------------
#USR_CF='dbo'
USR_CF=`id -un`
NOT_DIGITAL=1
UNKNOWN=1
NB_FIELD=1
PROCESSED=1
PRE_TEST=1
CONSISTENCY_STATUS=0
FORMAT_STATUS=1
BATCH_MODE='batch'
TRN_MIN=0
CONTINUE="N"
CRE_D=$3

REPORT_FILE="${DTRANSFER}/${REMOTE_SITE}/to/${ENV_PREFIX}_ESIJ0790_REPORTFILE_${CRE_D}.dat"

NSTEP=${NJOB}_05
# Begin rm
#-----------------------------------------------------------------
LIBEL="Delete of GETSITES file "
#RMFIL "${DFILT}/${NJOB}_LOOP_*_GETSITES_*.dat"
rm -f ${DFILT}/${NJOB}_LOOP_*_GETSITES_*.dat


NSTEP=${NJOB}_10
# récupération filiale et établissement du nom de fichier passé en paramčtre
# reconstitution du nom original
# -------------------------------------------------------------------------------
# filiale
SSD_CF=`ls ${DFILT}/${NJOB}_LOOP_*.dat | cut -d'_' -f8`
# établissement
ESB_CF=`ls ${DFILT}/${NJOB}_LOOP_*.dat | cut -d'_' -f9`
#CSMENGINE
IS_CSMENGINE=`ls ${DFILT}/${NJOB}_LOOP_*.dat | cut -d'_' -f10`
# date closing
FILE_CLOSING_DATE=`ls ${DFILT}/${NJOB}_LOOP_*.dat | cut -d'_' -f11`
# date client
DATE_CLIENT=`ls ${DFILT}/${NJOB}_LOOP_*.dat | cut -d'_' -f12`
# heure client
HEURE_CLIENT=`ls ${DFILT}/${NJOB}_LOOP_*.dat | cut -d'_' -f13 | cut -d'.' -f1`
# id client
#ID_CLIENT=`ls ${DFILT}/${NJOB}_LOOP_*.dat | cut -d'_' -f14 | cut -d'.' -f1`
ID_CLIENT=1
# nom origine
NOM_ORIGINE=$DFILT/${NOM_PREFIX}_${SSD_CF}_${ESB_CF}_${IS_CSMENGINE}_${FILE_CLOSING_DATE}_${DATE_CLIENT}_${HEURE_CLIENT}_${ID_CLIENT}.dat
NOM_ORIGINE_SANS_REP=${NOM_PREFIX}_${SSD_CF}_${ESB_CF}_${IS_CSMENGINE}_${FILE_CLOSING_DATE}_${DATE_CLIENT}_${HEURE_CLIENT}_${ID_CLIENT}.dat


ANNEE=`echo ${DATE_CLIENT} | cut -d'-' -f1`
MOIS=`echo ${DATE_CLIENT} | cut -d'-' -f2`
JOUR=`echo ${DATE_CLIENT} | cut -d'-' -f3`
FILEMTH=`echo "${FILE_CLOSING_DATE:4:2}"`
FILEYEA=`echo "${FILE_CLOSING_DATE:0:4}"`

ARCHIVE_DATE=`date +"%Y%m%d%H%M%S"`
ARCHIVE_PREFIX=svg

REPERTOIRE_DESTINATION="${DTRANSFER}/${REP_DESTINATION}/from/"
PREP_NOM_FICHIER="${ENV_PREFIX}_ESIJ0800_AE_${SSD_CF}_${ESB_CF}_${DATE_CLIENT}_${ID_CLIENT}-${IS_CSMENGINE}.dat"


if [ ! -f ${DFILI}/${ENV_PREFIX}_ESIJ0790_LEDGER_TRN_NT.dat ]
then
  touch ${DFILI}/${ENV_PREFIX}_ESIJ0790_LEDGER_TRN_NT.dat
fi

NSTEP=${NJOB}_02
#Begin isql
#-----------------------------------------------------------------------------
LIBEL="Selection of the largest TRN_NT from BEST..TACCSUP before insertion"
ISQL_BASE="BEST"
ISQL_QRY="select max(TRN_NT) from BEST..TACCSUP where ssd_cf = ${SSD_CF} and esb_cf = ${ESB_CF}"
ISQL_O=${DFILT}/${NSTEP}_${IB}_ISQL_O.log
ISQL_FRES=${DFILT}/${NSTEP}_${IB}_ISQLRES_O.dat
ISQL_RES

MAXTRN_NT=`cat ${ISQL_FRES}`
let MAXTRN_NT=MAXTRN_NT

echo "${SSD_CF}~${ESB_CF}~${MAXTRN_NT}" > ${DFILT}/${NSTEP}_${IB}_ESIJ0790_LEDGER_TRN_NT.dat

NSTEP=${NJOB}_04
#------------------------------------------------------------------------------
LIBEL="Delete SSD/ESB from TRN_NT file"
SORT_WDIR=${SORTWORK}
SORT_CMD=`CFTMP`
SORT_I="${DFILI}/${ENV_PREFIX}_ESIJ0790_LEDGER_TRN_NT.dat 1000 1"
SORT_O="${DFILT}/${NSTEP}_${IB}_ESIJ0790_LEDGER_TRN_NT.dat 1000 1"
INPUT_TEXT ${SORT_CMD} <<EOF
/FIELDS PROJSSD_CF         1:1 -  1:,
        PROJESB_CF         2:1 -  2:
/CONDITION CONDSSD ( PROJSSD_CF = "${SSD_CF}" ) AND ( PROJESB_CF = "${ESB_CF}" )
/OUTFILE ${SORT_O}
/OMIT CONDSSD
exit
EOF
SORT


NSTEP=${NJOB}_06
#------------------------------------------------------------------------------
LIBEL="Insert SSD/ESB into TRN_NT file"
SORT_WDIR=${SORTWORK}
SORT_CMD=`CFTMP`
SORT_I="${DFILT}/${NJOB}_02_${IB}_ESIJ0790_LEDGER_TRN_NT.dat 1000 1"
SORT_I2="${DFILT}/${NJOB}_04_${IB}_ESIJ0790_LEDGER_TRN_NT.dat 1000 1"
SORT_O="${DFILI}/${ENV_PREFIX}_ESIJ0790_LEDGER_TRN_NT.dat"
INPUT_TEXT ${SORT_CMD} <<EOF
/OUTFILE ${SORT_O} 
exit
EOF
SORT


NSTEP=${NJOB}_10
#renommer le fichier en entrée
#--------------------------------------------------
LIBEL="Getting the work file ${DFILT}/${NOM_ORIGINE}"
EXECKSH "mv ${DFILT}/${NJOB}_LOOP_*.dat ${NOM_ORIGINE}"

# Recuperation de la norme du fichier
NORME=`echo ${IS_CSMENGINE} | awk -F"NG" '{ print $2}'`

NSTEP=${NJOB}_11
#Check of date field in file's name
#--------------------------------------------------
LIBEL="Check of date field in file's name"

date "+%Y%m%d" -d "${FILE_CLOSING_DATE}" > /dev/null  2>&1
is_closingDate=$?
date "+%Y%m%d" -d "${DATE_CLIENT}" > /dev/null  2>&1
is_clientDate=$?

if [ "${is_closingDate}" = 1 ] || [ "${is_clientDate}" = 1 ]
then
	  #Archive the file
		#-----------------------------------------------------------------
		LIBEL="Archive the file."
		EXECKSH_MODE=P
		EXECKSH "gzip -c ${NOM_ORIGINE} > ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}.gz"
		ECHO_LOG " WARNING - incorrect format of date in file's name"
		echo "${NOM_ORIGINE_SANS_REP};KO;incorrect format of date in file's name" >> ${REPORT_FILE}
		mv ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}.gz ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}_INCORRECT_FORMAT_DATE_IN_FILENAME.gz
  	if [ -f ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ]
  	then
	 		mv ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ${DTRANSFER}/${REMOTE_SITE}/fromsave/
  	fi
		rm -f ${DFILT}/${NJOB}_*_${IB}_*.dat
		JOBEND
fi
	

PARM_IS_POSXI17L=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep I17L | grep PARM_POSX | awk -F"~" '{ print $3 }'`
PARM_IS_POSXI17P=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep PARM_POSX | awk -F"~" '{ print $3 }'`
if [ "X${PARM_IS_POSXI17L}" == "X_POSX" ] || [ "X${PARM_IS_POSXI17P}" == "X_POSX" ]
then
	export PARM_IS_POSX=_POSX
fi

NSTEP=${NJOB}_13
#---------------------------------------------------------------
LIBEL="Ckecking All Extend Period conditions"
if [ "X${NORME}" = "XI17G" ]
then
  # If I17G norme, the traitement is permitted

	PARM_REQCODPOS_CT=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep I17G | grep PARM_REQCOD_CT | awk -F"~" '{ print $3 }' | grep POS | grep -v POSB`
	PARM_REQCODINV_CT=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep I17G | grep PARM_REQCOD_CT | awk -F"~" '{ print $3 }' | grep INV | grep -v INVB`
	PARM_BALSHTMTH_NF=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep I17G | grep PARM_BALSHTMTH_NF | awk -F"~" '{ print $3 }'`
	PARM_BALSHTYEA_NF=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep I17G | grep PARM_BALSHTYEA_NF | awk -F"~" '{ print $3 }'`
	PARM_CLODAT_D=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep I17G | grep PARM_CLODAT_D | awk -F"~" '{ print $3 }'`
	PARM_IS_POSX=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep I17G | grep PARM_POSX | awk -F"~" '{ print $3 }'`
	CONTINUE="Y"

	NSTEP=${NJOB}_13A_I17G
	# Archive the file
	#-----------------------------------------------------------------
	LIBEL="Archive the file."
	EXECKSH_MODE=P
	EXECKSH "gzip -c ${NOM_ORIGINE} > ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}.gz"

	
	if [ "X${PARM_REQCODPOS_CT}" != "X" ] && [ "X${PARM_IS_POSX}" = "X_POSX" ]
	then
		ECHO_LOG " WARNING - Posting POS I17G AE in Extend Period is not permitted"
		echo "${NOM_ORIGINE_SANS_REP};KO;Posting POS I17G AE in Extend Period is not permitted" >> ${REPORT_FILE}
		mv ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}.gz ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}_POS_FORBIDDEN_IN_EXTEND_PERIOD.gz
  	if [ -f ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ]
  	then
	 		mv ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ${DTRANSFER}/${REMOTE_SITE}/fromsave/
  	fi
		rm -f ${DFILT}/${NJOB}_*_${IB}_*.dat
		JOBEND
	fi
else
  # If 117P or I17L norme, verify the parameters of extend period to go on traitement
  PARM_REQCODPOS_CT=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep ${NORME} | grep PARM_REQCOD_CT | awk -F"~" '{ print $3 }' | grep POS | grep -v POSB`
	PARM_REQCODINV_CT=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep ${NORME} | grep PARM_REQCOD_CT | awk -F"~" '{ print $3 }' | grep INV | grep -v INVB`
	PARM_BALSHTMTH_NF=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep ${NORME} | grep PARM_BALSHTMTH_NF | awk -F"~" '{ print $3 }'`
	PARM_BALSHTYEA_NF=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep ${NORME} | grep PARM_BALSHTYEA_NF | awk -F"~" '{ print $3 }'`
	PARM_CLODAT_D=`cat ${DFILI}/${ENV_PREFIX}_ESIJ0790_ESIJ0791_01_PARM.dat | grep ${NORME} | grep PARM_CLODAT_D | awk -F"~" '{ print $3 }'`
	

	NSTEP=${NJOB}_13A
	# Archive the file
	#-----------------------------------------------------------------
	LIBEL="Archive the file."
	EXECKSH_MODE=P
	EXECKSH "gzip -c ${NOM_ORIGINE} > ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}.gz"
	
	if [ "X${PARM_IS_POSX}" = "X_POSX" ]
	then
		#------------------------------------------------------------------------------
		LIBEL="Look for Extend Period informations for ledger"
		BCP_WAY="OUT"
		BCP_VER="+"
		BCP_O=${DFILT}/${NSTEP}_${IB}_${SSD_CF}_${ESB_CF}_${NORME}_EXTEND_PERIOD_O.dat
		BCP_QRY="exec BEST..PiTI17CLOPER_01 ${SSD_CF}, ${ESB_CF}, '${CRE_D}', '${NORME}'"
		BCP
		
		is_ok=`cat ${DFILT}/${NSTEP}_${IB}_${SSD_CF}_${ESB_CF}_${NORME}_EXTEND_PERIOD_O.dat | awk -F"~" '{ print $4}'`
		
		if [ "X${PARM_REQCODINV_CT}" != "X" ] && [ "X${PARM_IS_POSX}" = "X_POSX" ]
		then
			ECHO_LOG " WARNING - Posting INV I17P/L AE in Extend Period is not permitted"
			echo "${NOM_ORIGINE_SANS_REP};KO;Posting INV I17P/L AE in Extend Period is not permitted" >> ${REPORT_FILE}
			mv ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}.gz ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}_INV_FORBIDDEN_IN_EXTEND_PERIOD.gz
	  	if [ -f ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ]
  		then
	 			mv ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ${DTRANSFER}/${REMOTE_SITE}/fromsave/
  		fi
			rm -f ${DFILT}/${NJOB}_*_${IB}_*.dat
			JOBEND
		fi
		
		if [ "X${is_ok}" = "XKO" ]
		then
			CONTINUE="N"
			ECHO_LOG " WARNING - Posting AE in Extend Period is not permitted"
			echo "${NOM_ORIGINE_SANS_REP};KO;Posting AE in Extend Period is not permitted" >> ${REPORT_FILE}
			mv ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}.gz ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}_REJECTED_EXTEND_PERIOD_INVALID.gz
  		if [ -f ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ]
  		then
	  		mv ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ${DTRANSFER}/${REMOTE_SITE}/fromsave/
  		fi
			rm -f ${DFILT}/${NJOB}_*_${IB}_*.dat
			JOBEND
		else
		  CONTINUE="Y"
		fi
	else
	  CONTINUE="Y"
	fi
fi

if [ "X${CONTINUE}" = "XN" ]
then
	ECHO_LOG " WARNING - Posting AE in Extend Period is not permitted"
	JOBEND
fi

NSTEP=${NJOB}_14
#---------------------------------------------------------------
LIBEL="Ckecking retrieve of inventory type"
if [ "X${PARM_REQCODINV_CT}" = "X" ] && [ "X${PARM_REQCODPOS_CT}" = "X" ]
then
	mv ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}.gz ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}_REJECTED_NO_INVENTORY_RETRIEVED.gz
	ECHO_LOG " WARNING - Problem when retrieving inventory type for ${NORME}, Aucune AE inseree"
	echo "WARNING - Problem when retrieving inventory type for ${NORME}, Aucune AE inseree" >> ${REPORT_FILE}
	STEPWARNING 1
	JOBEND
fi


if [ "X${PARM_REQCODINV_CT}" != "X" ]
then
	NSTEP=${NJOB}_15
	# TYPINV INV Force NATURE to 9
	#-----------------------------------------------------------------------------
	LIBEL="TYPINV INV Force NATURE to 9"
	SORT_WDIR=${SORTWORK}
	SORT_CMD=`CFTMP`
	SORT_I="${NOM_ORIGINE} 1000 1"
	SORT_O="${DFILT}/${NSTEP}_${IB}_SORT_NEW_ACCUP_O.dat"
	INPUT_TEXT $SORT_CMD <<EOF
	/FIELDS  ZONE1       1: - 37:,
        	 ZONE2      39: - 40:
	/DERIVEDFIELD NATURE "9~"
	/COPY
	/OUTFILE ${SORT_O}
	/REFORMAT ZONE1,NATURE, ZONE2
	exit
EOF
	SORT
fi

if [ "X${PARM_REQCODPOS_CT}" != "X" ]
then
	NSTEP=${NJOB}_15
	# TYPINV POS Force NATURE to 10
	#-----------------------------------------------------------------------------
	LIBEL="TYPINV POS Force NATURE to 10"
	SORT_WDIR=${SORTWORK}
	SORT_CMD=`CFTMP`
	SORT_I="${NOM_ORIGINE} 1000 1"
	SORT_O="${DFILT}/${NSTEP}_${IB}_SORT_NEW_ACCUP_O.dat"
	INPUT_TEXT $SORT_CMD <<EOF
	/FIELDS  ZONE1       1: - 37:,
        	 ZONE2      39: - 40:
	/DERIVEDFIELD NATURE "10~"
	/COPY
	/OUTFILE ${SORT_O}
	/REFORMAT ZONE1,NATURE, ZONE2
	exit
EOF
	SORT
fi

NSTEP=${NJOB}_15A
#------------------------------------------------------------------------------
LIBEL="Check if SSD and ESB are in TI17CLOPER"
BCP_WAY="OUT"
BCP_VER="+"
BCP_O=${DFILT}/${NSTEP}_${IB}_${SSD_CF}_${ESB_CF}_${NORME}_CHECK_SSD_ESB.dat
BCP_QRY="exec BEST..PsTI17CLOPER_03 ${SSD_CF}, ${ESB_CF}, '${CRE_D}', '${NORME}'"
BCP


NSTEP=${NJOB}_15B
# if there's an incorrect SSD or ESB, file is rejected
#-----------------------------------------------------------------------------
LIBEL="if there's an incorrect SSD or ESB, file is rejected"
is_ok=`cat ${DFILT}/${NJOB}_15A_${IB}_${SSD_CF}_${ESB_CF}_${NORME}_CHECK_SSD_ESB.dat | awk -F"~" '{ print $2}'`
if [ ${is_ok} = 0 ] 
then
	ECHO_LOG " WARNING - Entity not eligible to ${NORME} No AE inseree"
	echo "${NOM_ORIGINE_SANS_REP};KO;Entity not eligible to ${NORME} No AE inseree" >> ${REPORT_FILE}
	mv ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}.gz ${DTRANSFER}/${REMOTE_SITE}/fromsave/${ARCHIVE_PREFIX}_${ARCHIVE_DATE}_${NOM_ORIGINE_SANS_REP}_REJECTED_WRONG_SSD_ESB_TI17CLOPER_${SSD_CF}_${ESB_CF}.gz
  if [ -f ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ]
  then
	  mv ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ${DTRANSFER}/${REMOTE_SITE}/fromsave/
  fi
	rm -f ${DFILT}/${NJOB}_*_${IB}_*.dat
	JOBEND
fi


NSTEP=${NJOB}_16
# Verify All the lines have SSD and ESB corresponding to file name
#-----------------------------------------------------------------------------
LIBEL="Verify All the lines have SSD and ESB corresponding to file name"
SORT_WDIR=${SORTWORK}
SORT_CMD=`CFTMP`
SORT_I="${DFILT}/${NJOB}_15_${IB}_SORT_NEW_ACCUP_O.dat 1000 1"
SORT_O="${DFILT}/${NSTEP}_${IB}_CORRECT_SSD_ESB_AE_O.dat 1000 1"
SORT_O2="${DFILT}/${NSTEP}_${IB}_WRONG_SSD_ESB_AE_O.dat 1000 1"
INPUT_TEXT $SORT_CMD <<EOF
/FIELDS SSD_CF 		  	1:1 - 1:EN,
				ESB_CF        2:1 - 2:EN
/COPY
/CONDITION SSD ( SSD_CF EQ ${SSD_CF} ) AND ( ESB_CF EQ ${ESB_CF} )
/OUTFILE ${SORT_O}
/INCLUDE SSD
/OUTFILE ${SORT_O2}
/OMIT SSD
exit
EOF
SORT

NSTEP=${NJOB}_16A
# if there's an incorrect SSD or ESB, file is rejected
#-----------------------------------------------------------------------------
LIBEL="if there's an incorrect SSD or ESB, file is rejected"
nb_LineWrong=`wc -l ${DFILT}/${NJOB}_16_${IB}_WRONG_SSD_ESB_AE_O.dat | cut -d" " -f1`
if [ ${nb_LineWrong} != 0 ] 
then
