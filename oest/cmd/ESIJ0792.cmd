let NbLineTotal=${NbLineNoZero}+${NbLineZero}
let NbLine=${NbLineNoZero}

if [ ${NbLineTotal} -gt ${Limite} ]
then
while [[ ${NbLine} -ge ${Limite} ]]; do
  let i=i+1
  let itail=${NbLine}-${Limite}

  head -${Limite} ${DFILT}/${NJOB}_70_${IB}_SORT_NEW_ACCUP_NOZERO_O.dat > ${DFILT}/${NSTEP}_${IB}_SORT_NEW_ACCUP_NOZERO_O_${i}.dat
  tail -${itail} ${DFILT}/${NJOB}_70_${IB}_SORT_NEW_ACCUP_NOZERO_O.dat > ${DFILT}/${NSTEP}_${IB}_SORT_NEW_ACCUP_NOZERO_O_tail_${itail}.dat
  mv  ${DFILT}/${NSTEP}_${IB}_SORT_NEW_ACCUP_NOZERO_O_tail_${itail}.dat ${DFILT}/${NJOB}_70_${IB}_SORT_NEW_ACCUP_NOZERO_O.dat

  NbLine=`wc -l ${DFILT}/${NJOB}_70_${IB}_SORT_NEW_ACCUP_NOZERO_O.dat | awk -F" " '{ print $1 }'`
done

let i=i+1
mv ${DFILT}/${NJOB}_70_${IB}_SORT_NEW_ACCUP_NOZERO_O.dat ${DFILT}/${NSTEP}_${IB}_SORT_NEW_ACCUP_NOZERO_O_${i}.dat
NbFile=${i}

fi

NSTEP=${NJOB}_90
# Renumerotation du nombre de ligne NUMILNE_NT
#--------------------------------------------------
LIBEL="Renumerotation du nombre de ligne NUMLINE_NT"
j=1

if [ ${NbFile} -ge 2 ] || [ ${NbLineTotal} -ge ${Limite} ]
then
while [[ ${j} -le ${NbFile} ]]; do
  LIBEL="Renumerotation du nombre de ligne NUMLINE_NT"
  PRG=ESTC2345
  FPRM=`CFTMP`
  INPUT_TEXT ${FPRM} << EOF
  NUM ${Limite}
  exit
EOF
  export ${PRG}_PRM=${FPRM}
  export ${PRG}_I1=${DFILT}/${NJOB}_80_${IB}_SORT_NEW_ACCUP_NOZERO_O_${j}.dat
  export ${PRG}_O1=${DFILT}/${NSTEP}_${IB}_SORT_NEW_ACCUP_NOZERO_O_RENUM_${j}.dat
  EXECPRG

PREP_NOM_FICHIER="${ENV_PREFIX}_ESIJ0800_AE_${SSD_CF}_${ESB_CF}_${DATE_CLIENT}_${j}-${IS_CSMENGINE}.dat"
EXECKSH "cp $DFILT/${NSTEP}_${IB}_SORT_NEW_ACCUP_NOZERO_O_RENUM_${j}.dat ${REPERTOIRE_DESTINATION}/${PREP_NOM_FICHIER}"
  let j=j+1
done

else

NSTEP=${NJOB}_100
# Déplacer le fichier dans le répertoire d'entrée du ESIJ0800
# Le nom est celui attendu par l'ESIJ0800
#--------------------------------------------------
LIBEL="Move of file in input directory of ESIJ0800"

EXECKSH "mv $DFILT/${NJOB}_70_${IB}_SORT_NEW_ACCUP_NOZERO_O.dat ${REPERTOIRE_DESTINATION}/${PREP_NOM_FICHIER}"

fi

echo "${NOM_ORIGINE_SANS_REP};OK;" >> ${REPORT_FILE}

if [ -f ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ]
then
	EXECKSH "mv ${DTRANSFER}/${REMOTE_SITE}/from/${NOM_ORIGINE_SANS_REP}*zip ${DTRANSFER}/${REMOTE_SITE}/fromsave/"
fi



rm -f ${DFILT}/${NJOB}_*_${IB}_*.dat

JOBEND
