function TRACE_EXPORTS_EVAL {
   fexport=$1
   echo
   echo '#-------------------------------------------------------------------------'  2>&1 | ${TEE}
   echo "Trace  of export variables of job $NJOB: $fexport "  2>&1 | ${TEE}
   echo '#-------------------------------------------------------------------------'  2>&1 | ${TEE}
   
	while  read -r line
	do
			expo=`echo $line| cut -d' ' -f1`
			str=`echo $line | cut -d' ' -f2-1000`
			f=`echo $str | cut -d'=' -f1`
			value=`echo $str | cut -d'=' -f2-1000`
			if [ "$expo" = "export" ]
			then
					val=` eval echo  $value`
					printf '#---> %-30s = %s\n'  $f $val  2>&1 | ${TEE}
			fi
	done <"$fexport"
	
	echo '#-------------------------------------------------------------------------'  2>&1 | ${TEE}
   
}	


#---------------------------------------------------------------------------------------------------------------------------------|----------------------------------|
# IS_ESCD9001|                IFRS4-local                                |                EBS                                     |            IFRS17                |
#---------------------------------------------------------------------------------------------------------------------------------|----------------------------------|
# ESCD9001   | grep "${CHAIN_NAME}~"   TI17PERMFIL.dat                                                                            |                                  |
#---------------------------------------------------------------------------------------------------------------------------------|grep "${IDF_CT}~" TI17PERMFIL.dat |
# ESFD9001   | grep ${CHAIN_NAME}_${IDF_CT}~  TI17PERMFIL.dat            |grep ${CHAIN_NAME}_${param_Context_id}~  TI17PERMFIL.dat|  								 |
#----------------------------------------------------------------------- | -------------------------------------------------------|----------------------------------|


if [ "${IS_ESCD9001}" = "Y" ]  
then
		. $DFILT/${NCHAIN}_${IB}_PERM.dat
		TRACE_EXPORTS_EVAL  $DFILT/${NCHAIN}_${IB}_PERM.dat
# --- ESFD9001 ------------------------------------------------------------------------------------------------------------------------------------
else  
	# --- IFRS17 ------------------------------------------------------------------------------------------------------------------------------------
	if [[ "${ARG2_CHN_1}" = I17* || "${ARG2_CHN_1}" = EBS* ||   "${ARG2_CHN_1}" = IFRS*  ]] 
	then
        . $DFILT/${NCHAIN}_${IDF_CT}_${IB}_PERM.dat
        TRACE_EXPORTS_EVAL  $DFILT/${NCHAIN}_${IDF_CT}_${IB}_PERM.dat
	else 
		#---------ESFD9001 / EBS ------------------------------------------------------------------------------------------------------------------------------------
		if [[ "${EST_PLAN}" = *PLAN2.dat || "${EST_PLAN}" = ""  ]] 
		then
			. $DFILT/${NCHAIN}_${param_Context_id}_${IB}_PERM.dat
			TRACE_EXPORTS_EVAL  $DFILT/${NCHAIN}_${param_Context_id}_${IB}_PERM.dat
		#---------ESFD9001 / #IFRS4 / Local ------------------------------------------------------------------------------------------------------------------------------------
		else 
			. $DFILT/${NCHAIN}_${IDF_CT}_${IB}_PERM.dat
			TRACE_EXPORTS_EVAL  $DFILT/${NCHAIN}_${IDF_CT}_${IB}_PERM.dat
		fi

	fi
fi


