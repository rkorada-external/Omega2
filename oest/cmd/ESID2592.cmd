# Call generic functions
. ${DUTI}/fctgen.cmd
. ${DUTI}/fctprint.cmd
. ${DUTI}/fctsplit.cmd

. ${DCMD}/ESCD9002.cmd

# Job Initialisation
JOBINIT


NSTEP=${NJOB}_05
#if no file generated by the previous split
#---------------------------------------------------------------
if test ! -s ${DFILT}/${NJOB}_${IB}_ESTR7620_O.dat
then
  JOBEND
fi

NSTEP=${NJOB}_10
#
#---------------------------------------------------------------
LIBEL="Add last page number on each report page"
FWLP_I=${DFILT}/${NJOB}_${IB}_ESTR7620_O.dat
FWLP_O=${DFILT}/${NSTEP}_${IB}_ESTR7620_WLP_O.dat
EST_WLP

NSTEP=${NJOB}_15
#
#---------------------------------------------------------------
LIBEL="Remove temporary file"
RMFIL "${DFILT}/${NJOB}_${IB}_ESTR7620_O.dat"

NSTEP=${NJOB}_20
#subject : retrocession closing period synthesis and verification print out
#Modif OG 01/10/02, l'edition ne sortira que ds INTRANET et plus sous papier
#--------------------------------------------------------------------------
LIBEL="Print out launch"
PRT_NAME=${PRTID}
PRN_OUT=WEB
PRN_I=${DFILT}/${NJOB}_10_${IB}_ESTR7620_WLP_O.dat
PRN_FMT="estr7620"
PRN

########################
# Erase temporary files #
########################

NSTEP=${NJOB}_25
LIBEL="Erase temporary files"
RMFIL "${DFILT}/${NJOB}*_${IB}_*.dat" 

JOBEND
