#-----------------------------------------------------------------------------
# Description : 
#   Print out of acceptance closing period synthesis sent to the principal 
#   establishment for each subsidary 
#
#   Launch C program ESTR7610 
#
# job launched by ESID2090.cmd
#
#-----------------------------------------------------------------------------
# historiques des modifications
#===============================================================================
#set -x

# Call generic functions
. ${DUTI}/fctgen.cmd
. ${DUTI}/fctprint.cmd

. ${DCMD}/ESCD9002.cmd

# Initialisation of the Job
JOBINIT


NSTEP=${NJOB}_05
#if no file generated by the previous split
#---------------------------------------------------------------
if test ! -s ${DFILT}/${NJOB}_${IB}_ESTR7610_O.dat
then
  JOBEND
fi

NSTEP=${NJOB}_10
#
#---------------------------------------------------------------
LIBEL="Add last page number on each report page"
FWLP_I=${DFILT}/${NJOB}_${IB}_ESTR7610_O.dat
FWLP_O=${DFILT}/${NSTEP}_${IB}_ESTR7610_WLP_O.dat
EST_WLP

NSTEP=${NJOB}_15
#
#---------------------------------------------------------------
LIBEL="Remove temporary file"
RMFIL "${DFILT}/${NJOB}_${IB}_ESTR7610_O.dat"

NSTEP=${NJOB}_20
#subject : Acceptance closing period print out
#Modif OG 01/10/02, l'edition ne sortira que ds INTRANET et plus sous papier
#---------------------------------------------------------------
LIBEL="Start printing"
PRT_NAME=${PRTID}
PRN_OUT=WEB
PRN_I=${DFILT}/${NJOB}_10_${IB}_ESTR7610_WLP_O.dat
PRN_FMT="estr7610"
#PRN


########################
# Erase temporary files #
########################

NSTEP=${NJOB}_25
LIBEL="Erase temporary files"
RMFIL "${DFILT}/${NJOB}*_${IB}_*.dat" 
     
JOBEND
