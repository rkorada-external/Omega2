#----------------------------------------------------------------------------
# FUNCTION: SEG_STORE_RESULT
#
# Input parameters:
#	- PERIMETER_SCOPE: Perimeter scope (ASM or RETRO)
#	- PERIMETER_SCOPE_CT : Perimeter scope reference value ("1" for ASM, "2" for RETRO)
#
# Subject: Function that store the resuls generated by the segmentation 
# process. There are 3 files to handle:
# - updated perimeter
# - results
# - errors
# Return 0 if OK, >0 otherwise
#---------------------------------------------------------------
# modifications chronology:
#   02/12/2014    Nicolas Gasull    Store segmentation results from $DFILP instead of in any specific $DFILP's subfolder for UW Abstract use
#----------------------------------------------------------------------------

SEG_STORE_RESULT() {
	# Used to log the function name
	SEG_STORE_RESULT="SEG_STORE_RESULT"
	
	# used to identify generated files of this function
	FILE_ID="2017_${HOST_PRDSIT}_${PERIMETER_SCOPE}"
	
	# The target perimeter table depends on the production site
	PERIMETER_TABLE_PRDSIT=${PERIMETER_TABLE}_${HOST_PRDSIT}
	
	SEG_LOG_DEBUG "Start insertion for production site ${HOST_PRDSIT}"

	#-----------------------------------
	# Updated perimeter
	# - Delete previous perimeter data related to the current production site
	# - Insert the new perimeter data
	#-----------------------------------
	time_1=`date +%s`; 
	
	# Insert the results in the temporary table
	NSTEP=${NJOB}_INSERT_PERIM_${PERIMETER_SCOPE}
	LIBEL='Insert segmentation updated perimeter'
	BCP_WAY="IN"; BCP_VER=""; BCP_RMINFILE="NO"; BCP_TRUNCATE="NO"; BCP_FS=$'\x1c'
	BCP_I=${DFILT}/${NJOB}_${IB}_SEG_${HOST_PRDSIT}_${PERIMETER_SCOPE}_PERIMETER_TMP_UPDATED.dat
	BCP_TABLE=BTRAVI..${PERIMETER_TABLE_PRDSIT}_TMP
	BCP
	
	# Once the insert is done, drop the previous perimeter table
	SEG_LOG_DEBUG "Drop old perimeter table: ${PERIMETER_TABLE_PRDSIT}"
	
	NSTEP=${NJOB}_DROP_OLD_PERIM_${PERIMETER_SCOPE}
	LIBEL="Drop old perimeter table"
	ISQL_BASE="BTRAVI"
	ISQL_QRY="drop table ${PERIMETER_TABLE_PRDSIT}"
	ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_DROP_PERIMETER_TABLE.log
	ISQL
	
	# Then rename the temporary one
	SEG_LOG_DEBUG "Rename perimeter table: ${PERIMETER_TABLE_PRDSIT}_TMP"
	
	NSTEP=${NJOB}_RENAME_TMP_PERIM_${PERIMETER_SCOPE}
	LIBEL="Rename temporary table"
	ISQL_BASE="BTRAVI"
	ISQL_QRY="sp_rename ${PERIMETER_TABLE_PRDSIT}_TMP, ${PERIMETER_TABLE_PRDSIT}"
	ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_RENAME_PERIMETER_TABLE.log
	ISQL
	
	time_2=`date +%s`; 
	SEG_LOG_INFO "End of new perimeter insert in $(expr $time_2 - $time_1) sec"

	# =======================================
	# Fetch & prepare batch plan
	# =======================================
	
	# Extract the batch plan and retrieve run to update to completed status & to incomplete status (depend on the group option)
	# only for run that are "in progress" status (to not update "in error" segmentation runs)
	NSTEP=${NJOB}_EXTRACT_BATCH_PLAN_${PERIMETER_SCOPE}
	LIBEL='Extract Batch plan'
	BCP_WAY="OUT"; BCP_VER="+";
	BCP_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_BATCH_PLAN.dat
	BCP_QRY=" select bp.SGT_NT, bp.SGTVER_NT, bp.SGTRUN_NT, bp.GROUPRUN_B, tr.SGTRESTABNME_LL, tr.SGTERRTABNME_LL, segType.SGTTYPMOD_NT
				from BSEG..TSEGBATCHPLAN bp inner join BSEG..TSEGRUN tr on tr.SGTRUN_NT=bp.SGTRUN_NT 
				inner join BEST..TSEGMENTATION seg on seg.SGT_NT = tr.SGT_NT and seg.SGTVER_NT = bp.SGTVER_NT
				inner join BEST..TSEGTYPE segType on seg.SGTTYP_NT = segType.SGTTYP_NT
				where bp.SGTSCOPE_CT='${PERIMETER_SCOPE_CT}'"	
	BCP
	echo "[INFO] Output file will be: $BCP_O"
	echo "[INFO] Running BCP with query:"
	echo "$BCP_QRY"
	
	PRDSIT_RUNS=$(awk 'BEGIN {FS = OFS = "~"} NR==FNR{if( $4 == "0" && $7 != "2"){a=a " "$3}} END{print a}' ${DFILT}/${NSTEP}_${IB}_${FILE_ID}_BATCH_PLAN.dat)
	GROUP_RUNS=$(awk 'BEGIN {FS = OFS = "~"} NR==FNR{if( $4 == "1" && $7 != "2"){a=a " "$3}} END{print a}' ${DFILT}/${NSTEP}_${IB}_${FILE_ID}_BATCH_PLAN.dat)
	RETRO_PRDSIT_RUNS=$(awk 'BEGIN {FS = OFS = "~"} NR==FNR{if( $4 == "0" && $7 == "2"){a=a " "$3}} END{print a}' ${DFILT}/${NSTEP}_${IB}_${FILE_ID}_BATCH_PLAN.dat)
	RETRO_GROUP_RUNS=$(awk 'BEGIN {FS = OFS = "~"} NR==FNR{if( $4 == "1" && $7 == "2"){a=a " "$3}} END{print a}' ${DFILT}/${NSTEP}_${IB}_${FILE_ID}_BATCH_PLAN.dat)

	awkstring='BEGIN {FS = "~"; OFS = "'$'\x1c''"} NR==FNR{print "RUN_" $3 "_WITHSEG=" $1 , $3 , $2 , "" }'
	eval $(awk "$awkstring" ${DFILT}/${NSTEP}_${IB}_${FILE_ID}_BATCH_PLAN.dat)

	# Fetch result & errors table names in RUN_[run]_RESTABNME and RUN_[run]_ERRTABNME
	# Also prepare SGT_NT SGTRUN_NT SGTVER_NT prefix for lines to export to UWa
	awkstring='
		BEGIN {FS = "~"; OFS = "'$'\x1c''"}
		NR==FNR {
			print "RUN_" $3 "_SEG=" $1
			print "RUN_" $3 "_WITHSEG=\"" $1 , $3 , $2 , "\""
			print "RUN_" $3 "_RESTABNME=\"" $5 "\""
			print "RUN_" $3 "_ERRTABNME=\"" $6 "\""
		}'
	eval $(awk "$awkstring" ${DFILT}/${NSTEP}_${IB}_${FILE_ID}_BATCH_PLAN.dat)

	RUNS_TO_COMPLETE="$PRDSIT_RUNS $RETRO_PRDSIT_RUNS"
	RUNS_TO_INCOMPLETE=
	
	# Group results: take care of "incomplete" (4) status	
	if [ -n "$GROUP_RUNS" ] || [ -n "$RETRO_GROUP_RUNS" ]; then
		if [ "${LAST_PRDSITCF}" = "${HOST_PRDSIT}" ]; then
			# US batch → mark all group runs complete
			RUNS_TO_COMPLETE="$RUNS_TO_COMPLETE $GROUP_RUNS $RETRO_GROUP_RUNS"
		else
			# APAC or EU batch → mark group runs incomplete
			RUNS_TO_INCOMPLETE="$RUNS_TO_INCOMPLETE $GROUP_RUNS $RETRO_GROUP_RUNS"
		fi
	fi
	
	if [ "${LAST_PRDSITCF}" = "${HOST_PRDSIT}" ]; then
	 # US batch → everything complete
		RUNS_TO_COMPLETE="$PRDSIT_RUNS $GROUP_RUNS $RETRO_PRDSIT_RUNS $RETRO_GROUP_RUNS"
		RUNS_TO_INCOMPLETE=
		NEW_TABLE_RUNS="$PRDSIT_RUNS"	
		RETRO_TABLE_RUNS="$RETRO_PRDSIT_RUNS" 
	else
		# APAC/EU batch
		RUNS_TO_COMPLETE="$PRDSIT_RUNS $RETRO_PRDSIT_RUNS"
		RUNS_TO_INCOMPLETE="$GROUP_RUNS $RETRO_GROUP_RUNS"
	fi
	
	if [ "${FIRST_PRDSITCF}" = "${HOST_PRDSIT}" ]; then
		# APAC → create tables for PRDSIT + GROUP + retro runs
		NEW_TABLE_RUNS="$PRDSIT_RUNS $GROUP_RUNS"
		RETRO_TABLE_RUNS="$RETRO_PRDSIT_RUNS $RETRO_GROUP_RUNS"
	else
		# EU/US → only PRDSIT tables 
		NEW_TABLE_RUNS="$PRDSIT_RUNS"
		RETRO_TABLE_RUNS="$RETRO_PRDSIT_RUNS"		
	fi
	
	RUNS_TO_INSERT="$PRDSIT_RUNS $GROUP_RUNS"
	RETRO_RUNS_TO_INSERT="$RETRO_PRDSIT_RUNS $RETRO_GROUP_RUNS"

	# Prepare comma separated run lists for batch update
	RUNLIST_TO_COMPLETE=
	RUNLIST_TO_INCOMPLETE=
	for run in $RUNS_TO_COMPLETE ; do
		RUNLIST_TO_COMPLETE="$RUNLIST_TO_COMPLETE,$run"
	done
	for run in $RUNS_TO_INCOMPLETE ; do
		RUNLIST_TO_INCOMPLETE="$RUNLIST_TO_INCOMPLETE,$run"
	done
	
	# Strip first comma
	RUNLIST_TO_COMPLETE="${RUNLIST_TO_COMPLETE:1}"
	RUNLIST_TO_INCOMPLETE="${RUNLIST_TO_INCOMPLETE:1}"
	
	# =======================================
	# Generate results
	# =======================================
	
	# Create results tables
	for run in $NEW_TABLE_RUNS ; do
		NSTEP=${NJOB}_CREATE_RESULT_TABLES_${run}_${PERIMETER_SCOPE}
		LIBEL="Create results & error tables for run $run"
		ISQL_BASE="BSEG"
		ISQL_QRY=$(sed "s/#sgtrunNt/$run/g" "$DDDL/BSEG_SEGRESULTSCREATE.tab")
		ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_CREATE_RESULT_TABLES_${run}_${PERIMETER_SCOPE}.log
		ISQL
	done
	
	# Retro runs: new logic (extra column SGTRUL_NT)
	for run in $RETRO_TABLE_RUNS; do
		NSTEP=${NJOB}_CREATE_RETRO_RESULT_TABLES_${run}_${PERIMETER_SCOPE}
		LIBEL="Create results & error tables for retro run $run (with SGTRUL_NT)"
		ISQL_BASE="BSEG"
		# ISQL_QRY=$(sed "s/#sgtrunNt/$run/g" "$DDDL/BSEG_SEGRESULTSCREATE_RETRO_PROP.tab")
		ISQL_QRY="use BSEG
go

-- Create results table
CREATE TABLE TSEGRUNRES_${run} (
SGMT_NF              USGMT_NF                       not null,
SGTLVL_NT            int                            not null,
SEGCTRTYP_CT         UBANVAL_CT                     null,
CTR_NF               UCTR_NF                        not null,
UWY_NF               UUWY_NF                        not null,
UW_NT                UUW_NT                         not null,
SEC_NF               USEC_NF                        not null,
RTO_NF               UCLI_NF                        not null,
SSD_CF				USSD_CF						   not null,
SGTRUL_NT			int							   null
)
lock datapages
go

GRANT ALL on TSEGRUNRES_${run} to GDBBATCH
GRANT SELECT on TSEGRUNRES_${run} to GOMEGA
GRANT SELECT on TSEGRUNRES_${run} to GCONSULT
GRANT SELECT on TSEGRUNRES_${run} to dbo
go

-- Create error results table
create table TSEGRUNERR_${run} (
SEGCTRTYP_CT         UBANVAL_CT                     null,
CTR_NF               UCTR_NF                        not null,
UWY_NF               UUWY_NF                        not null,
UW_NT                UUW_NT                         not null,
SEC_NF               USEC_NF                        not null,
END_NT               UEND_NT                        not null,
RTO_NF               UCLI_NF                        not null,
PLC_NT               UPLC_NT                        null,
SSD_CF				USSD_CF						   not null,
SGTERR_CT            char(12)                       not null,
SGTERR_LL            UL255                          null,

)
lock datapages
go

GRANT ALL on TSEGRUNERR_${run} to GDBBATCH
GRANT SELECT on TSEGRUNERR_${run} to GOMEGA
GRANT SELECT on TSEGRUNERR_${run} to GCONSULT
GRANT SELECT on TSEGRUNERR_${run} to dbo
go"
		ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_CREATE_RETRO_RESULT_TABLES_${run}_${PERIMETER_SCOPE}.log
		ISQL
	done


	# Insert results
	time_3=`date +%s`; 
	SEG_LOG_DEBUG "Insert new results for ${HOST_PRDSIT} and scope ${PERIMETER_SCOPE}"
	
	for run in $RUNS_TO_INSERT ; do
		# Handle run results
		RUN_RESULTS_FILE=${DFILT}/${NJOB}_${IB}_SEG_${HOST_PRDSIT}_${PERIMETER_SCOPE}_PERIMETER_TMP_RESULT_$run.dat
		RUN_RESULTS_SORT=${DFILT}/${NJOB}_${IB}_${HOST_PRDSIT}_${PERIMETER_SCOPE}_SEG_SORT_RESULT_$run.dat

		nameref restabnme_var="RUN_${run}_RESTABNME"
		nameref errtabnme_var="RUN_${run}_ERRTABNME"
		
		if [ -s "$RUN_RESULTS_FILE" ] ; then
		
			NSTEP=${NJOB}_SORT_RESULTS_$run_${PERIMETER_SCOPE}
			LIBEL="Sorting results of run $run to improve index creation performance"
			SORT_WDIR=${SORTWORK}
			SORT_CMD=`CFTMP`
			SORT_I="$RUN_RESULTS_FILE 1000 1"
			SORT_O="$RUN_RESULTS_SORT"
			SORT_FS=$'\x1c'
			INPUT_TEXT $SORT_CMD <<EOF
			/FIELDS
				SGMT_NF 1:1 -  1:,
				CTR_NF 4:1 -  4:,
				UWY_NF 5:1 -  5:EN,
				UW_NT 6:1 -  6:EN,
				SEC_NF 7:1 -  7:EN,
				RTO_NF 8:1 -  8:EN,
				SGTLVL_NT 2:1 -  2:EN
			/KEYS
				SGMT_NF,
				CTR_NF,
				UWY_NF,
				UW_NT,
				SEC_NF,
				RTO_NF
			/CONDITION
				LVL0 SGTLVL_NT = 0
			/INCLUDE
				LVL0
exit
EOF

			SORT

			NSTEP=${NJOB}_INSERT_RESULTS_$run_${PERIMETER_SCOPE}
			LIBEL="Insert segmentation results for run $run"
			BCP_WAY="IN"; BCP_VER=""; BCP_RMINFILE="NO"; BCP_TRUNCATE="NO"; BCP_FS=$'\x1c'
			BCP_I=$RUN_RESULTS_SORT
			BCP_TABLE=${restabnme_var}
			BCP
			
			NSTEP=${NJOB}_CLEAN_RUNAGG_${run}
			LIBEL="Delete previous segmentation aggregated results for run $run"
			ISQL_BASE="BSEG"
			ISQL_QRY="DELETE FROM BSEG..TSEGRUNAGG WHERE SGTRUN_NT=$run"
			ISQL_O=${DFILT}/${NSTEP}_${IB}_CLEAN_RUNAGG_${run}.log
			ISQL
			
			NSTEP=${NJOB}_INSERT_RUNAGG_${run}
			LIBEL="Insert segmentation aggregated results for run $run"
			ISQL_BASE="BSEG"
			ISQL_QRY="INSERT INTO BSEG..TSEGRUNAGG (SGTRUN_NT, SGMT_NF, ROWCOUNT_NT, SGTRUL_NT) SELECT $run, SGMT_NF, count(*), null FROM ${restabnme_var} WHERE SGTLVL_NT = 0 GROUP BY SGMT_NF"
			ISQL_O=${DFILT}/${NSTEP}_${IB}_INSERT_RUNAGG_${run}.log
			ISQL
		fi
		
		# Handle run errors
		RUN_ERRORS_FILE=${DFILT}/${NJOB}_${IB}_SEG_${HOST_PRDSIT}_${PERIMETER_SCOPE}_PERIMETER_TMP_ERROR_$run.dat
		
		if [ -s "$RUN_ERRORS_FILE" ] ; then
			NSTEP=${NJOB}_INSERT_ERRORS_$run_${PERIMETER_SCOPE}
			LIBEL="Insert segmentation error results for run $run"
			BCP_WAY="IN"; BCP_VER=""; BCP_RMINFILE="NO"; BCP_TRUNCATE="NO"; BCP_FS=$'\x1c'
			BCP_TABLE=${errtabnme_var}
			BCP_I=$RUN_ERRORS_FILE
			BCP
		fi
	done

	# New loop for retro runs with extra column SGTRUL_NT
	for run in $RETRO_RUNS_TO_INSERT; do
		
		RUN_RETRO_RESULTS_FILE=${DFILT}/${NJOB}_${IB}_SEG_${HOST_PRDSIT}_${PERIMETER_SCOPE}_PERIMETER_TMP_RESULT_$run.dat
        RUN_RETRO_RESULTS_SORT=${DFILT}/${NJOB}_${IB}_${HOST_PRDSIT}_${PERIMETER_SCOPE}_SEG_SORT_RESULT_$run.dat  

		nameref restabnme_var="RUN_${run}_RESTABNME"
		nameref errtabnme_var="RUN_${run}_ERRTABNME"

		if [ -s "$RUN_RETRO_RESULTS_FILE" ]; then
			NSTEP=${NJOB}_SORT_RETRO_RESULTS_$run_${PERIMETER_SCOPE}
			LIBEL="Sorting retro results of run $run with extra column SGTRUL_NT"
			SORT_WDIR=${SORTWORK}
			SORT_CMD=`CFTMP`
			SORT_I="$RUN_RETRO_RESULTS_FILE 1000 1"
			SORT_O="$RUN_RETRO_RESULTS_SORT"
			SORT_FS=$'\x1c'
			INPUT_TEXT $SORT_CMD <<EOF
		/FIELDS
			SGMT_NF 1:1 -  1:,
			CTR_NF 4:1 -  4:,
			UWY_NF 5:1 -  5:EN,
			UW_NT 6:1 -  6:EN,
			SEC_NF 7:1 -  7:EN,
			RTO_NF 8:1 -  8:EN,
			SGTLVL_NT 2:1 -  2:EN,
			SGTRUL_NT 9:1 -  9:EN
		/KEYS
			SGMT_NF,
			CTR_NF,
			UWY_NF,
			UW_NT,
			SEC_NF,
			RTO_NF,
			SGTRUL_NT
		/CONDITION
			LVL0 SGTLVL_NT = 0
		/INCLUDE
			LVL0
exit			
EOF
				
		SORT

			NSTEP=${NJOB}_INSERT_RESULTS_$run_${PERIMETER_SCOPE}
			LIBEL="Insert segmentation results for run $run"
			BCP_WAY="IN"; BCP_VER=""; BCP_RMINFILE="NO"; BCP_TRUNCATE="NO"; BCP_FS=$'\x1c'
			BCP_I=$RUN_RETRO_RESULTS_SORT
			BCP_TABLE=${restabnme_var}
			BCP

			NSTEP=${NJOB}_CLEAN_RUNAGG_${run}
			LIBEL="Delete previous segmentation aggregated results for run $run"
			ISQL_BASE="BSEG"
			ISQL_QRY="DELETE FROM BSEG..TSEGRUNAGG WHERE SGTRUN_NT=$run"
			ISQL_O=${DFILT}/${NSTEP}_${IB}_CLEAN_RUNAGG_${run}.log
			ISQL

			NSTEP=${NJOB}_INSERT_RUNAGG_${run}
			LIBEL="Insert segmentation aggregated results for run $run"
			ISQL_BASE="BSEG"
			ISQL_QRY="INSERT INTO BSEG..TSEGRUNAGG (SGTRUN_NT, SGMT_NF, ROWCOUNT_NT, SGTRUL_NT) SELECT $run, SGMT_NF, count(*), SGTRUL_NT FROM ${restabnme_var} WHERE SGTLVL_NT = 0 GROUP BY SGMT_NF, SGTRUL_NT"
			ISQL_O=${DFILT}/${NSTEP}_${IB}_INSERT_RUNAGG_${run}.log
			ISQL
		fi
		
		# Handle run errors
		RUN_ERRORS_FILE=${DFILT}/${NJOB}_${IB}_SEG_${HOST_PRDSIT}_${PERIMETER_SCOPE}_PERIMETER_TMP_ERROR_$run.dat
		
		if [ -s "$RUN_ERRORS_FILE" ] ; then
			NSTEP=${NJOB}_INSERT_ERRORS_$run_${PERIMETER_SCOPE}
			LIBEL="Insert segmentation error results for run $run"
			BCP_WAY="IN"; BCP_VER=""; BCP_RMINFILE="NO"; BCP_TRUNCATE="NO"; BCP_FS=$'\x1c'
			BCP_TABLE=${errtabnme_var}
			BCP_I=$RUN_ERRORS_FILE
			BCP
		fi
	done
	

	# Create index after results insertion for performance improvement
	for run in $PRDSIT_RUNS ; do
		NSTEP=${NJOB}_CREATE_INDEX_${run}_${PERIMETER_SCOPE}
		LIBEL="Create index for run $run results table"
		ISQL_BASE="BSEG"
		ISQL_QRY=$(sed "s/#sgtrunNt/$run/g" "$DDDL/BSEG_SEGRESULTSINDEX.tab")
		ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_CREATE_INDEX_${run}_${PERIMETER_SCOPE}.log
		ISQL
	done
	
	
	for run in $RETRO_TABLE_RUNS; do
		NSTEP=${NJOB}_CREATE_INDEX_RETRO_${run}_${PERIMETER_SCOPE}
		LIBEL="Create index for retro run $run results table"
		ISQL_BASE="BSEG"
		# ISQL_QRY=$(sed "s/#sgtrunNt/$run/g" "$DDDL/BSEG_RETROPROP_SEGRESULTSINDEX.tab")
		ISQL_QRY="use BSEG
go

create unique index ISEGRUNRES_${run}_00 on TSEGRUNRES_${run} (
	SGMT_NF ASC,
	CTR_NF ASC,
	UWY_NF ASC,
	UW_NT ASC,
	SEC_NF ASC,
	RTO_NF ASC,
	SGTLVL_NT ASC,
	SGTRUL_NT ASC
	
)
go

create unique index ISEGRUNERR_${run}_00 on TSEGRUNERR_${run} (
	CTR_NF ASC,
	UWY_NF ASC,
	UW_NT ASC,
	SEC_NF ASC,
	END_NT ASC,
	RTO_NF ASC
)
go"
		ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_CREATE_INDEX_${run}_${PERIMETER_SCOPE}.log
		ISQL
	done


	# =======================================
	# Put results in DFILP for future UW export use
	# =======================================
	for run in $RUNS_TO_INSERT ; do
		RUN_RESULTS_FILE=${DFILT}/${NJOB}_${IB}_SEG_${HOST_PRDSIT}_${PERIMETER_SCOPE}_PERIMETER_TMP_RESULT_$run.dat
		
		if [ -s "$RUN_RESULTS_FILE" ] ; then
			nameref runsegmentation_variable=RUN_${run}_SEG
			nameref runprefix_variable=RUN_${run}_WITHSEG
			
			NSTEP="${NJOB}_${PERIMETER_SCOPE}_SAVE_RESULTS_FOR_UWEXPORT_${run}"
			LIBEL="Saving results of run #${run} for UW Export (segmentation ${runsegmentation_variable})"
			STEPSTART
			# Prefixing results with run ID for UW export
			sed -e "s/^/${runprefix_variable}/" $RUN_RESULTS_FILE > "$DFILP/${ENV_PREFIX}_SEG_${HOST_PRDSIT}_${PERIMETER_SCOPE}_RESULT_${runsegmentation_variable}.dat"
			STEPEND $?
		fi
	done

	time_4=`date +%s`; 
	SEG_LOG_INFO "End of results insert in $(expr $time_4 - $time_3) sec"
	
	# =======================================
	# Update run status
	# =======================================
	
	if [ -n "$RUNLIST_TO_COMPLETE" ]; then
		NSTEP=${NJOB}_UPDATE_RUN_COMPLETE_${PERIMETER_SCOPE}
		LIBEL="Update run status for complete runs"
		ISQL_BASE="BSEG"
		ISQL_QRY="update TSEGRUN set SGTRUNSTS_CT='5', LSTUPD_D=getDate(), LSTUPDUSR_CF=suser_name() where SGTRUN_NT in (${RUNLIST_TO_COMPLETE}) and SGTRUNSTS_CT in ('2','4') "
		ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_UPDATE_RUN_COMPLETE_${PERIMETER_SCOPE}.log
		ISQL
	fi
	
	if [ -n "$RUNLIST_TO_INCOMPLETE" ]; then
		NSTEP=${NJOB}_UPDATE_RUN_INCOMPLETE_${PERIMETER_SCOPE}
		LIBEL="Update run status for incomplete runs"
		ISQL_BASE="BSEG"
		ISQL_QRY="update TSEGRUN set SGTRUNSTS_CT='4', LSTUPD_D=getDate(), LSTUPDUSR_CF=suser_name() where SGTRUN_NT in (${RUNLIST_TO_INCOMPLETE}) and SGTRUNSTS_CT='2' "
		ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_UPDATE_RUN_INCOMPLETE_${PERIMETER_SCOPE}.log
		ISQL
	fi
	
	#-----------------------------------
	# Rename temporary perimeter files
	# for each production site (if the schema changed
	# the perimeter files for other production sites
	# may have changed)
	#-----------------------------------
	for prdsit_cf in `find ${DFILT}/ -name ${NJOB}_${IB}_SEG_*_${PERIMETER_SCOPE}_PERIMETER_TMP_UPDATED.dat -printf "%f\n" | sed "s/${NJOB}_${IB}_SEG_\(.*\)\_${PERIMETER_SCOPE}\_PERIMETER\_TMP\_UPDATED\.dat/\1/"`
	do
		SEG_LOG "Replace perimeter file for production site ${prdsit_cf}"
		mv -f ${DFILT}/${NJOB}_${IB}_SEG_${prdsit_cf}_${PERIMETER_SCOPE}_PERIMETER_TMP_UPDATED.dat ${DFILP}/${ENV_PREFIX}_SEG_${prdsit_cf}_${PERIMETER_SCOPE}_PERIMETER.dat
	done
	
	#-----------------------------------
	# Update status of runs to completed
	# or incomplete if also need to be run by another production site
	# (in case of scope = all production site)
	#-----------------------------------
	time_7=`date +%s`; 

	# Update scheduled status with related run status
	NSTEP=${NJOB}_UPDATE_SCHEDULED_STATUS_${PERIMETER_SCOPE}
	LIBEL="Update scheduled run status"
	ISQL_BASE="BSEG"
	ISQL_QRY="update BSEG..TSEGRUNSCHED set rs.sgtrunsts_ct = r.sgtrunsts_ct, LSTUPD_D=getDate(), LSTUPDUSR_CF=suser_name() "
	ISQL_QRY+="FROM BSEG..TSEGRUNSCHED rs "
	ISQL_QRY+="inner join BSEG..TSEGRUN r on rs.sgt_nt = r.sgt_nt and rs.sgtrundat_d <= r.sgtrundat_d and rs.sgtrunsts_ct not in ('5', '6') "
	ISQL_QRY+="where r.scheduled_b = 1 and r.sgtrundat_d = convert(datetime, '${RUN_DATE}', 112)"
	ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_SCHEDULED_RUN_STATUS_${PERIMETER_SCOPE}.log
	ISQL
	
	time_8=`date +%s`; 
	SEG_LOG_INFO "End of status update in $(expr $time_8 - $time_7) sec"
	
	
	# =======================================
	# Handle run obsoletion
	# =======================================
	
	# Actually delete obsolete runs and their results (previous night)
	NSTEP=${NJOB}_DELETE_OBSOLETE_RUNS_${PERIMETER_SCOPE}
	LIBEL="Delete obsolete runs and associated results/errors"
	ISQL_BASE="BSEG"
	ISQL_QRY="-- Execute SP
		BSEG.dbo.PdSEGCLEANOBSOLETE_01"
	ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_DELETE_OBSOLETE_RUNS_${PERIMETER_SCOPE}.log
	ISQL

	# Mark old runs as obsolete
	OLDRUN_QRY="
		select tr.SGTRUN_NT
		from BSEG..TSEGRUN tr
		inner join BSEG..TSEGBATCHPLAN bp on bp.SGT_NT=tr.SGT_NT and bp.SGTSCOPE_CT=tr.SGTSCOPE_CT and bp.SGTRUN_NT <> tr.SGTRUN_NT
		inner join BEST..TSEGMENTATION seg on seg.SGT_NT = tr.SGT_NT
		inner join BEST..TSEGTYPE segType on seg.SGTTYP_NT = segType.SGTTYP_NT
		where tr.SGTSCOPE_CT='${PERIMETER_SCOPE_CT}' and tr.SGTSIMU_B=0 and tr.SGTSNAP_B=0 and tr.SGTOBSOLETE_B=0"
	
	# Keep group results if not last prod site processing
	if [ "$HOST_PRDSIT" != "$LAST_PRDSITCF" ] ; then
		OLDRUN_QRY+="
		and segType.SGTMGTLVL_CT <> '1'"
	fi

	NSTEP=${NJOB}_HANDLE_OLD_RUNS_${PERIMETER_SCOPE}
	LIBEL="Handle previous runs and mark them as obsolete"
	ISQL_BASE="BSEG"
	ISQL_QRY="UPDATE TSEGRUN SET SGTOBSOLETE_B=1, LSTUPD_D=getDate(), LSTUPDUSR_CF=suser_name() WHERE SGTRUN_NT in ($OLDRUN_QRY)"
	ISQL_O=${DFILT}/${NSTEP}_${IB}_${FILE_ID}_DELETE_OBSOLETE_RUNS_${PERIMETER_SCOPE}.log
	ISQL
	
	# Remove temporary files
	NSTEP=${NJOB}_CLEAN_TMPS_${PERIMETER_SCOPE}
	LIBEL="Cleaning run results temporary files"
	STEPSTART
	# Additional rm with wildcards
	rm -f ${DFILT}/${NJOB}_${IB}_SEG_${HOST_PRDSIT}_${PERIMETER_SCOPE}_PERIMETER_TMP_RESULT_*.dat ${DFILT}/${NJOB}_${IB}_SEG_${HOST_PRDSIT}_${PERIMETER_SCOPE}_PERIMETER_TMP_ERROR_*.dat ${DFILT}/${NJOB}_${IB}_${HOST_PRDSIT}_${PERIMETER_SCOPE}_SEG_SORT_RESULT_*.dat
	STEPEND $?
	
	SEG_LOG_INFO "End of full process in $(expr $time_8 - $time_1) sec"

	return 0
}
